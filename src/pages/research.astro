            {row.spreadChange !== null && (
              <span class={`text-xs font-mono shrink-0 w-14 ${row.spreadChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                {row.spreadChange >= 0 ? '+' : ''}{fmt(row.spreadChange)}
              </span>
            )}
          </div>
        ))}
      </div>

      <!-- ── Ratio chart ───────────────────────────────────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.ratioChartHeading}</h3>
      <div class="space-y-2 mb-8">
        {fragSeries.map(row => (
          <div class="flex items-center gap-3">
            <span class="text-xs font-mono text-gray-500 w-16 text-right shrink-0">{row.label}</span>
            <div class="flex-1 bg-gray-100 rounded-sm h-6 relative">
              <div
                class={`h-6 rounded-sm ${row.ratio === maxFRatio ? 'bg-accent' : 'bg-accent/55'}`}
                style={`width: ${maxFRatio > 0 ? Math.round((row.ratio / maxFRatio) * 100) : 0}%`}
              />
