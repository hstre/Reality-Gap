      <p class="text-xs text-gray-400 uppercase tracking-widest mb-2">{tc.label}</p>
      <h1 class="text-3xl font-light text-gray-900 mb-3" style="font-family: Georgia, serif;">
        {tc.heading}
      </h1>
      <p class="text-gray-500 text-base max-w-2xl">{tc.subheading}</p>
    </div>

    <!-- Prominent disclaimer -->
    <div class="border border-amber-300 bg-amber-50 rounded-md px-6 py-5 mb-10">
      <p class="text-sm font-semibold text-amber-800 mb-2">{tc.disclaimer.heading}</p>
      <p class="text-sm text-amber-700 leading-relaxed">{tc.disclaimer.body}</p>
    </div>

    <!-- ── Preliminary takeaways ──────────────────────────────────────────── -->
    <section class="mb-10">
      <div class="flex items-baseline gap-3 mb-3">
        <h2 class="text-base font-semibold text-gray-800">{tc.takeaways.heading}</h2>
        <span class="text-xs text-gray-400">{tc.takeaways.windowNote(retroN)}</span>
      </div>
      <div class="space-y-2">
        {tc.takeaways.items.map((item: { kind: string; text: string }) => {
          const kindLabel = (tc.takeaways.kindLabels as any)[item.kind] ?? item.kind;
          const kindColor = item.kind === 'suggests'
            ? 'bg-teal-50 border-teal-200 text-teal-700'
            : item.kind === 'limits'
            ? 'bg-orange-50 border-orange-200 text-orange-700'
            : 'bg-gray-50 border-gray-200 text-gray-500';
          return (
            <div class="flex items-start gap-3 border rounded-md px-4 py-3 text-sm" style={`border-color: inherit;`}>
              <span class={`text-xs font-medium px-1.5 py-0.5 rounded shrink-0 mt-0.5 border ${kindColor}`}>{kindLabel}</span>
              <span class="text-gray-700">{item.text}</span>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ── 1. Cross-index snapshot ───────────────────────────────────────── -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.indexSection.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.indexSection.note}</p>

      <div class="border border-gray-200 rounded-md overflow-hidden mb-3">
        <table class="table-rg">
          <thead>
            <tr class="bg-gray-50 text-xs uppercase text-gray-500 tracking-wide">
              <th class="text-left px-4 py-2 font-medium">{tc.indexSection.colIndex}</th>
              <th class="text-right px-4 py-2 font-medium">{tc.indexSection.colN}</th>
              <th class="text-right px-4 py-2 font-medium">{tc.indexSection.colP25}</th>
              <th class="text-right px-4 py-2 font-medium font-bold">{tc.indexSection.colMedian}</th>
              <th class="text-right px-4 py-2 font-medium">{tc.indexSection.colP75}</th>
            </tr>
          </thead>
          <tbody>
            {indexStats.map(row => (
              <tr class="border-t border-gray-100">
                <td class="px-4 py-2 text-gray-700 font-medium">{row.idx}</td>
                <td class="px-4 py-2 text-right font-mono text-gray-500">{row.n}</td>
                <td class="px-4 py-2 text-right font-mono text-gray-500">{fmt(row.p25)}</td>
                <td class="px-4 py-2 text-right font-mono font-semibold text-gray-900">{fmt(row.med)}</td>
                <td class="px-4 py-2 text-right font-mono text-gray-500">{fmt(row.p75)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400">{tc.indexSection.footnote}</p>
    </section>

    <!-- ── 2. Distribution ───────────────────────────────────────────────── -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.distribution.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">
        {tc.distribution.note
          .replace('{n}', String(valid.length))
          .replace('{total}', String(summaries.length))
          .replace('{notCovered}', String(notCoveredCount))
          .replace('{nearBoundary}', String(nearBoundaryCount))}
      </p>

      <!-- Bar chart -->
      <div class="space-y-2 mb-5">
        {buckets.map(b => (
          <div class="flex items-center gap-3">
            <span class="text-xs font-mono text-gray-500 w-14 text-right shrink-0">{b.label}</span>
            <div class="flex-1 bg-gray-100 rounded-sm h-6 relative">
              <div
                class="h-6 rounded-sm bg-accent/70"
                style={`width: ${maxBucketCount > 0 ? Math.round((b.count / maxBucketCount) * 100) : 0}%`}
              />
            </div>
            <span class="text-xs font-mono text-gray-700 w-8 shrink-0">{b.count}</span>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-3 gap-4">
        {[
          { label: 'P25', value: fmt(p25) },
          { label: tc.distribution.medianLabel, value: fmt(med) },
          { label: 'P75', value: fmt(p75) },
        ].map(item => (
          <div class="border border-gray-200 rounded-md p-4 text-center">
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">{item.label}</p>
            <p class="text-2xl font-light text-gray-800" style="font-family: Georgia, serif;">{item.value}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 3. Sector comparison ──────────────────────────────────────────── -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.sectors.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.sectors.note}</p>

      <div class="space-y-2 mb-4">
        {sectorStats.map(s => (
          <div class="flex items-center gap-3">
            <span
              class="text-xs text-gray-600 shrink-0 text-right"
              style="width: 200px; min-width: 200px;"
            >
              {s.sector}
            </span>
            <div class="flex-1 bg-gray-100 rounded-sm h-5 relative">
              <div
                class="h-5 rounded-sm bg-accent/60"
                style={`width: ${maxSectorMed > 0 ? Math.round((s.med / maxSectorMed) * 100) : 0}%`}
              />
            </div>
            <span class="text-xs font-mono font-semibold text-gray-800 w-10 shrink-0">{fmt(s.med)}</span>
            <span class="text-xs font-mono text-gray-400 w-8 shrink-0">n={s.n}</span>
          </div>
        ))}
      </div>
      <p class="text-xs text-gray-400">{tc.sectors.footnote}</p>
    </section>

    <!-- ── 4. Time series ────────────────────────────────────────────────── -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.timeSeries.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.timeSeries.note}</p>

      {timeSeries.length > 0 ? (
        <div class="border border-gray-200 rounded-md overflow-hidden mb-3">
          <table class="table-rg">
            <thead>
              <tr class="bg-gray-50 text-xs uppercase text-gray-500 tracking-wide">
                <th class="text-left px-4 py-2 font-medium">{tc.timeSeries.colPeriod}</th>
                <th class="text-right px-4 py-2 font-medium">{tc.timeSeries.colN}</th>
                <th class="text-right px-4 py-2 font-medium">{tc.timeSeries.colP25}</th>
                <th class="text-right px-4 py-2 font-semibold text-gray-700">{tc.timeSeries.colMedian}</th>
                <th class="text-right px-4 py-2 font-medium">{tc.timeSeries.colP75}</th>
              </tr>
            </thead>
            <tbody>
              {timeSeries.map(row => (
                <tr class="border-t border-gray-100">
                  <td class="px-4 py-2 text-gray-700 font-medium">{row.label}</td>
                  <td class="px-4 py-2 text-right font-mono text-gray-500">{row.n}</td>
                  <td class="px-4 py-2 text-right font-mono text-gray-500">{fmt(row.p25)}</td>
                  <td class="px-4 py-2 text-right font-mono font-semibold text-gray-900">{fmt(row.med)}</td>
                  <td class="px-4 py-2 text-right font-mono text-gray-500">{fmt(row.p75)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="border border-gray-200 rounded-md px-5 py-6 text-center text-sm text-gray-400">
          {tc.timeSeries.noData}
        </div>
      )}
      <p class="text-xs text-gray-400">{tc.timeSeries.footnote}</p>
    </section>

    <!-- ── 5. Valuation Fragility Divergence ───────────────────────────── -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.fragility.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.fragility.subheading}</p>

      <!-- Panel construction note -->
      <div class="border border-gray-200 rounded-md bg-gray-50/60 px-5 py-4 mb-7 text-sm text-gray-600 leading-relaxed">
        <p class="font-semibold text-gray-700 mb-1">Panel construction</p>
        <p>{tc.fragility.panelNote(fragPanelN, FRAG_PERIODS.length, fragMethodLabel)}</p>
        <p class="mt-2 text-xs text-gray-500">{tc.fragility.dataTypeNote}</p>
      </div>

      <!-- ── Three-cases framework ──────────────────────────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.frameworkHeading}</h3>
      <div class="grid grid-cols-1 gap-3 mb-6" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
        {tc.fragility.frameworkCases.map((c: { label: string; description: string }, i: number) => {
          const colors = [
            'border-gray-200 bg-gray-50/40',
            'border-orange-200 bg-orange-50/40',
            'border-amber-200 bg-amber-50/40',
          ];
          const labelColors = ['text-gray-600', 'text-orange-700', 'text-amber-700'];
          return (
            <div class={`border rounded-md px-4 py-3 ${colors[i]}`}>
              <p class={`text-xs font-semibold mb-1 ${labelColors[i]}`}>{c.label}</p>
              <p class="text-xs text-gray-600 leading-relaxed">{c.description}</p>
            </div>
          );
        })}
      </div>
      <p class="text-xs text-gray-400 italic mb-8">{tc.fragility.frameworkNote}</p>

      <!-- ── Signal cards ─────────────────────────────────────────────── -->
      <p class="text-xs text-gray-400 uppercase tracking-widest mb-3">{tc.fragility.signalHeading}</p>
      <div class="grid grid-cols-3 gap-3 mb-8">
        {[
          { label: tc.fragility.currentCoreRgLabel,      value: fmt(fragLatest.conservativeMedian, 2), note: fragLatest.label, accent: false },
          { label: tc.fragility.currentNarrativeRgLabel, value: fmt(fragLatest.highMedian, 2),          note: fragLatest.label, accent: false },
          { label: tc.fragility.currentSpreadLabel,      value: fmt(fragLatest.spread, 2),              note: fragLatest.label, accent: true  },
          { label: tc.fragility.currentRatioLabel,       value: fmt(fragLatest.ratio, 1) + '×',         note: fragLatest.label, accent: false },
          { label: tc.fragility.peakSpreadLabel,         value: fmt(fragPeak.spread, 2),                note: fragPeak.label,   accent: false },
          { label: tc.fragility.peakRatioLabel,          value: fmt(fragPeak.ratio, 1) + '×',           note: fragPeak.label,   accent: false },
        ].map(card => (
          <div class={`border rounded-md p-4 ${card.accent ? 'border-orange-200 bg-orange-50/30' : 'border-gray-200'}`}>
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">{card.label}</p>
            <p class={`text-2xl font-light ${card.accent ? 'text-orange-800' : 'text-gray-800'}`} style="font-family: Georgia, serif;">{card.value}</p>
            <p class="text-xs text-gray-400 mt-1">{card.note}</p>
          </div>
        ))}
      </div>

      <!-- ── 2025 data caveat ───────────────────────────────────────────── -->
      <div class="flex gap-2.5 border border-amber-200 bg-amber-50/60 rounded-md px-4 py-3 mb-5 text-xs text-amber-800 leading-relaxed">
        <span class="shrink-0 mt-0.5">⚠</span>
        <span>
          <strong>Note on 2025 data:</strong> Q1–Q4 2025 observations use the <em>current</em> market
          capitalisation rather than end-of-quarter prices. Changes within 2025 therefore reflect
          shifts in smoothed earnings (G) more than actual price movements. Treat the 2025 trajectory
          as fundamental-reclassification signal, not as a market-price time series.
        </span>
      </div>

      <!-- ── SVG: Core RG vs Narrative RG over time ───────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-1">Core RG vs. Narrative RG — Time Series</h3>
      <p class="text-xs text-gray-400 mb-3">
        Open panel (all companies with valid RG10 per quarter, n varies). Q1 2024: 21 companies only (tercile method).
        Shaded area = Narrative RG − Core RG (spread).
      </p>
      <!-- Legend -->
      <div class="flex items-center gap-5 mb-2 text-xs text-gray-500">
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-6 h-0.5 rounded" style="background:rgb(20,184,166);"></span>
          Core RG (bottom quartile)
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-6 h-0.5 rounded" style="background:rgb(234,88,12);"></span>
          Narrative RG (top quartile)
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-6 h-3 rounded-sm opacity-30" style="background:rgb(249,115,22);"></span>
          Spread
        </span>
      </div>
      <div class="border border-gray-100 rounded-md bg-white p-3 mb-4 overflow-x-auto">
        <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} class="w-full" style="min-width:400px; max-height:260px;">
          {/* Y grid + labels */}
          {svgYTicks.map(y => (
            <>
              <line x1={SVG_PL} y1={svgY(y)} x2={SVG_W - SVG_PR} y2={svgY(y)} stroke="#f3f4f6" stroke-width="1" />
              <text x={SVG_PL - 5} y={svgY(y) + 3.5} text-anchor="end" font-size="10" fill="#9ca3af">{y}</text>
            </>
          ))}
          {/* X vertical guides */}
          {openFragSeries.map((_, i) => (
            <line x1={svgX(i)} y1={SVG_PT} x2={svgX(i)} y2={SVG_PT + SVG_IH} stroke="#f9fafb" stroke-width="1" stroke-dasharray="3 2" />
          ))}
          {/* Spread fill */}
          {svgFillPts && <polygon points={svgFillPts} fill="rgba(249,115,22,0.10)" />}
          {/* Core line */}
          {svgCorePoints && <polyline points={svgCorePoints} fill="none" stroke="rgb(20,184,166)" stroke-width="2.2" stroke-linejoin="round" />}
          {/* Narrative line */}
          {svgHighPoints && <polyline points={svgHighPoints} fill="none" stroke="rgb(234,88,12)" stroke-width="2.2" stroke-linejoin="round" />}
          {/* Dots + value labels */}
          {openFragSeries.map((r, i) => (
            <>
              <circle cx={svgX(i)} cy={svgY(r.consMedian)} r="3.5" fill="rgb(20,184,166)" />
              <text x={svgX(i)} y={svgY(r.consMedian) + 14} text-anchor="middle" font-size="9" fill="rgb(13,148,136)">{r.consMedian.toFixed(1)}</text>
              <circle cx={svgX(i)} cy={svgY(r.highMedian)} r="3.5" fill="rgb(234,88,12)" />
              <text x={svgX(i)} y={svgY(r.highMedian) - 6} text-anchor="middle" font-size="9" fill="rgb(194,65,12)">{r.highMedian.toFixed(1)}</text>
            </>
          ))}
          {/* X labels + n */}
          {openFragSeries.map((r, i) => (
            <>
              <text x={svgX(i)} y={SVG_PT + SVG_IH + 16} text-anchor="middle" font-size="10" fill="#6b7280">{r.label}</text>
              <text x={svgX(i)} y={SVG_PT + SVG_IH + 28} text-anchor="middle" font-size="8.5" fill="#d1d5db">n={r.n}</text>
            </>
          ))}
          {/* Y-axis label */}
          <text
            transform={`translate(11,${SVG_PT + SVG_IH / 2}) rotate(-90)`}
            text-anchor="middle" font-size="9.5" fill="#9ca3af">RG10</text>
        </svg>
      </div>

      <!-- ── SVG: Fragility Spread ─────────────────────────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-1">Fragility Spread — Time Series</h3>
      <p class="text-xs text-gray-400 mb-3">
        Narrative RG minus Core RG. Higher values indicate greater structural divergence in market valuations.
      </p>
      <div class="border border-gray-100 rounded-md bg-white p-3 mb-8 overflow-x-auto">
        <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} class="w-full" style="min-width:400px; max-height:260px;">
          {/* Y grid + labels */}
          {Array.from({ length: Math.ceil(svgSpreadMaxY / 0.5) + 1 }, (_, i) => i * 0.5).map(y => (
            <>
              <line x1={SVG_PL} y1={SVG_PT + (1 - y / svgSpreadMaxY) * SVG_IH} x2={SVG_W - SVG_PR} y2={SVG_PT + (1 - y / svgSpreadMaxY) * SVG_IH} stroke="#f3f4f6" stroke-width="1" />
              {(y * 10) % 5 === 0 && (
                <text x={SVG_PL - 5} y={SVG_PT + (1 - y / svgSpreadMaxY) * SVG_IH + 3.5} text-anchor="end" font-size="10" fill="#9ca3af">{y.toFixed(1)}</text>
              )}
            </>
          ))}
          {/* X vertical guides */}
          {openFragSeries.map((_, i) => (
            <line x1={svgX(i)} y1={SVG_PT} x2={svgX(i)} y2={SVG_PT + SVG_IH} stroke="#f9fafb" stroke-width="1" stroke-dasharray="3 2" />
          ))}
          {/* Area fill */}
          {svgSpreadFillPts && <polygon points={svgSpreadFillPts} fill="rgba(234,88,12,0.12)" />}
          {/* Baseline */}
          <line x1={SVG_PL} y1={SVG_PT + SVG_IH} x2={SVG_W - SVG_PR} y2={SVG_PT + SVG_IH} stroke="#e5e7eb" stroke-width="1" />
          {/* Spread line */}
          {svgSpreadPts && <polyline points={svgSpreadPts} fill="none" stroke="rgb(234,88,12)" stroke-width="2.2" stroke-linejoin="round" />}
          {/* Dots + value labels */}
          {openFragSeries.map((r, i) => {
            const cy = SVG_PT + (1 - r.spread / svgSpreadMaxY) * SVG_IH;
            const isPeak = r.spread === Math.max(...openFragSeries.map(x => x.spread));
            return (
              <>
                <circle cx={svgX(i)} cy={cy} r="3.5" fill={isPeak ? 'rgb(185,28,28)' : 'rgb(234,88,12)'} />
                <text x={svgX(i)} y={cy - 7} text-anchor="middle" font-size="9" fill={isPeak ? 'rgb(185,28,28)' : 'rgb(194,65,12)'}
                  font-weight={isPeak ? 'bold' : 'normal'}>{r.spread.toFixed(2)}{isPeak ? ' ↑' : ''}</text>
              </>
            );
          })}
          {/* X labels + n */}
          {openFragSeries.map((r, i) => (
            <>
              <text x={svgX(i)} y={SVG_PT + SVG_IH + 16} text-anchor="middle" font-size="10" fill="#6b7280">{r.label}</text>
              <text x={svgX(i)} y={SVG_PT + SVG_IH + 28} text-anchor="middle" font-size="8.5" fill="#d1d5db">n={r.n}</text>
            </>
          ))}
          <text
            transform={`translate(11,${SVG_PT + SVG_IH / 2}) rotate(-90)`}
            text-anchor="middle" font-size="9.5" fill="#9ca3af">Spread</text>
        </svg>
      </div>

      <!-- ── SVG: Gini Coefficient of RG10 Distribution ───────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-1">Gini Coefficient — Time Series</h3>
      <p class="text-xs text-gray-400 mb-3">
        Distributional inequality of RG10 across all companies per quarter (0 = perfect equality, 1 = maximum concentration).
        Independent of quartile boundaries — captures the full distribution shape.
        Peak: {giniPeak.label} ({giniPeak.g.toFixed(3)}) · Latest: {giniLatest.label} ({giniLatest.g.toFixed(3)}).
      </p>
      <div class="border border-gray-100 rounded-md bg-white p-3 mb-8 overflow-x-auto">
        <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} class="w-full" style="min-width:400px; max-height:260px;">
          {/* Y grid */}
          {giniYTicks.map(y => (
            <>
              <line x1={SVG_PL} y1={gY(y)} x2={SVG_W - SVG_PR} y2={gY(y)} stroke="#f3f4f6" stroke-width="1" />
              <text x={SVG_PL - 5} y={gY(y) + 3.5} text-anchor="end" font-size="10" fill="#9ca3af">{y.toFixed(1)}</text>
            </>
          ))}
          {/* X guides */}
          {giniSeries.map((_, i) => (
            <line x1={gX(i)} y1={SVG_PT} x2={gX(i)} y2={SVG_PT + SVG_IH} stroke="#f9fafb" stroke-width="1" stroke-dasharray="3 2" />
          ))}
          {/* Area fill */}
          {svgGiniFillPts && <polygon points={svgGiniFillPts} fill="rgba(99,102,241,0.08)" />}
          {/* Baseline */}
          <line x1={SVG_PL} y1={SVG_PT + SVG_IH} x2={SVG_W - SVG_PR} y2={SVG_PT + SVG_IH} stroke="#e5e7eb" stroke-width="1" />
          {/* Gini line */}
          {svgGiniPts && <polyline points={svgGiniPts} fill="none" stroke="rgb(99,102,241)" stroke-width="2.2" stroke-linejoin="round" />}
          {/* Dots + labels */}
          {giniSeries.map((r, i) => {
            const cy = gY(r.g);
            const isPeak = r.pk === giniPeak.pk;
            return (
              <>
                <circle cx={gX(i)} cy={cy} r="3.5" fill={isPeak ? 'rgb(79,70,229)' : 'rgb(99,102,241)'} />
                <text x={gX(i)} y={cy - 7} text-anchor="middle" font-size="9"
                  fill={isPeak ? 'rgb(79,70,229)' : 'rgb(99,102,241)'}
                  font-weight={isPeak ? 'bold' : 'normal'}>
                  {r.g.toFixed(3)}{isPeak ? ' ↑' : ''}
                </text>
              </>
            );
          })}
          {/* X labels */}
          {giniSeries.map((r, i) => (
            <>
              <text x={gX(i)} y={SVG_PT + SVG_IH + 16} text-anchor="middle" font-size="10" fill="#6b7280">{r.label}</text>
              <text x={gX(i)} y={SVG_PT + SVG_IH + 28} text-anchor="middle" font-size="8.5" fill="#d1d5db">n={r.n}</text>
            </>
          ))}
          <text transform={`translate(11,${SVG_PT + SVG_IH / 2}) rotate(-90)`}
            text-anchor="middle" font-size="9.5" fill="#9ca3af">Gini</text>
        </svg>
      </div>

      <!-- ── Gini insight ───────────────────────────────────────────────── -->
      <div class="border border-indigo-100 bg-indigo-50/40 rounded-md px-5 py-4 mb-8 space-y-3">
        <p class="text-xs font-semibold text-indigo-800 uppercase tracking-wide">What the Gini shows that Spread doesn't</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs text-indigo-900">
