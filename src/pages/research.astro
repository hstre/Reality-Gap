          <!-- JP line (amber, dashed for sparse coverage) -->
          {geoJPPath && <path d={geoJPPath} fill="none" stroke="rgb(245,158,11)" stroke-width="2" stroke-linejoin="round" stroke-dasharray="5,3" />}
          <!-- Dots on each data point -->
          {geoSeries.US.map(r => { const i = GEO_PERIODS.indexOf(r.pk); return i >= 0 ? <circle cx={geoChartX(i)} cy={geoChartY(r.med)} r="2.5" fill="rgb(59,130,246)" /> : null; })}
          {geoSeries.DE.map(r => { const i = GEO_PERIODS.indexOf(r.pk); return i >= 0 ? <circle cx={geoChartX(i)} cy={geoChartY(r.med)} r="2.5" fill="rgb(20,184,166)" /> : null; })}
          {geoSeries.GB.map(r => { const i = GEO_PERIODS.indexOf(r.pk); return i >= 0 ? <circle cx={geoChartX(i)} cy={geoChartY(r.med)} r="2.5" fill="rgb(34,197,94)" /> : null; })}
          {geoSeries.FR.map(r => { const i = GEO_PERIODS.indexOf(r.pk); return i >= 0 ? <circle cx={geoChartX(i)} cy={geoChartY(r.med)} r="2.5" fill="rgb(244,63,94)" /> : null; })}
          {geoSeries.CH.map(r => { const i = GEO_PERIODS.indexOf(r.pk); return i >= 0 ? <circle cx={geoChartX(i)} cy={geoChartY(r.med)} r="2.5" fill="rgb(168,85,247)" /> : null; })}
          {geoSeries.JP.map(r => { const i = GEO_PERIODS.indexOf(r.pk); return i >= 0 ? <circle cx={geoChartX(i)} cy={geoChartY(r.med)} r="2.5" fill="rgb(245,158,11)" /> : null; })}
          <!-- Legend row 1 -->
          <circle cx={SVG_PL + 4}   cy={SVG_H - SVG_PB + 32} r="3.5" fill="rgb(59,130,246)" />
          <text x={SVG_PL + 11}  y={SVG_H - SVG_PB + 36} font-size="9" fill="#6b7280">US</text>
          <circle cx={SVG_PL + 34}  cy={SVG_H - SVG_PB + 32} r="3.5" fill="rgb(20,184,166)" />
          <text x={SVG_PL + 41}  y={SVG_H - SVG_PB + 36} font-size="9" fill="#6b7280">DE</text>
          <circle cx={SVG_PL + 64}  cy={SVG_H - SVG_PB + 32} r="3.5" fill="rgb(34,197,94)" />
          <text x={SVG_PL + 71}  y={SVG_H - SVG_PB + 36} font-size="9" fill="#6b7280">GB</text>
          <circle cx={SVG_PL + 94}  cy={SVG_H - SVG_PB + 32} r="3.5" fill="rgb(244,63,94)" />
          <text x={SVG_PL + 101} y={SVG_H - SVG_PB + 36} font-size="9" fill="#6b7280">FR</text>
          <circle cx={SVG_PL + 124} cy={SVG_H - SVG_PB + 32} r="3.5" fill="rgb(168,85,247)" />
          <text x={SVG_PL + 131} y={SVG_H - SVG_PB + 36} font-size="9" fill="#6b7280">CH</text>
          <circle cx={SVG_PL + 154} cy={SVG_H - SVG_PB + 32} r="3.5" fill="rgb(245,158,11)" />
