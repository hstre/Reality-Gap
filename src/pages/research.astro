              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colRatio}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colRatioChange}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colUpperTail}</th>
            </tr>
          </thead>
          <tbody>
            {fragSeries.map(row => (
              <tr class={`border-t border-gray-100 ${row.spread === maxFSpread ? 'bg-orange-50/40' : ''}`}>
                <td class="px-3 py-2 font-medium text-gray-700">
