          {tc.fragility.divergenceLegendCons}
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-3 rounded-sm bg-orange-400/70"></span>
          {tc.fragility.divergenceLegendHigh}
        </span>
      </div>
      <div class="space-y-4 mb-8">
        {fragSeries.map(row => (
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-mono text-gray-600 w-16 shrink-0 text-right">{row.label}</span>
              <span class="text-xs text-gray-400 w-16 shrink-0">{row.dataType === 'annual' ? tc.fragility.annualLabel : tc.fragility.quarterlyLabel}</span>
            </div>
            <!-- Conservative bar -->
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-gray-400 w-32 shrink-0 text-right pl-0">Core RG</span>
              <div class="flex-1 bg-gray-100 rounded-sm h-4 relative">
                <div
                  class="h-4 rounded-sm bg-teal-400/70"
                  style={`width: ${maxFHigh > 0 ? Math.round((row.conservativeMedian / maxFHigh) * 100) : 0}%`}
                />
              </div>
              <span class="text-xs font-mono text-gray-600 w-8 shrink-0">{fmt(row.conservativeMedian)}</span>
            </div>
            <!-- High bar -->
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-400 w-32 shrink-0 text-right">Narrative RG</span>
              <div class="flex-1 bg-gray-100 rounded-sm h-4 relative">
                <div
                  class={`h-4 rounded-sm ${row.spread === maxFSpread ? 'bg-orange-500/70' : 'bg-orange-400/55'}`}
                  style={`width: ${maxFHigh > 0 ? Math.round((row.highMedian / maxFHigh) * 100) : 0}%`}
                />
              </div>
              <span class="text-xs font-mono font-semibold text-gray-700 w-8 shrink-0">{fmt(row.highMedian)}</span>
              {row.spread === maxFSpread && (
                <span class="text-xs text-orange-600 font-medium shrink-0">← {tc.fragility.peakAnnotation}</span>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- ── Spread chart ──────────────────────────────────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.spreadChartHeading}</h3>
      <div class="space-y-2 mb-8">
        {fragSeries.map(row => (
          <div class="flex items-center gap-3">
            <span class="text-xs font-mono text-gray-500 w-16 text-right shrink-0">{row.label}</span>
            <div class="flex-1 bg-gray-100 rounded-sm h-6 relative">
              <div
                class={`h-6 rounded-sm ${row.spread === maxFSpread ? 'bg-accent' : 'bg-accent/55'}`}
                style={`width: ${maxFSpread > 0 ? Math.round((row.spread / maxFSpread) * 100) : 0}%`}
              />
            </div>
            <span class="text-xs font-mono text-gray-700 w-10 shrink-0">{fmt(row.spread)}</span>
            {row.spread === maxFSpread && (
              <span class="text-xs text-accent font-semibold shrink-0">{tc.fragility.peakAnnotation}</span>
