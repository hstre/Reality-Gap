---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { en } from '../i18n/en';
import sp500Raw from '../data/macro/sp500_cape.json';
import daxRaw   from '../data/macro/dax40_pe.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const t = en;

const sp500 = (sp500Raw as any).current as { date: string; cape: number; rg10: number; trend: string };
const dax   = (daxRaw as any).current  as { date: string; trailing_pe: number; rg10: number };

function snapshotBand(v: number): string {
  if (v < 1.0) return 'text-emerald-700';
  if (v < 1.8) return 'text-blue-700';
  if (v < 2.5) return 'text-amber-700';
  if (v < 3.5) return 'text-orange-700';
  return 'text-red-700';
}
---

<BaseLayout
  title={t.home.meta.title}
  description={t.home.meta.description}
  lang="en"
  canonicalPath="/"
  altLangPath="/de/"
  altLang="de"
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-10">
    <div class="max-w-2xl">
      <h1 class="text-4xl font-normal text-gray-900 mb-3" style="font-family: Georgia, serif;">
        {t.home.hero.title}
      </h1>
      <p class="text-lg text-gray-500 mb-6 font-light">{t.home.hero.subtitle}</p>
      <p class="text-base text-gray-700 leading-relaxed mb-8">
        {t.home.hero.description}
      </p>
      <p class="text-xs text-gray-400 border-l-2 border-gray-200 pl-3">
        {t.home.hero.note}
      </p>
    </div>
  </section>

  <!-- Macro snapshot strip -->
  <section class="max-w-5xl mx-auto px-6 pb-10">
    <div class="flex flex-wrap gap-3 items-stretch">
      <a href={`${base}/macro`}
         class="flex-1 min-w-[180px] border border-gray-200 rounded-md px-5 py-4 bg-white hover:border-gray-300 hover:shadow-sm transition-all no-underline group">
        <div class="text-xs text-gray-400 mb-1 font-medium tracking-wide uppercase">M(S&amp;P 500)RG10</div>
        <div class={`text-2xl font-mono font-semibold ${snapshotBand(sp500.rg10)}`}>
          {sp500.rg10.toFixed(2)}<span class="text-base ml-0.5">{sp500.trend}</span>
        </div>
        <div class="text-xs text-gray-400 mt-1">CAPE {sp500.cape.toFixed(1)} · {sp500.date}</div>
      </a>

      <a href={`${base}/macro/dax40`}
         class="flex-1 min-w-[180px] border border-gray-200 rounded-md px-5 py-4 bg-white hover:border-gray-300 hover:shadow-sm transition-all no-underline group">
        <div class="text-xs text-gray-400 mb-1 font-medium tracking-wide uppercase">M(DAX 40)RG10</div>
        <div class={`text-2xl font-mono font-semibold ${snapshotBand(dax.rg10)}`}>
          {dax.rg10.toFixed(2)}
        </div>
        <div class="text-xs text-gray-400 mt-1">Trailing P/E {dax.trailing_pe.toFixed(1)} · {dax.date}</div>
      </a>

      <div class="flex-1 min-w-[180px] border border-gray-100 rounded-md px-5 py-4 bg-gray-50/60">
        <div class="text-xs text-gray-400 mb-1 font-medium tracking-wide uppercase">Macro Approximation</div>
        <div class="text-xs text-gray-500 leading-relaxed mt-2">
          M(Index)RG10 = CAPE ÷ 10 (S&amp;P) or trailing P/E ÷ 10 (DAX).
          Values above 2.0 indicate above-average stretch; above 3.5 is historically rare.
        </div>
      </div>
    </div>
  </section>

  <!-- Cards -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { href: `${base}/methodology`, card: t.home.cards.methodology },
        { href: `${base}/paper`,       card: t.home.cards.paper },
        { href: `${base}/rankings`,    card: t.home.cards.rankings },
        { href: `${base}/companies`,   card: t.home.cards.companies },
        { href: `${base}/research`,    card: t.home.cards.research },
        { href: `${base}/macro`,       card: t.home.cards.macro },
      ].map(({ href, card }) => (
        <a href={href} class="border border-gray-200 rounded-md p-5 bg-white hover:border-gray-300 hover:shadow-sm transition-all no-underline group block">
          <h2 class="text-sm font-semibold text-gray-800 group-hover:text-accent transition-colors mb-2">
            {card.title}
          </h2>
          <p class="text-xs text-gray-500 leading-relaxed">{card.description}</p>
          <p class="text-xs text-accent mt-4 opacity-0 group-hover:opacity-100 transition-opacity">{t.home.cta} →</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
