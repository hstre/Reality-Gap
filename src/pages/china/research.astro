---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import type { Company } from '../../lib/rg';
import { getLatestObservation } from '../../lib/rg';
import chinaSlugJson from '../../data/companies.china.index.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const slugs: string[] = chinaSlugJson;
const companies: Company[] = await Promise.all(
  slugs.map(slug =>
    import(`../../data/companies/${slug}.json`).then(m => m.default as Company)
  )
);

// ── Helpers ──────────────────────────────────────────────
function parsePeriod(key: string): number {
  const m = key.match(/^(\d{4})_q(\d)$/);
  return m ? parseInt(m[1]!) * 10 + parseInt(m[2]!) : 0;
}

function median(arr: number[]): number {
  if (!arr.length) return 0;
  const s = [...arr].sort((a, b) => a - b);
  const mid = Math.floor(s.length / 2);
  return s.length % 2 !== 0 ? s[mid]! : (s[mid - 1]! + s[mid]!) / 2;
}

function pct(v: number | null, max: number): string {
  if (v === null) return '0%';
  return Math.min(100, Math.round((v / max) * 100)) + '%';
}

function fmt(v: number | null, d = 2): string {
  return v == null ? '—' : v.toFixed(d);
}

// ── Per-company rows ─────────────────────────────────────
interface CompanyRow {
  slug: string; name: string; ticker: string; sector: string;
  period: string; mc: number | null; te: number | null;
  g: number | null; ni: number | null; gw: number | null; ia: number | null;
  rg8: number | null; rg10: number | null; rg12: number | null;
  obs: any[]; isSoe: boolean;
}

// State-owned enterprises (majority state-controlled)
const SOE_SLUGS = new Set([
  'icbc','bankofchina','chinaconstructionbank',
  'petrochina','sinopec','chinashenhua',
  'chinaunicom','chinatelecom','chinamobile',
  'cnooc','citic',
]);

const rows: CompanyRow[] = companies.map(c => {
  const obs = getLatestObservation(c);
  const allObs = [...c.observations].sort((a, b) => parsePeriod(b.periodKey) - parsePeriod(a.periodKey));
  return {
    slug:   c.slug,
    name:   c.company,
    ticker: c.ticker,
    sector: c.sector,
    period: obs?.periodLabel ?? '—',
    mc:  (obs as any)?.marketCap      ?? null,
    te:  (obs as any)?.tangibleEquity ?? null,
    g:   (obs as any)?.smoothedEarnings ?? null,
    ni:  (obs as any)?.netIncome      ?? null,
    gw:  (obs as any)?.goodwill       ?? null,
    ia:  (obs as any)?.intangibles    ?? null,
    rg8:  obs?.rg8  ?? null,
    rg10: obs?.rg10 ?? null,
    rg12: obs?.rg12 ?? null,
    obs: allObs,
    isSoe: SOE_SLUGS.has(c.slug),
  };
});

const rowsSorted = [...rows].sort((a, b) => (b.rg10 ?? -999) - (a.rg10 ?? -999));
const maxRG10 = Math.max(...rowsSorted.map(r => r.rg10 ?? 0), 0.1);

// ── SOE / Private split ──────────────────────────────────
const soeRows     = rowsSorted.filter(r => r.isSoe  && r.rg10 !== null);
const privateRows = rowsSorted.filter(r => !r.isSoe && r.rg10 !== null);
const soeRGs      = soeRows.map(r => r.rg10 as number);
const privateRGs  = privateRows.map(r => r.rg10 as number);
const allRGs      = rowsSorted.filter(r => r.rg10 !== null).map(r => r.rg10 as number);

const soeMedian     = median(soeRGs);
const privateMedian = median(privateRGs);
const cnMedian      = median(allRGs);

// ── Cross-market benchmark (approx medians from research page data) ─
// These are rough reference values for narrative context only
const benchmarks = [
  { label: 'S&P 500',    rg: 2.55, color: '#ef4444' },
  { label: 'CAC 40',     rg: 1.52, color: '#f97316' },
  { label: 'SMI',        rg: 1.41, color: '#a855f7' },
  { label: 'FTSE 100',   rg: 1.12, color: '#22c55e' },
  { label: 'DAX 40',     rg: 1.05, color: '#3b82f6' },
  { label: 'Nikkei 225', rg: 0.98, color: '#64748b' },
  { label: 'Hang Seng (all)',     rg: cnMedian,      color: '#dc2626' },
  { label: 'Hang Seng (SOE)',     rg: soeMedian,     color: '#991b1b' },
  { label: 'Hang Seng (private)', rg: privateMedian, color: '#f59e0b' },
];
const benchMax = Math.max(...benchmarks.map(b => b.rg), 0.1);
---

<BaseLayout
  title="China Research — Reality Gap"
  description={`Reality Gap analysis for ${rows.length} HK-listed Chinese companies. Key finding: structural bifurcation between state-owned enterprises (median RG10 ${soeMedian.toFixed(2)}) and private-sector companies (median RG10 ${privateMedian.toFixed(2)}).`}
  lang="en"
  canonicalPath="/china/research"
>
<div class="max-w-5xl mx-auto px-6 py-12">

  <!-- Header -->
  <div class="mb-2">
    <a href={`${base}/china`} class="text-sm text-gray-400 hover:text-accent no-underline">← China Companies</a>
  </div>
  <h1 class="text-3xl font-normal text-gray-900 mb-2" style="font-family: Georgia, serif;">
    China — RG Research
  </h1>
  <p class="text-gray-600 mb-1">
    Reality Gap analysis for {rows.length} HK-listed companies across all major Hang Seng sectors.
    All values in HKD billions.
  </p>
  <div class="flex flex-wrap gap-2 mb-8">
    <span class="text-xs bg-amber-50 text-amber-700 border border-amber-200 rounded px-2 py-0.5">Approximation · yfinance / Yahoo Finance</span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">H-share market cap basis</span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">Not investment advice</span>
  </div>

  <!-- ── 1. Core Finding ───────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4">1. Core Finding: Structural Bifurcation</h2>

    <!-- Two big stat cards -->
    <div class="grid grid-cols-2 gap-4 mb-6" style="max-width:440px">
      <div class="border border-gray-200 rounded-md p-5 bg-red-50/40">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">State-owned ({soeRows.length} companies)</div>
        <div class="text-3xl font-light text-red-700 mb-0.5">{soeMedian.toFixed(2)}</div>
        <div class="text-xs text-gray-400">Median RG10</div>
      </div>
      <div class="border border-gray-200 rounded-md p-5 bg-amber-50/40">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Private sector ({privateRows.length} companies)</div>
        <div class="text-3xl font-light text-amber-600 mb-0.5">{privateMedian.toFixed(2)}</div>
        <div class="text-xs text-gray-400">Median RG10</div>
      </div>
    </div>

    <div class="space-y-3 mb-6">
      <div class="border-l-2 border-red-300 pl-4">
        <p class="text-sm font-semibold text-gray-700 mb-0.5">Chinese SOEs trade far below conservative fundamental coverage</p>
        <p class="text-sm text-gray-500">
          The big state banks (ICBC, Bank of China: RG10 = 0.06 each), oil majors (PetroChina: 0.06, Sinopec: 0.09),
          and state telecoms (China Telecom: 0.08) all have market caps that are a fraction of their estimated
          fundamental base. RG10 of 0.06 means the market prices the company at only 6% of the conservative
          earnings-and-equity coverage — a discount found nowhere in US, European, or even Japanese large-cap markets.
        </p>
      </div>
      <div class="border-l-2 border-amber-300 pl-4">
        <p class="text-sm font-semibold text-gray-700 mb-0.5">Private-sector tech behaves like European, not US, markets</p>
        <p class="text-sm text-gray-500">
          Tencent ({rows.find(r=>r.slug==='tencent')?.rg10?.toFixed(2)}), Alibaba ({rows.find(r=>r.slug==='alibaba')?.rg10?.toFixed(2)}),
          Meituan ({rows.find(r=>r.slug==='meituan')?.rg10?.toFixed(2)}), Xiaomi ({rows.find(r=>r.slug==='xiaomi')?.rg10?.toFixed(2)})
          are in the 1.3–2.2 range — comparable to French or Swiss tech, but well below US equivalents
          (Meta ~4, Alphabet ~4, Nvidia ≫ 10). The narrative premium exists, but is structurally compressed.
        </p>
      </div>
      <div class="border-l-2 border-gray-200 pl-4">
        <p class="text-sm font-semibold text-gray-700 mb-0.5">The SOE discount is not simply "cheap" — it reflects earnings skepticism</p>
        <p class="text-sm text-gray-500">
          A low RG does not automatically mean undervaluation. For Chinese SOEs, it likely reflects
          investors' structural discount for earnings quality, political risk, and uncertain capital
          return policies — an implicit recognition that reported earnings may not be fully accessible
          to minority shareholders.
        </p>
      </div>
    </div>
  </section>

  <!-- ── 2. RG10 Ranking ───────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1">2. RG10 Ranking — All {rows.length} Companies</h2>
    <p class="text-sm text-gray-500 mb-1">Sorted high to low. <span class="text-red-600 font-medium">Red label</span> = state-owned enterprise. Vertical line at RG10 = 1.0.</p>
    <p class="text-xs text-gray-400 mb-5">Current / most recent period per company.</p>

    <div class="space-y-1.5">
      {rowsSorted.map(r => (
        <div class="flex items-center gap-2 text-xs">
          <a href={`${base}/china/${r.slug}`}
             class={`shrink-0 no-underline font-medium hover:underline ${r.isSoe ? 'text-red-700' : 'text-gray-700'}`}
             style="width:170px; text-align:right; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
             title={r.name}>{r.name}</a>
          <div class="flex-1 bg-gray-100 rounded-sm h-5 relative" style="max-width:320px">
            <!-- Reference line at 1.0 -->
            <div class="absolute top-0 bottom-0 w-px bg-gray-400 z-10"
                 style={`left:${pct(1.0, maxRG10)}`} title="RG10=1.0"/>
            {r.rg10 !== null && (
              <div class="h-5 rounded-sm"
                   style={`width:${pct(r.rg10, maxRG10)};background:${
                     r.rg10 < 0.3  ? '#fca5a5' :
                     r.rg10 < 1.0  ? '#6ee7b7' :
                     r.rg10 < 2.0  ? '#93c5fd' : '#fbbf24'}`}/>
            )}
          </div>
          <span class="font-mono font-semibold text-gray-700 w-8 shrink-0">{fmt(r.rg10)}</span>
          <span class="text-gray-400 shrink-0 hidden sm:inline" style="width:80px; overflow:hidden; text-overflow:ellipsis;">{r.sector}</span>
        </div>
      ))}
    </div>
    <div class="flex flex-wrap gap-3 mt-3 text-xs text-gray-400">
      <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded" style="background:#fca5a5"></span>SOE deep discount (&lt;0.3)</span>
      <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded" style="background:#6ee7b7"></span>Below coverage (0.3–1.0)</span>
      <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded" style="background:#93c5fd"></span>Narrative premium (1–2)</span>
      <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded" style="background:#fbbf24"></span>Elevated (&gt;2)</span>
    </div>
  </section>

  <!-- ── 3. SOE vs Private split ───────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1">3. SOE vs. Private: Side by Side</h2>
    <p class="text-xs text-gray-400 mb-5">
      SOEs defined as majority state-controlled: big banks, oil majors, state telecoms, CNOOC, CITIC.
      All other companies classified as private / non-state-controlled.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- SOE column -->
      <div class="border border-red-100 rounded-md p-4">
        <div class="text-xs font-semibold text-red-700 uppercase tracking-wide mb-3">
          State-owned ({soeRows.length}) · Median RG10 {soeMedian.toFixed(2)}
        </div>
        {soeRows.map(r => (
          <div class="flex items-center justify-between py-1 border-b border-gray-50 last:border-0">
            <a href={`${base}/china/${r.slug}`} class="text-xs text-gray-700 hover:text-accent no-underline">{r.name}</a>
            <div class="flex items-center gap-2">
              <div class="w-16 h-2 bg-gray-100 rounded-sm overflow-hidden">
                <div class="h-full rounded-sm bg-red-300" style={`width:${Math.min(100,(r.rg10!/soeMedian/2)*100).toFixed(0)}%`}/>
              </div>
              <span class="font-mono text-xs font-semibold text-red-700 w-8 text-right">{fmt(r.rg10)}</span>
            </div>
          </div>
        ))}
      </div>
      <!-- Private column -->
      <div class="border border-amber-100 rounded-md p-4">
        <div class="text-xs font-semibold text-amber-700 uppercase tracking-wide mb-3">
          Private sector ({privateRows.length}) · Median RG10 {privateMedian.toFixed(2)}
        </div>
        {privateRows.map(r => (
          <div class="flex items-center justify-between py-1 border-b border-gray-50 last:border-0">
            <a href={`${base}/china/${r.slug}`} class="text-xs text-gray-700 hover:text-accent no-underline">{r.name}</a>
            <div class="flex items-center gap-2">
              <div class="w-16 h-2 bg-gray-100 rounded-sm overflow-hidden">
                <div class="h-full rounded-sm bg-amber-300" style={`width:${Math.min(100,(r.rg10!/privateMedian/2)*100).toFixed(0)}%`}/>
              </div>
              <span class="font-mono text-xs font-semibold text-amber-700 w-8 text-right">{fmt(r.rg10)}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 4. Cross-market comparison ────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1">4. Cross-Market Comparison</h2>
    <p class="text-sm text-gray-500 mb-1">Median RG10 of major indices vs. Hang Seng sub-groups.</p>
    <p class="text-xs text-gray-400 mb-5">Western index medians are approximate, based on the broader research dataset. Not directly comparable (different accounting standards, currency bases).</p>

    <div class="space-y-2">
      {benchmarks.sort((a,b) => b.rg - a.rg).map(b => (
        <div class="flex items-center gap-3 text-xs">
          <span class="text-gray-600 shrink-0" style="width:160px; text-align:right;">{b.label}</span>
          <div class="flex-1 bg-gray-100 rounded-sm h-5 relative" style="max-width:340px">
            <div class="h-5 rounded-sm" style={`width:${(b.rg/benchMax*100).toFixed(1)}%;background:${b.color};opacity:0.75`}/>
          </div>
          <span class="font-mono font-semibold text-gray-700 w-8 shrink-0">{b.rg.toFixed(2)}</span>
        </div>
      ))}
    </div>
    <div class="mt-6 border border-gray-100 rounded-md p-4 bg-gray-50/50 text-sm text-gray-600">
      <p class="font-semibold text-gray-700 mb-1">What the comparison shows</p>
      <ul class="space-y-1 text-xs text-gray-500 list-none">
        <li>— The Hang Seng <em>as a whole</em> (median {cnMedian.toFixed(2)}) sits below Japan and close to the DAX — not obviously cheap, but not elevated either.</li>
        <li>— The private-sector sub-group (median {privateMedian.toFixed(2)}) overlaps with FTSE and DAX territory — comparable to conservative European pricing.</li>
        <li>— The SOE sub-group (median {soeMedian.toFixed(2)}) has no Western parallel. US, European, and Japanese large-caps simply do not trade at this discount to conservative coverage.</li>
        <li>— The US premium ({benchmarks.find(b=>b.label==='S&P 500')?.rg.toFixed(2)}) remains the outlier at the other end: a structural narrative premium that Chinese markets, even at their private-sector best, do not replicate.</li>
      </ul>
    </div>
  </section>

  <!-- ── 5. Full Metrics Table ─────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1">5. Full Metrics Table</h2>
    <p class="text-xs text-gray-400 mb-4">Current / most recent period. All values in HKD billions. G = 4-year average net income.</p>
    <div class="overflow-x-auto">
      <table class="table-rg w-full text-xs">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-gray-500 font-medium whitespace-nowrap px-2 py-1.5">Company</th>
            <th class="text-center text-gray-400 font-normal whitespace-nowrap px-2 py-1.5">Type</th>
            <th class="text-right text-gray-500 font-medium whitespace-nowrap px-2 py-1.5">MC</th>
            <th class="text-right text-gray-500 font-medium whitespace-nowrap px-2 py-1.5">TE</th>
            <th class="text-right text-gray-500 font-medium whitespace-nowrap px-2 py-1.5">G avg</th>
            <th class="text-right text-gray-500 font-medium whitespace-nowrap px-2 py-1.5">RG8</th>
            <th class="text-right text-gray-500 font-medium whitespace-nowrap px-2 py-1.5">RG10</th>
            <th class="text-right text-gray-500 font-medium whitespace-nowrap px-2 py-1.5">RG12</th>
            <th class="text-left text-gray-400 font-normal whitespace-nowrap px-2 py-1.5">Period</th>
          </tr>
        </thead>
        <tbody>
          {rowsSorted.map(r => (
            <tr class="border-b border-gray-50 hover:bg-gray-50/50">
              <td class="whitespace-nowrap px-2 py-1.5">
                <a href={`${base}/china/${r.slug}`}
                   class={`font-medium hover:text-accent no-underline ${r.isSoe ? 'text-red-700' : 'text-gray-800'}`}>
                  {r.name}
                </a>
              </td>
              <td class="text-center px-2 py-1.5">
                <span class={`text-xs rounded px-1.5 py-0.5 ${r.isSoe ? 'bg-red-50 text-red-600' : 'bg-gray-50 text-gray-400'}`}>
                  {r.isSoe ? 'SOE' : 'priv'}
                </span>
              </td>
              <td class="text-right font-mono px-2 py-1.5 text-gray-600">{r.mc != null ? Math.round(r.mc).toLocaleString() : '—'}</td>
              <td class="text-right font-mono px-2 py-1.5 text-gray-600">{r.te != null ? Math.round(r.te).toLocaleString() : '—'}</td>
              <td class="text-right font-mono px-2 py-1.5 text-gray-600">{r.g  != null ? Math.round(r.g).toLocaleString()  : '—'}</td>
              <td class="text-right font-mono px-2 py-1.5">{fmt(r.rg8)}</td>
              <td class="text-right font-mono px-2 py-1.5 font-semibold text-accent">{fmt(r.rg10)}</td>
              <td class="text-right font-mono px-2 py-1.5">{fmt(r.rg12)}</td>
              <td class="text-left text-gray-400 px-2 py-1.5">{r.period}</td>
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr class="border-t-2 border-gray-200 bg-gray-50">
            <td class="px-2 py-1.5 text-gray-600 font-semibold" colspan={6}>Overall median</td>
            <td class="text-right font-mono font-semibold text-gray-800 px-2 py-1.5">{cnMedian.toFixed(2)}</td>
            <td colspan={2}></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </section>

  <!-- ── 6. Methodology ─────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4">6. Methodology and Limitations</h2>
    <div class="overflow-x-auto">
      <table class="table-rg w-full text-xs">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-gray-500 font-medium px-2 py-1.5 w-32">Dimension</th>
            <th class="text-left text-gray-500 font-medium px-2 py-1.5">Note</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Source', 'yfinance / Yahoo Finance, re-aggregating HKEX-reported financials. Not audited. Prototype-grade only.'],
            ['Market cap', 'Current MC (latest) or shares × year-end close price for historical periods. Share count drift not corrected.'],
            ['Earnings smoothing', '4-year average net income (G). Many CN companies are semi-annual or annual reporters; quarterly smoothing as in US/EU is not always available.'],
            ['Currency', 'All values in HKD billions throughout. No CNY/HKD conversion. No CPI inflation adjustment.'],
            ['Accounting standards', 'ASBE (Chinese GAAP) differs from IFRS/US GAAP in goodwill impairment, R&D capitalisation, and minority interest treatment. RG values are not directly comparable across standards.'],
            ['SOE classification', '11 companies classified as state-owned (majority state-controlled). Borderline cases (Ping An, Longfor) classified as private. Classification affects the bifurcation analysis.'],
            ['Historical depth', 'Typically 3–6 observations per company. Insufficient for long-horizon fragility analysis. The US dataset covers back to 2009 via SEC XBRL.'],
            ['Interpretation', 'Low RG for SOEs reflects investors\' discount for earnings quality and capital return uncertainty — not necessarily undervaluation in a fundamental sense.'],
          ].map(([dim, note]) => (
            <tr class="border-b border-gray-50">
              <td class="font-medium text-gray-700 whitespace-nowrap px-2 py-2 align-top">{dim}</td>
              <td class="text-gray-500 px-2 py-2">{note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <p class="text-xs text-gray-400 border-t border-gray-100 pt-6">
    All data is illustrative and for research purposes only. Not investment advice.
    Data via yfinance / Yahoo Finance. Values in HKD billions.
    RG = Market Cap / (Tangible Equity + N × Smoothed Earnings).
  </p>

</div>
</BaseLayout>
