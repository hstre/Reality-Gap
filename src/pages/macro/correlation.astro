---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import capeRaw     from '../../data/macro/sp500_cape.json';
import buffettRaw  from '../../data/macro/buffett_global.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ── Align annual data: Dec CAPE/10 + US Buffett (1975–2024) ──────────────────
const decByYear: Record<string, number> = {};
for (const p of (capeRaw as any).series as Array<{ date: string; rg10: number }>) {
  if (p.date.endsWith('-12')) decByYear[p.date.slice(0, 4)] = p.rg10;
}
const usSeries: Array<{ year: number; value: number }> =
  (buffettRaw as any).countries.US.series;

interface Pair { year: number; rg10: number; buffett: number; }
const pairs: Pair[] = usSeries
  .filter(d => decByYear[String(d.year)] !== undefined)
  .map(d => ({ year: d.year, rg10: decByYear[String(d.year)], buffett: d.value }));

// ── Stats ─────────────────────────────────────────────────────────────────────
const n       = pairs.length;
const meanRg  = pairs.reduce((s, p) => s + p.rg10, 0) / n;
const meanBuf = pairs.reduce((s, p) => s + p.buffett, 0) / n;
const cov     = pairs.reduce((s, p) => s + (p.rg10 - meanRg) * (p.buffett - meanBuf), 0) / n;
const stdRg   = Math.sqrt(pairs.reduce((s, p) => s + (p.rg10 - meanRg) ** 2, 0) / n);
const stdBuf  = Math.sqrt(pairs.reduce((s, p) => s + (p.buffett - meanBuf) ** 2, 0) / n);
const corr    = cov / (stdRg * stdBuf);

const curRg10   = (capeRaw as any).current.rg10 as number;
const curBuf    = (buffettRaw as any).countries.US.latest.value as number;
const curBufYr  = (buffettRaw as any).countries.US.latest.year as number;

// ── Chart JSON ────────────────────────────────────────────────────────────────
const chartData = JSON.stringify({
  years:    pairs.map(p => p.year),
  rg10:     pairs.map(p => p.rg10),
  buffett:  pairs.map(p => p.buffett),
  avgRg10:  pairs.map(() => parseFloat(meanRg.toFixed(3))),
  avgBuf:   pairs.map(() => parseFloat(meanBuf.toFixed(1))),
});

// ── Key episodes ──────────────────────────────────────────────────────────────
const episodes = [
  { period: '1975–1994', label: 'Structurally cheap era', rg10: '0.9–2.0', buffett: '37–71%',
    note: 'Both metrics far below today. Buffett Indicator below 100% every year; CAPE at or below long-run average.' },
  { period: '1995–2000', label: 'Tech-boom surge', rg10: '2.5→4.4', buffett: '91→153%',
    note: 'Synchronized explosion upward. CAPE peaked at 44.2 (Dec 1999). Buffett hit 153% — first time above 100%.' },
  { period: '2001–2002', label: 'Dot-com unwind', rg10: '3.1→2.3', buffett: '132→101%',
    note: 'Both deflated together but remained elevated. CAPE slow to fall because earnings had already been inflated.' },
  { period: '2008',      label: 'Financial crisis', rg10: '1.5', buffett: '79%',
    note: 'Buffett crashed 43% in one year (equity value wiped out). CAPE fell less — earnings lag effect.' },
  { period: '2009',      label: 'Post-crisis recovery', rg10: '2.0', buffett: '104%',
    note: 'Buffett recovered +32% as markets rebounded before earnings. Divergence: Buffett surged, CAPE lagged.' },
  { period: '2020–2021', label: 'COVID-era expansion', rg10: '3.4→3.8', buffett: '197→208%',
    note: 'Both at historic highs. Buffett disproportionate: fiscal stimulus expanded GDP slowly, equities exploded.' },
  { period: '2024',      label: 'Current: new all-time high', rg10: curRg10.toFixed(2), buffett: `${curBuf}%`,
    note: `Buffett at all-time high (${curBuf}%). CAPE/10 at ${curRg10.toFixed(2)}× — elevated but below 2000 peak (4.42×). Structural divergence: equities now ${curBuf}% of GDP, never seen before.` },
];

function fmt(v: number, d = 2): string { return v.toFixed(d); }
---

<BaseLayout
  title="Macro RG × Buffett Indicator — Correlation Analysis"
  description="How correlated are the Shiller CAPE-based Macro RG and the US Buffett Indicator? Historical analysis 1975–2024."
  lang="en"
  canonicalPath="/macro/correlation"
  altLangPath="/de/makro/korrelation"
  altLang="de"
>
<div class="max-w-5xl mx-auto px-6 py-12">

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────── -->
  <div class="mb-2 flex items-center gap-2 text-sm text-gray-400">
    <a href={`${base}/`} class="hover:text-accent no-underline">Home</a>
    <span>›</span>
    <a href={`${base}/macro`} class="hover:text-accent no-underline">Macro RG</a>
    <span>›</span>
    <span class="text-gray-600 font-medium">Correlation Analysis</span>
  </div>

  <!-- ── Index switcher ──────────────────────────────────────────────────── -->
  <div class="flex items-center gap-2 mb-6 flex-wrap">
    <a href={`${base}/macro`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      S&amp;P 500
    </a>
    <a href={`${base}/macro/dax40`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      DAX 40
    </a>
    <a href={`${base}/macro/global`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      Global Buffett Indicator
    </a>
    <span class="text-xs border border-accent bg-accent/5 text-accent rounded px-3 py-1 font-medium">
      Correlation ←
    </span>
  </div>

  <!-- ── Header ──────────────────────────────────────────────────────────── -->
  <h1 class="text-3xl font-normal text-gray-900 mb-2" style="font-family: Georgia, serif;">
    Macro RG × Buffett Indicator — Correlation
  </h1>
  <p class="text-gray-600 mb-1">
    How closely do the Shiller CAPE-based Macro RG and the US Buffett Indicator
    (market cap / GDP) move together — and where do they diverge?
  </p>
  <div class="flex flex-wrap gap-2 mb-8">
    <span class="text-xs bg-blue-50 text-blue-700 border border-blue-200 rounded px-2 py-0.5">
      r = {fmt(corr, 3)} over {n} years
    </span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">
      Annual series · 1975–{pairs[pairs.length - 1].year}
    </span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">
      CAPE: Yale / Shiller · Buffett: World Bank
    </span>
  </div>

  <!-- ── Section 1: Core Finding ─────────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      1. Core Finding
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <!-- Correlation -->
      <div class="border border-blue-200 rounded-md p-5 bg-blue-50">
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">Pearson r (1975–{pairs[pairs.length-1].year})</div>
        <div class="text-4xl font-mono font-semibold text-blue-700 mb-1">{fmt(corr, 3)}</div>
        <div class="text-xs text-blue-600 font-medium mt-1">Very strong positive correlation</div>
        <div class="text-xs text-gray-500 mt-2">Dec CAPE/10 vs. annual Buffett, {n} paired observations</div>
      </div>

      <!-- Current CAPE/10 -->
      <div class="border border-gray-200 rounded-md p-5 bg-gray-50">
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">M(S&amp;P 500)RG10 — now</div>
        <div class="text-3xl font-mono font-semibold text-orange-700 mb-1">{fmt(curRg10)}×</div>
        <div class="text-xs text-gray-500">CAPE/10 · {(capeRaw as any).current.date}</div>
        <div class="text-xs text-gray-400 mt-2">Overlap-period avg: {fmt(meanRg)}×</div>
      </div>

      <!-- Current Buffett -->
      <div class="border border-gray-200 rounded-md p-5 bg-gray-50">
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">US Buffett Indicator — {curBufYr}</div>
        <div class="text-3xl font-mono font-semibold text-orange-700 mb-1">{curBuf}%</div>
        <div class="text-xs text-gray-500">Market cap / GDP · World Bank</div>
        <div class="text-xs text-gray-400 mt-2">Overlap-period avg: {fmt(meanBuf, 1)}%</div>
      </div>
    </div>

    <!-- Interpretation -->
    <div class="border-l-2 border-blue-200 pl-4 text-sm text-gray-600 space-y-2">
      <p>
        A Pearson correlation of <strong>{fmt(corr, 3)}</strong> means the two metrics move in the same direction
        roughly <strong>{Math.round(corr * corr * 100)}%</strong> of the time (R²). They share the same
        macro drivers — interest rate cycles, economic expansions, and risk appetite — but measure different
        dimensions of the same phenomenon.
      </p>
      <p>
        <strong>What each captures:</strong> Macro RG (CAPE/10) reflects how expensive corporate earnings are
        relative to a smoothed 10-year baseline. The Buffett Indicator reflects how large the equity market
        has grown relative to the total economy. High correlation means both signal excess simultaneously —
        but the <em>magnitude</em> and <em>timing</em> of their movements differ, and that divergence
        carries information.
      </p>
    </div>
  </section>

  <!-- ── Section 2: Dual-axis chart ──────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      2. Historical Comparison (1975–{pairs[pairs.length-1].year})
    </h2>
    <p class="text-sm text-gray-500 mb-4">
      Annual series. Left axis: M(S&amp;P 500)RG10 = CAPE ÷ 10. Right axis: US Buffett Indicator (%).
      Dashed lines = overlap-period averages.
    </p>

    <!-- Legend -->
    <div class="flex flex-wrap gap-5 mb-3 text-xs text-gray-500 select-none">
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#1e4d78" stroke-width="2.5"/>
        </svg>
        M(S&amp;P 500)RG10 (left)
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#b45309" stroke-width="2.5"/>
        </svg>
        US Buffett Indicator % (right)
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#9ca3af" stroke-width="1.5" stroke-dasharray="4 3"/>
        </svg>
        Period averages
      </span>
    </div>

    <div class="relative" style="height: 300px;">
      <canvas
        id="correlation-chart"
        data-chart={chartData}
        data-avg-rg={fmt(meanRg, 3)}
        data-avg-buf={fmt(meanBuf, 1)}
        aria-label="Macro RG vs Buffett Indicator 1975–2024"
        role="img"
        style="width: 100%; height: 100%;"
      ></canvas>
    </div>
    <p class="text-xs text-gray-400 mt-2">
      CAPE source: Robert Shiller / Yale (December monthly reading used for annual alignment).
      Buffett Indicator source: World Bank — CM.MKT.LCAP.GD.ZS.
    </p>
  </section>

  <!-- ── Section 3: Why they correlate ───────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      3. Why They Correlate — and What Each Adds
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="border border-gray-200 rounded-md p-5">
        <div class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Shared drivers (why r = {fmt(corr, 2)})</div>
        <ul class="space-y-2 text-xs text-gray-500">
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">—</span>
            <span><strong class="text-gray-600">Interest rates.</strong> Lower rates raise equity valuations (CAPE rises) and expand market cap relative to GDP (Buffett rises). Simultaneously.</span>
          </li>
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">—</span>
            <span><strong class="text-gray-600">Economic expansions.</strong> GDP growth and corporate earnings growth tend to coincide, pulling both metrics in the same direction.</span>
          </li>
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">—</span>
            <span><strong class="text-gray-600">Risk appetite.</strong> Bull markets compress risk premia, pushing up both the earnings multiple (CAPE) and the overall market-to-economy ratio.</span>
          </li>
        </ul>
      </div>

      <div class="border border-gray-200 rounded-md p-5">
        <div class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">What each captures uniquely</div>
        <ul class="space-y-2 text-xs text-gray-500">
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">—</span>
            <span><strong class="text-gray-600">Macro RG / CAPE.</strong> Earnings-cycle valuation. Smooths over a full business cycle, detecting whether prices are expensive relative to <em>long-run</em> earnings capacity.</span>
          </li>
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">—</span>
            <span><strong class="text-gray-600">Buffett Indicator.</strong> Structural concentration. How large is the listed equity sector relative to the whole economy? Captures financialization — the growing share of GDP represented by listed corporations.</span>
          </li>
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">—</span>
            <span><strong class="text-gray-600">The gap between them</strong> signals whether earnings are expensive (CAPE problem) or whether markets have simply grown larger than the economy can justify (structural problem).</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ── Section 4: Historical episodes ──────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      4. Key Historical Episodes
    </h2>
    <p class="text-sm text-gray-500 mb-5">
      Periods where the two metrics converged, diverged, or gave conflicting signals.
    </p>

    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">Period</th>
            <th class="text-left text-xs text-gray-500 font-medium">Episode</th>
            <th class="text-left text-xs text-gray-500 font-medium">RG10</th>
            <th class="text-left text-xs text-gray-500 font-medium">Buffett</th>
            <th class="text-left text-xs text-gray-500 font-medium">Key observation</th>
          </tr>
        </thead>
        <tbody>
          {episodes.map(ep => (
            <tr>
              <td class="font-mono text-xs text-gray-600 whitespace-nowrap">{ep.period}</td>
              <td class="text-sm font-medium text-gray-800 whitespace-nowrap">{ep.label}</td>
              <td class="font-mono text-sm text-gray-700 whitespace-nowrap">{ep.rg10}</td>
              <td class="font-mono text-sm text-gray-700 whitespace-nowrap">{ep.buffett}</td>
              <td class="text-xs text-gray-500">{ep.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Section 5: Current reading ──────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      5. Current Reading ({(capeRaw as any).current.date} / {curBufYr})
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
      <div class="border border-orange-200 rounded-md p-5 bg-orange-50">
        <div class="text-xs text-gray-500 mb-2 font-medium uppercase tracking-wide">M(S&amp;P 500)RG10</div>
        <div class="text-3xl font-mono font-semibold text-orange-700 mb-1">{fmt(curRg10)}×</div>
        <div class="text-xs text-gray-600">
          {fmt(((curRg10 - meanRg) / meanRg * 100), 0)}% above overlap-period average ({fmt(meanRg)}×).
          Below the 2000 dot-com peak (4.42×). Historically in the 85th–90th percentile.
        </div>
      </div>
      <div class="border border-orange-200 rounded-md p-5 bg-orange-50">
        <div class="text-xs text-gray-500 mb-2 font-medium uppercase tracking-wide">US Buffett Indicator</div>
        <div class="text-3xl font-mono font-semibold text-orange-700 mb-1">{curBuf}%</div>
        <div class="text-xs text-gray-600">
          {fmt(((curBuf - meanBuf) / meanBuf * 100), 0)}% above overlap-period average ({fmt(meanBuf, 1)}%).
          All-time high — no prior year in the dataset exceeded this level.
        </div>
      </div>
    </div>

    <div class="border-l-2 border-orange-200 pl-4 text-sm text-gray-600 space-y-2">
      <p>
        <strong>The divergence in extremity matters.</strong> CAPE is elevated but not at 2000 bubble levels.
        The Buffett Indicator is at a genuine all-time high with no historical precedent in 50 years of data.
        This asymmetry suggests the excess is partly structural — equities have grown as a share of
        the economy beyond what earnings multiples alone would imply.
      </p>
      <p>
        One explanation: the post-2010 era combined zero-rate policy (which expands CAPE) with
        tech-sector concentration and share buybacks (which expand market cap without proportional
        GDP growth). The result is a Buffett Indicator that has drifted structurally higher even
        as CAPE periodically corrected.
      </p>
    </div>
  </section>

  <!-- ── Section 6: Limitations ──────────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      6. Limitations
    </h2>
    <div class="space-y-3 text-xs text-gray-500">
      <div class="flex gap-3">
        <span class="text-gray-300 shrink-0 mt-0.5">—</span>
        <span><strong class="text-gray-600">Correlation ≠ causation.</strong> Both metrics rise in bull markets because they share macro drivers, not because one causes the other.</span>
      </div>
      <div class="flex gap-3">
        <span class="text-gray-300 shrink-0 mt-0.5">—</span>
        <span><strong class="text-gray-600">Structural shift in Buffett baseline.</strong> The US Buffett Indicator has risen secularly since 1990 as the corporate sector financialized. The 1975–2024 average of {fmt(meanBuf, 1)}% includes a long low-value period (1975–1995) that may not be representative of the current economy.</span>
      </div>
      <div class="flex gap-3">
        <span class="text-gray-300 shrink-0 mt-0.5">—</span>
        <span><strong class="text-gray-600">CAPE timing lag.</strong> CAPE uses 10-year trailing earnings. In sharp recessions (2008–09), earnings collapse fast while the 10-year average moves slowly — making CAPE appear lower than actual conditions warrant. Buffett reacts more immediately to market cap changes.</span>
      </div>
      <div class="flex gap-3">
        <span class="text-gray-300 shrink-0 mt-0.5">—</span>
        <span><strong class="text-gray-600">Annual vs. monthly granularity.</strong> The Buffett series is annual (World Bank); CAPE is monthly. This analysis uses December CAPE to align, losing intra-year detail.</span>
      </div>
      <div class="flex gap-3">
        <span class="text-gray-300 shrink-0 mt-0.5">—</span>
        <span><strong class="text-gray-600">Not a predictive model.</strong> High correlation between two valuation metrics does not predict near-term returns. Both can remain elevated for years.</span>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <p class="text-xs text-gray-400 border-t border-gray-100 pt-6">
    CAPE source: Robert Shiller, Yale University — ie_data.xls, monthly series 1881–present.
    Buffett Indicator source: World Bank Open Data — CM.MKT.LCAP.GD.ZS, annual 1975–{curBufYr}.
    Correlation computed on {n} aligned annual observations (December CAPE/10 vs. annual Buffett).
    For research purposes only. Not investment advice.
  </p>

</div>

<!-- ── Chart.js ─────────────────────────────────────────────────────────────── -->
<script>
  function initCorrelationChart(): void {
    const canvas = document.getElementById('correlation-chart') as HTMLCanvasElement | null;
    if (!canvas) return;
    if ((canvas as any).__corrChartInit) return;
    (canvas as any).__corrChartInit = true;

    const Chart = (window as any).Chart;
    if (!Chart) return;

    const raw    = canvas.getAttribute('data-chart');
    const avgRg  = parseFloat(canvas.getAttribute('data-avg-rg') ?? '0');
    const avgBuf = parseFloat(canvas.getAttribute('data-avg-buf') ?? '0');
    if (!raw) return;

    const { years, rg10, buffett, avgRg10, avgBuf: avgBufLine } = JSON.parse(raw) as {
      years: number[]; rg10: number[]; buffett: number[];
      avgRg10: number[]; avgBuf: number[];
    };

    new Chart(canvas, {
      type: 'line',
      data: {
        labels: years,
        datasets: [
          {
            label: 'M(S&P500)RG10',
            data: rg10,
            borderColor: '#1e4d78',
            backgroundColor: 'rgba(30,77,120,0.07)',
            fill: false,
            borderWidth: 2.5,
            pointRadius: 2,
            pointHoverRadius: 5,
            tension: 0.2,
            yAxisID: 'y',
            order: 1,
          },
          {
            label: `RG avg (${avgRg.toFixed(2)}×)`,
            data: avgRg10,
            borderColor: '#1e4d78',
            backgroundColor: 'transparent',
            borderWidth: 1,
            borderDash: [5, 4],
            pointRadius: 0,
            tension: 0,
            yAxisID: 'y',
            order: 3,
          },
          {
            label: 'US Buffett Indicator',
            data: buffett,
            borderColor: '#b45309',
            backgroundColor: 'rgba(180,83,9,0.07)',
            fill: false,
            borderWidth: 2.5,
            pointRadius: 2,
            pointHoverRadius: 5,
            tension: 0.2,
            yAxisID: 'y2',
            order: 2,
          },
          {
            label: `Buffett avg (${avgBuf.toFixed(1)}%)`,
            data: avgBufLine,
            borderColor: '#b45309',
            backgroundColor: 'transparent',
            borderWidth: 1,
            borderDash: [5, 4],
            pointRadius: 0,
            tension: 0,
            yAxisID: 'y2',
            order: 4,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx: any): string => {
                const v = ctx.parsed.y;
                if (v == null) return '';
                return ctx.datasetIndex <= 1
                  ? `${ctx.dataset.label}: ${Number(v).toFixed(2)}×`
                  : `${ctx.dataset.label}: ${Number(v).toFixed(1)}%`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: '#9ca3af', font: { size: 10 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 12 },
            border: { color: '#e5e7eb' },
          },
          y: {
            beginAtZero: true,
            min: 0,
            max: 5,
            position: 'left',
            grid: { color: '#f3f4f6' },
            ticks: {
              color: '#1e4d78',
              font: { size: 10 },
              callback: (v: any): string => `${Number(v).toFixed(1)}×`,
            },
            border: { color: '#dbeafe' },
            title: { display: true, text: 'RG10', color: '#1e4d78', font: { size: 9 } },
          },
          y2: {
            beginAtZero: true,
            min: 0,
            max: 250,
            position: 'right',
            grid: { display: false },
            ticks: {
              color: '#b45309',
              font: { size: 10 },
              callback: (v: any): string => `${Number(v).toFixed(0)}%`,
            },
            border: { color: '#fef3c7' },
            title: { display: true, text: 'Buffett %', color: '#b45309', font: { size: 9 } },
          },
        },
      },
    });
  }

  function loadChartJs(cb: () => void): void {
    if ((window as any).Chart) { cb(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    s.onload = cb;
    s.onerror = (): void => console.warn('CorrChart: Chart.js failed to load');
    document.head.appendChild(s);
  }

  loadChartJs(initCorrelationChart);
</script>

</BaseLayout>
