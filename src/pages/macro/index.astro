---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import capeRaw from '../../data/macro/sp500_cape.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ── Types ────────────────────────────────────────────────────────────────────
interface CapePoint { date: string; cape: number; rg10: number; }
interface CapeData {
  source: string; url: string; fetched: string; note: string;
  sources: string[];
  yale_cutoff: string;
  supplement_url: string | null;
  series_standard: string;
  long_run_avg_rg10: number;
  long_run_max_rg10: number;
  long_run_min_rg10: number;
  current: { date: string; cape: number; rg10: number; trend: string; };
  series: CapePoint[];
  peaks: Array<{ date: string; note: string; cape?: number; rg10?: number; }>;
}

const data = capeRaw as unknown as CapeData;

// ── Current reading — last monthly observation in the series ─────────────────
const cur     = data.current;
const rg10    = cur.rg10;
const trend   = cur.trend;
const display = `${rg10.toFixed(2)}${trend}`;

// ── Long-run stats (pre-computed in JSON) ────────────────────────────────────
const avgRg10 = data.long_run_avg_rg10;
const maxRg10 = data.long_run_max_rg10;
const minRg10 = data.long_run_min_rg10;

// ── Interpretation band for current value ────────────────────────────────────
function bandFor(v: number): { label: string; color: string; bg: string; border: string; } {
  if (v < 1.0) return { label: 'Below long-run average — historically infrequent',
                         color: 'text-emerald-700', bg: 'bg-emerald-50', border: 'border-emerald-200' };
  if (v < 1.8) return { label: 'Around long-run average (~1.7) — historically normal zone',
                         color: 'text-blue-700',    bg: 'bg-blue-50',    border: 'border-blue-200' };
  if (v < 2.5) return { label: 'Above average — caution zone',
                         color: 'text-amber-700',   bg: 'bg-amber-50',   border: 'border-amber-200' };
  if (v < 3.5) return { label: 'Strongly stretched — historically elevated',
                         color: 'text-orange-700',  bg: 'bg-orange-50',  border: 'border-orange-200' };
  return              { label: 'Historically very hot — rare territory',
                         color: 'text-red-700',     bg: 'bg-red-50',     border: 'border-red-200' };
}
const band = bandFor(rg10);

// ── Interpretation bands table data ─────────────────────────────────────────
const bands = [
  { lo: 0,   hi: 1.0, rg: '< 1.0',   cape: '< 10',  label: 'Below long-run avg / historically attractive',  color: 'bg-emerald-50 text-emerald-700 border-emerald-200', ctx: 'Rare outside major bear markets or crises. 1982, 2009 briefly.' },
  { lo: 1.0, hi: 1.8, rg: '1.0–1.8', cape: '10–18', label: 'Around long-run average — normal zone',         color: 'bg-blue-50 text-blue-700 border-blue-200',           ctx: 'Long-run CAPE mean ~17. Typical in post-WW2 recovery cycles.' },
  { lo: 1.8, hi: 2.5, rg: '1.8–2.5', cape: '18–25', label: 'Somewhat above average — caution',              color: 'bg-amber-50 text-amber-700 border-amber-200',         ctx: 'Common in extended bull markets (1960s, 1990s, 2010s).' },
  { lo: 2.5, hi: 3.5, rg: '2.5–3.5', cape: '25–35', label: 'Significantly stretched — elevated risk',       color: 'bg-orange-50 text-orange-700 border-orange-200',      ctx: 'Pre-GFC 2007 (~2.7), post-COVID 2021 (~3.9).' },
  { lo: 3.5, hi: 999, rg: '≥ 3.5',   cape: '≥ 35',  label: 'Historically very hot — rare territory',        color: 'bg-red-50 text-red-700 border-red-200',               ctx: 'Dot-com peak 2000 (~4.4), late-2021 peak (~3.9), today (~3.9).' },
];
const currentBandIdx = bands.findIndex(b => rg10 >= b.lo && rg10 < b.hi);

// ── Monthly chart series (all observations — same standard as current value) ──
// The chart and the displayed current value both come from the same monthly series.
// X-axis labels are YYYY-MM; Chart.js autoSkip shows ~15 tick marks (≈ every decade).
const chartLabels = data.series.map(p => p.date);
const chartRg10   = data.series.map(p => p.rg10);
const chartAvg    = data.series.map(() => parseFloat(avgRg10.toFixed(3)));
const chartData   = JSON.stringify({ labels: chartLabels, rg10: chartRg10, avg: chartAvg });

// ── Provenance labels ────────────────────────────────────────────────────────
const hasMultpl     = data.sources.includes('multpl_supplement');
const supplementNote = hasMultpl && data.supplement_url
  ? `Supplemented with multpl.com for months after ${data.yale_cutoff}.`
  : `Yale data only (through ${data.yale_cutoff}).`;

// ── Format helpers ───────────────────────────────────────────────────────────
function fmt2(v: number): string { return v.toFixed(2); }
---

<BaseLayout
  title="Macro RG — Reality Gap"
  description="M(S&P500)RG10: macro-level Reality Gap approximation using Shiller/CAPE data. Historical series 1881–present."
  lang="en"
  canonicalPath="/macro"
  altLangPath="/de/makro"
  altLang="de"
>
<div class="max-w-5xl mx-auto px-6 py-12">

  <!-- ── Header ──────────────────────────────────────────────────────────── -->
  <div class="mb-2">
    <a href={`${base}/`} class="text-sm text-gray-400 hover:text-accent no-underline">← Home</a>
  </div>

  <!-- Index switcher -->
  <div class="flex items-center gap-2 mb-4">
    <span class="text-xs border border-accent bg-accent/5 text-accent rounded px-3 py-1 font-medium">
      S&amp;P 500 ←
    </span>
    <a href={`${base}/macro/dax40`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      DAX 40
    </a>
  </div>

  <h1 class="text-3xl font-normal text-gray-900 mb-2" style="font-family: Georgia, serif;">
    Macro RG — Market-Level Approximation
  </h1>
  <p class="text-gray-600 mb-1">
    A macro extension of the Reality Gap framework, applying the RG lens to
    entire equity universes rather than individual companies.
  </p>
  <div class="flex flex-wrap gap-2 mb-8">
    <span class="text-xs bg-blue-50 text-blue-700 border border-blue-200 rounded px-2 py-0.5">Macro approximation — not full RG</span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">Monthly series · {data.series.length} observations</span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">Data through {cur.date} · fetched {data.fetched}</span>
    <span class="text-xs bg-amber-50 text-amber-700 border border-amber-200 rounded px-2 py-0.5">Tangible equity not included in this construction</span>
  </div>

  <!-- ── Section 1: Current Reading ─────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      1. Current Reading
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <!-- Main metric -->
      <div class={`border rounded-md p-5 col-span-1 md:col-span-1 ${band.bg} ${band.border}`}>
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">M(S&amp;P 500)RG10</div>
        <div class={`text-4xl font-mono font-semibold mb-1 ${band.color}`}>{display}</div>
        <div class="text-xs text-gray-500">as of {cur.date}</div>
        <div class={`text-xs mt-2 font-medium ${band.color}`}>{band.label}</div>
      </div>

      <!-- CAPE raw -->
      <div class="border border-gray-200 rounded-md p-5 bg-gray-50">
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">Shiller CAPE</div>
        <div class="text-3xl font-mono font-semibold text-gray-800 mb-1">{cur.cape.toFixed(1)}</div>
        <div class="text-xs text-gray-500">Cyclically adjusted P/E (10-year real earnings)</div>
        <div class="text-xs text-gray-400 mt-2">Long-run average: ~{(avgRg10 * 10).toFixed(1)}</div>
      </div>

      <!-- Formula card -->
      <div class="border border-gray-200 rounded-md p-5 bg-white">
        <div class="text-xs text-gray-500 mb-2 font-medium tracking-wide uppercase">Construction</div>
        <div class="font-mono text-sm text-gray-800 mb-3">M(S&amp;P 500)RG10 = CAPE / 10</div>
        <p class="text-xs text-gray-500">
          The firm-level RG is MC / (TE + 10·G). At the macro level, tangible equity
          data is not available. CAPE captures the price / smoothed-earnings ratio,
          which maps to the RG denominator's earnings term.
          The division by 10 aligns the scale with the capitalization factor N = 10.
        </p>
      </div>
    </div>

    <!-- Trend explanation -->
    <div class="text-sm text-gray-600 border-l-2 border-gray-200 pl-4">
      Trend sign appended directly to the value ({display}): compared to 12 months prior.
      <span class="font-mono text-gray-700 ml-1">++ &gt;+20% · + &gt;+5% · = ±5% · - &gt;-5% · -- &gt;-20%</span>
    </div>
  </section>

  <!-- ── Section 2: Interpretation Guide ────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      2. Heuristic Interpretation Bands
    </h2>
    <p class="text-sm text-gray-500 mb-5">
      Indicative reference only. These are not thresholds or signals — history shows
      that markets can remain in any zone for extended periods.
    </p>

    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">M(S&amp;P 500)RG10</th>
            <th class="text-left text-xs text-gray-500 font-medium">CAPE equivalent</th>
            <th class="text-left text-xs text-gray-500 font-medium">Heuristic label</th>
            <th class="text-left text-xs text-gray-500 font-medium">Context</th>
          </tr>
        </thead>
        <tbody>
          {bands.map((row, i) => (
            <tr class={i === currentBandIdx ? 'bg-blue-50/40' : ''}>
              <td class="font-mono font-semibold text-sm text-gray-800 whitespace-nowrap">
                {row.rg}
                {i === currentBandIdx && (
                  <span class={`ml-2 text-xs rounded px-1.5 py-0.5 border font-normal ${row.color}`}>← current</span>
                )}
              </td>
              <td class="font-mono text-sm text-gray-600 whitespace-nowrap">{row.cape}</td>
              <td><span class={`text-xs rounded px-2 py-0.5 border font-medium ${row.color}`}>{row.label}</span></td>
              <td class="text-xs text-gray-500">{row.ctx}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Section 3: Historical Chart ────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      3. M(S&amp;P 500)RG10 — Monthly Series (1881–{cur.date})
    </h2>
    <p class="text-sm text-gray-500 mb-1">
      <strong>Monthly observations</strong> — same series standard as the current value above.
      Dashed line = long-run average ({fmt2(avgRg10)}×).
    </p>
    <p class="text-xs text-gray-400 mb-4">
      Primary: Yale ie_data.xls (1881-01 – {data.yale_cutoff}).
      {hasMultpl && `Supplemented with multpl.com (${data.yale_cutoff} – ${cur.date}).`}
    </p>

    <!-- Legend -->
    <div class="flex flex-wrap gap-5 mb-3 text-xs text-gray-500 select-none">
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#1e4d78" stroke-width="2.5"/>
        </svg>
        M(S&amp;P 500)RG10
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#9ca3af" stroke-width="1.5" stroke-dasharray="4 3"/>
        </svg>
        Long-run average ({fmt2(avgRg10)}×)
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#ef4444" stroke-width="1" stroke-dasharray="2 2"/>
        </svg>
        RG10 = 1.0 reference
      </span>
    </div>

    <div class="relative" style="height: 300px;">
      <canvas
        id="macro-cape-chart"
        data-chart={chartData}
        data-avg={fmt2(avgRg10)}
        aria-label="M(S&P500)RG10 historical series 1881–present"
        role="img"
        style="width: 100%; height: 100%;"
      ></canvas>
    </div>
    <p class="text-xs text-gray-400 mt-2">
      Monthly values · {data.series.length} data points · range {fmt2(minRg10)}× – {fmt2(maxRg10)}×.
      CAPE series begins 1881 (requires 10 years of prior earnings starting 1871).
    </p>
  </section>

  <!-- ── Section 4: Key Historical Peaks ────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      4. Key Historical Peaks
    </h2>
    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">Episode</th>
            <th class="text-left text-xs text-gray-500 font-medium">Date</th>
            <th class="text-right text-xs text-gray-500 font-medium">CAPE</th>
            <th class="text-right text-xs text-gray-500 font-medium">M(S&amp;P 500)RG10</th>
            <th class="text-left text-xs text-gray-500 font-medium">Note</th>
          </tr>
        </thead>
        <tbody>
          {data.peaks.filter(p => p.cape != null).map(p => (
            <tr>
              <td class="text-sm font-medium text-gray-800">{p.note}</td>
              <td class="font-mono text-sm text-gray-600">{p.date}</td>
              <td class="text-right font-mono text-sm text-gray-800">{p.cape!.toFixed(2)}</td>
              <td class="text-right font-mono text-sm font-semibold text-accent">{p.rg10!.toFixed(2)}</td>
              <td class="text-xs text-gray-500">
                {p.rg10! >= 3.5 ? 'Historically very hot' :
                 p.rg10! >= 2.5 ? 'Significantly stretched' :
                 p.rg10! >= 1.8 ? 'Above average' : 'Moderate'}
              </td>
            </tr>
          ))}
          <!-- Current -->
          <tr class="bg-blue-50/30">
            <td class="text-sm font-medium text-gray-800">Current reading</td>
            <td class="font-mono text-sm text-gray-600">{cur.date}</td>
            <td class="text-right font-mono text-sm text-gray-800">{cur.cape.toFixed(2)}</td>
            <td class="text-right font-mono text-sm font-semibold text-accent">{rg10.toFixed(2)}{trend}</td>
            <td class={`text-xs font-medium ${band.color}`}>{band.label.split('—')[0].trim()}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Section 5: Other Markets (Placeholder) ─────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      5. Other Equity Universes
    </h2>
    <p class="text-sm text-gray-500 mb-5">
      Macro RG coverage is currently limited to the S&amp;P 500 via Shiller data.
      Other markets are listed below in the planned extension roadmap.
      No values are shown until the underlying data can be independently verified.
    </p>
    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">Notation</th>
            <th class="text-left text-xs text-gray-500 font-medium">Universe</th>
            <th class="text-left text-xs text-gray-500 font-medium">Planned source</th>
            <th class="text-left text-xs text-gray-500 font-medium">Status</th>
          </tr>
        </thead>
        <tbody>
          {[
            { m: 'M(S&P 500)RG10',   uni: 'S&P 500 (US large-cap)',       src: 'Shiller ie_data.xls / Yale',          st: 'live' },
            { m: 'M(DAX)RG10',       uni: 'DAX 40 (German large-cap)',     src: 'StarCapital / Barclays CAPE series',   st: 'planned' },
            { m: 'M(Nikkei 225)RG10',uni: 'Nikkei 225 (Japanese large-cap)',src: 'StarCapital / local academic sources', st: 'planned' },
            { m: 'M(STOXX 600)RG10', uni: 'STOXX Europe 600',              src: 'MSCI / Barclays European CAPE',        st: 'exploratory' },
            { m: 'M(MOEX)RG10',      uni: 'Moscow Exchange (Russia)',      src: 'Limited / disputed data',             st: 'exploratory' },
            { m: 'M(EM)RG10',        uni: 'MSCI Emerging Markets',         src: 'MSCI CAPE data',                      st: 'exploratory' },
          ].map(row => (
            <tr>
              <td class="font-mono text-sm text-gray-800 whitespace-nowrap" set:html={row.m} />
              <td class="text-sm text-gray-700">{row.uni}</td>
              <td class="text-xs text-gray-500">{row.src}</td>
              <td>
                <span class={[
                  'text-xs rounded px-2 py-0.5 font-medium border',
                  row.st === 'live'        ? 'bg-emerald-50 text-emerald-700 border-emerald-200' :
                  row.st === 'planned'     ? 'bg-blue-50 text-blue-700 border-blue-200' :
                                             'bg-gray-50 text-gray-500 border-gray-200'
                ].join(' ')}>
                  {row.st}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Section 6: Methodology ─────────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      6. Methodology and Limitations
    </h2>
    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">Dimension</th>
            <th class="text-left text-xs text-gray-500 font-medium">Detail</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Measure name',          'M(S&P 500)RG10 — M for macro, (S&P 500) for the universe, RG10 for the capitalization factor N=10'],
            ['Formula',               'M(S&P 500)RG10 = CAPE / 10, where CAPE = P / (10-year average real EPS). This equals Price / (10 × smoothed real earnings), mirroring the RG earnings term.'],
            ['What is included',      'Price relative to long-run inflation-adjusted earnings (CAPE numerics). Captures earnings smoothing and cyclicality.'],
            ['What is NOT included',  'Tangible equity is absent. The firm-level RG uses MC / (TE + N·G); at the macro level, aggregate tangible equity is not reliably available. This makes the macro measure systematically higher than a full-RG construction would be.'],
            ['Series standard',       `All values — current reading and historical chart — use the same <strong>monthly</strong> series. No annual downsampling. ${data.series.length} monthly observations (1881-01 – ${cur.date}).`],
            ['Current value',         `Latest monthly observation: ${cur.date}, CAPE = ${cur.cape.toFixed(2)}, M(S&P500)RG10 = ${rg10.toFixed(3)}. Trend (${trend}) = 12-month % change in CAPE.`],
            ['Long-run average',      `Long-run CAPE mean ≈ ${(avgRg10 * 10).toFixed(1)} (1881–${cur.date.slice(0,4)}), implying an M(S&P500)RG10 long-run mean of ≈ ${avgRg10.toFixed(2)}. The "normal" zone is around 1.7, not 1.0.`],
            ['Primary data source',   `Robert Shiller, Yale University — ie_data.xls. Coverage: 1881-01 – ${data.yale_cutoff}. CAPE series requires 10 years of prior earnings; raw price series starts 1871.`],
            ['Supplement source',     hasMultpl
              ? `multpl.com Shiller PE table — used for months after the Yale cutoff (${data.yale_cutoff}). multpl.com tracks the same Shiller CAPE series. Supplement covers ${data.yale_cutoff} – ${cur.date}.`
              : 'No supplement applied — Yale data covers full range.'],
            ['Trend computation',     '12-month % change in CAPE (monthly). ++ &gt;+20% · + &gt;+5% · = ±5% · − &gt;−5% · −− &gt;−20%.'],
            ['Interpretation',        'The bands are heuristic reference points, not thresholds for buy/sell decisions. High CAPE can persist for years. Low CAPE does not guarantee near-term outperformance.'],
          ].map(([dim, detail]) => (
            <tr>
              <td class="text-sm font-medium text-gray-700 whitespace-nowrap align-top">{dim}</td>
              <td class="text-sm text-gray-600" set:html={detail} />
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Footer -->
  <p class="text-xs text-gray-400 border-t border-gray-100 pt-6">
    Primary data: Robert Shiller, Yale University — <em>Irrational Exuberance</em> dataset, Yale (1881-01 – {data.yale_cutoff}).
    {hasMultpl && `Supplemented with multpl.com for months after ${data.yale_cutoff}.`}
    Last fetched: {data.fetched}. Series standard: monthly throughout (current value and chart use the same series).
    This page presents a macro approximation for research purposes only.
    It is not the full Reality Gap indicator and must not be used as investment advice.
    M(S&amp;P 500)RG10 = CAPE / 10. Tangible equity is not included in this macro construction.
  </p>

</div>

<!-- ── Chart.js initialisation ────────────────────────────────────────────── -->
<script>
  function initMacroChart(): void {
    const canvas = document.getElementById('macro-cape-chart') as HTMLCanvasElement | null;
    if (!canvas) return;
    if ((canvas as any).__macroChartInit) return;
    (canvas as any).__macroChartInit = true;

    // @ts-ignore
    const Chart = (window as any).Chart;
    if (!Chart) return;

    const raw = canvas.getAttribute('data-chart');
    if (!raw) return;
    const avg  = parseFloat(canvas.getAttribute('data-avg') ?? '0');

    const { labels, rg10, avg: avgLine } = JSON.parse(raw) as {
      labels: string[];
      rg10: number[];
      avg: number[];
    };

    // Reference line at 1.0
    const refLine = labels.map(() => 1.0);

    new Chart(canvas, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'M(S&P500)RG10',
            data: rg10,
            borderColor: '#1e4d78',
            backgroundColor: 'rgba(30,77,120,0.05)',
            fill: true,
            borderWidth: 2,
            pointRadius: 0,
            pointHoverRadius: 4,
            tension: 0.2,
            spanGaps: false,
            order: 1,
          },
          {
            label: `Long-run avg (${avg.toFixed(2)}×)`,
            data: avgLine,
            borderColor: '#9ca3af',
            backgroundColor: 'transparent',
            borderWidth: 1.5,
            borderDash: [5, 4],
            pointRadius: 0,
            tension: 0,
            spanGaps: true,
            order: 2,
          },
          {
            label: 'RG10 = 1.0',
            data: refLine,
            borderColor: '#ef4444',
            backgroundColor: 'transparent',
            borderWidth: 1,
            borderDash: [2, 3],
            pointRadius: 0,
            tension: 0,
            spanGaps: true,
            order: 3,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx: any): string => {
                const v = ctx.parsed.y;
                if (v === null || v === undefined) return `${ctx.dataset.label}: —`;
                return `${ctx.dataset.label}: ${Number(v).toFixed(2)}×`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: {
              color: '#9ca3af',
              font: { size: 10 },
              maxRotation: 0,
              autoSkip: true,
              maxTicksLimit: 15,
            },
            border: { color: '#e5e7eb' },
          },
          y: {
            beginAtZero: true,
            min: 0,
            grid: { color: '#f3f4f6' },
            ticks: {
              color: '#9ca3af',
              font: { size: 10 },
              callback: (v: any): string => `${Number(v).toFixed(1)}×`,
            },
            border: { color: '#e5e7eb' },
          },
        },
      },
    });
  }

  function loadChartJs(cb: () => void): void {
    // @ts-ignore
    if ((window as any).Chart) { cb(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    s.onload = cb;
    s.onerror = (): void => console.warn('MacroChart: failed to load Chart.js');
    document.head.appendChild(s);
  }

  loadChartJs(initMacroChart);
</script>

</BaseLayout>
