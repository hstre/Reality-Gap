---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import sp500Raw from '../../data/macro/sp500_cape.json';
import daxRaw   from '../../data/macro/dax40_pe.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ── Types ────────────────────────────────────────────────────────────────────
interface SeriesPoint { date: string; trailing_pe: number; rg10: number; }
interface DaxData {
  source: string; method: string; method_note: string; cape_note: string;
  fetched: string; series_source?: string;
  current: {
    date: string; trailing_pe: number; rg10: number;
    dax_price: number | null; ytd_52w_pct: number | null;
    sources_used: string[];
  };
  series?: SeriesPoint[];
}
interface Sp500Current { date: string; cape: number; rg10: number; trend: string; }

const data   = daxRaw   as unknown as DaxData;
const sp500  = (sp500Raw as any).current as Sp500Current;

const cur    = data.current;
const rg10   = cur.rg10;

// ── Historical series (from stooq if available) ───────────────────────────────
const hasSeries  = Array.isArray(data.series) && data.series.length > 12;
const seriesAvg  = hasSeries
  ? data.series!.reduce((s, p) => s + p.rg10, 0) / data.series!.length
  : null;
const chartData  = hasSeries
  ? JSON.stringify({
      labels: data.series!.map(p => p.date),
      rg10:   data.series!.map(p => p.rg10),
      avg:    data.series!.map(() => parseFloat((seriesAvg!).toFixed(3))),
    })
  : null;

// ── Interpretation band ───────────────────────────────────────────────────────
function bandFor(v: number): { label: string; color: string; bg: string; border: string; } {
  if (v < 1.0) return { label: 'Below long-run average — historically infrequent',
                         color: 'text-emerald-700', bg: 'bg-emerald-50', border: 'border-emerald-200' };
  if (v < 1.8) return { label: 'Around long-run average — normal zone',
                         color: 'text-blue-700',    bg: 'bg-blue-50',    border: 'border-blue-200' };
  if (v < 2.5) return { label: 'Above average — caution zone',
                         color: 'text-amber-700',   bg: 'bg-amber-50',   border: 'border-amber-200' };
  if (v < 3.5) return { label: 'Significantly stretched — elevated risk',
                         color: 'text-orange-700',  bg: 'bg-orange-50',  border: 'border-orange-200' };
  return              { label: 'Historically very hot — rare territory',
                         color: 'text-red-700',     bg: 'bg-red-50',     border: 'border-red-200' };
}
const band = bandFor(rg10);

// ── Bands table ───────────────────────────────────────────────────────────────
const bands = [
  { lo: 0,   hi: 1.0, rg: '< 1.0',   pe: '< 10',  label: 'Below average — historically infrequent',    color: 'bg-emerald-50 text-emerald-700 border-emerald-200' },
  { lo: 1.0, hi: 1.8, rg: '1.0–1.8', pe: '10–18', label: 'Around long-run average — normal zone',      color: 'bg-blue-50 text-blue-700 border-blue-200'           },
  { lo: 1.8, hi: 2.5, rg: '1.8–2.5', pe: '18–25', label: 'Somewhat above average — caution',           color: 'bg-amber-50 text-amber-700 border-amber-200'         },
  { lo: 2.5, hi: 3.5, rg: '2.5–3.5', pe: '25–35', label: 'Significantly stretched — elevated risk',    color: 'bg-orange-50 text-orange-700 border-orange-200'      },
  { lo: 3.5, hi: 999, rg: '≥ 3.5',   pe: '≥ 35',  label: 'Historically very hot — rare territory',     color: 'bg-red-50 text-red-700 border-red-200'               },
];
const currentBandIdx = bands.findIndex(b => rg10 >= b.lo && rg10 < b.hi);

function fmt2(v: number): string { return v.toFixed(2); }
---

<BaseLayout
  title="Macro RG DAX 40 — Reality Gap"
  description="M(DAX40)RG10: macro-level Reality Gap approximation for the DAX 40 using trailing P/E data."
  lang="en"
  canonicalPath="/macro/dax40"
  altLangPath="/de/makro/dax40"
  altLang="de"
>
<div class="max-w-5xl mx-auto px-6 py-12">

  <!-- ── Breadcrumb / subnav ─────────────────────────────────────────────── -->
  <div class="mb-2 flex items-center gap-2 text-sm text-gray-400">
    <a href={`${base}/`} class="hover:text-accent no-underline">Home</a>
    <span>›</span>
    <a href={`${base}/macro`} class="hover:text-accent no-underline">Macro RG</a>
    <span>›</span>
    <span class="text-gray-600 font-medium">DAX 40</span>
  </div>

  <!-- ── Index switcher ──────────────────────────────────────────────────── -->
  <div class="flex items-center gap-2 mb-6 flex-wrap">
    <a href={`${base}/macro`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      S&amp;P 500
    </a>
    <span class="text-xs border border-accent bg-accent/5 text-accent rounded px-3 py-1 font-medium">
      DAX 40 ←
    </span>
    <a href={`${base}/macro/global`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      Global Buffett Indicator
    </a>
    <a href={`${base}/macro/correlation`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      Correlation
    </a>
  </div>

  <!-- ── Header ──────────────────────────────────────────────────────────── -->
  <h1 class="text-3xl font-normal text-gray-900 mb-2" style="font-family: Georgia, serif;">
    Macro RG — DAX 40
  </h1>
  <p class="text-gray-600 mb-1">
    Market-level Reality Gap approximation for the German DAX 40 index.
  </p>
  <div class="flex flex-wrap gap-2 mb-8">
    <span class="text-xs bg-blue-50 text-blue-700 border border-blue-200 rounded px-2 py-0.5">Macro approximation — not full RG</span>
    <span class="text-xs bg-amber-50 text-amber-700 border border-amber-200 rounded px-2 py-0.5">Trailing P/E — not CAPE</span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">Data through {cur.date} · fetched {data.fetched}</span>
    <span class="text-xs bg-amber-50 text-amber-700 border border-amber-200 rounded px-2 py-0.5">Tangible equity not included</span>
  </div>

  <!-- ── Section 1: Current Reading ─────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      1. Current Reading
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <!-- Main metric -->
      <div class={`border rounded-md p-5 ${band.bg} ${band.border}`}>
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">M(DAX 40)RG10</div>
        <div class={`text-4xl font-mono font-semibold mb-1 ${band.color}`}>{rg10.toFixed(2)}</div>
        <div class="text-xs text-gray-500">as of {cur.date}</div>
        <div class={`text-xs mt-2 font-medium ${band.color}`}>{band.label}</div>
      </div>

      <!-- Trailing P/E -->
      <div class="border border-gray-200 rounded-md p-5 bg-gray-50">
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">Trailing P/E</div>
        <div class="text-3xl font-mono font-semibold text-gray-800 mb-1">{cur.trailing_pe.toFixed(1)}</div>
        <div class="text-xs text-gray-500">12-month trailing price-to-earnings</div>
        <div class="text-xs text-gray-400 mt-2">Cross-checked: {cur.sources_used.join(' · ')}</div>
      </div>

      <!-- Formula card -->
      <div class="border border-gray-200 rounded-md p-5 bg-white">
        <div class="text-xs text-gray-500 mb-2 font-medium tracking-wide uppercase">Construction</div>
        <div class="font-mono text-sm text-gray-800 mb-3">M(DAX 40)RG10 = P/E<sub>trailing</sub> / 10</div>
        <p class="text-xs text-gray-500">
          Trailing P/E is used instead of Shiller CAPE because no free automated
          source for historical DAX CAPE data is available.
          The formula mirrors M(S&amp;P 500)RG10 = CAPE / 10, but the denominator
          uses 12-month earnings rather than 10-year smoothed earnings.
        </p>
      </div>
    </div>

    <!-- DAX price context -->
    {cur.dax_price && (
      <div class="text-sm text-gray-600 border-l-2 border-gray-200 pl-4">
        DAX 40 level: <span class="font-mono text-gray-800">{cur.dax_price.toLocaleString('de-DE')}</span>
        {cur.ytd_52w_pct !== null && (
          <span class="ml-2 text-gray-500">
            · 52-week change: <span class={cur.ytd_52w_pct >= 0 ? 'text-teal-600' : 'text-red-600'}>
              {cur.ytd_52w_pct >= 0 ? '+' : ''}{cur.ytd_52w_pct.toFixed(1)}%
            </span>
          </span>
        )}
      </div>
    )}
  </section>

  <!-- ── Section 2: Comparison with S&P 500 ─────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      2. Cross-Index Comparison
    </h2>
    <p class="text-sm text-gray-500 mb-4">
      Side-by-side macro RG snapshot. Note: the two indices use different
      earnings denominators (CAPE vs. trailing P/E) — direct comparison
      should be interpreted with caution.
    </p>

    <div class="grid grid-cols-2 gap-4 mb-4">
      {[
        {
          label: 'M(S&P 500)RG10',
          value: sp500.rg10.toFixed(2) + sp500.trend,
          sub: `CAPE = ${sp500.cape.toFixed(1)} · ${sp500.date}`,
          method: 'Shiller CAPE / 10 (10-year real earnings)',
          ...bandFor(sp500.rg10),
        },
        {
          label: 'M(DAX 40)RG10',
          value: rg10.toFixed(2),
          sub: `Trailing P/E = ${cur.trailing_pe.toFixed(1)} · ${cur.date}`,
          method: 'Trailing P/E / 10 (12-month earnings)',
          ...bandFor(rg10),
        },
      ].map(c => (
        <div class={`border rounded-md p-5 ${c.bg} ${c.border}`}>
          <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">{c.label}</div>
          <div class={`text-3xl font-mono font-semibold mb-1 ${c.color}`}>{c.value}</div>
          <div class="text-xs text-gray-500">{c.sub}</div>
          <div class="text-xs text-gray-400 mt-2 italic">{c.method}</div>
        </div>
      ))}
    </div>

    <div class="text-xs text-gray-400 border border-gray-100 rounded-md bg-gray-50/50 px-4 py-3">
      The DAX 40 trades at a lower M(RG10) than the S&amp;P 500 ({rg10.toFixed(2)} vs. {sp500.rg10.toFixed(2)}), consistent
      with the DAX's historically lower valuation due to its heavy industrial and automotive
      weighting. However, part of the gap reflects the different earnings denominators:
      CAPE typically exceeds trailing P/E in an earnings-recovery environment.
    </div>
  </section>

  <!-- ── Section 3: Interpretation Bands ────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      3. Heuristic Interpretation Bands
    </h2>
    <p class="text-sm text-gray-500 mb-5">
      Same scale as the S&P 500 macro page. Indicative reference only —
      not signals or thresholds.
    </p>

    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">M(DAX 40)RG10</th>
            <th class="text-left text-xs text-gray-500 font-medium">Trailing P/E equiv.</th>
            <th class="text-left text-xs text-gray-500 font-medium">Heuristic label</th>
          </tr>
        </thead>
        <tbody>
          {bands.map((row, i) => (
            <tr class={i === currentBandIdx ? 'bg-blue-50/40' : ''}>
              <td class="font-mono font-semibold text-sm text-gray-800 whitespace-nowrap">
                {row.rg}
                {i === currentBandIdx && (
                  <span class={`ml-2 text-xs rounded px-1.5 py-0.5 border font-normal ${row.color}`}>← current</span>
                )}
              </td>
              <td class="font-mono text-sm text-gray-600 whitespace-nowrap">{row.pe}</td>
              <td><span class={`text-xs rounded px-2 py-0.5 border font-medium ${row.color}`}>{row.label}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Section 4: Historical Chart (if available) ────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      4. Historical Series
    </h2>

    {hasSeries ? (
      <>
        <p class="text-sm text-gray-500 mb-1">
          Monthly trailing P/E series for the DAX. Same standard as the current reading above.
          {seriesAvg !== null && (
            <> Dashed line = series average ({seriesAvg.toFixed(2)}×).</>
          )}
        </p>
        <p class="text-xs text-gray-400 mb-4">
          Source: {data.series_source} · {data.series!.length} observations ·
          {data.series![0].date} – {data.series![data.series!.length - 1].date}
        </p>
        <div class="flex flex-wrap gap-5 mb-3 text-xs text-gray-500 select-none">
          <span class="flex items-center gap-1.5">
            <svg width="24" height="10" aria-hidden="true">
              <line x1="0" y1="5" x2="24" y2="5" stroke="#b45309" stroke-width="2.5"/>
            </svg>
            M(DAX 40)RG10
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="24" height="10" aria-hidden="true">
              <line x1="0" y1="5" x2="24" y2="5" stroke="#9ca3af" stroke-width="1.5" stroke-dasharray="4 3"/>
            </svg>
            Series average ({seriesAvg?.toFixed(2)}×)
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="24" height="10" aria-hidden="true">
              <line x1="0" y1="5" x2="24" y2="5" stroke="#ef4444" stroke-width="1" stroke-dasharray="2 2"/>
            </svg>
            RG10 = 1.0 reference
          </span>
        </div>
        <div class="relative" style="height: 260px;">
          <canvas
            id="dax-history-chart"
            data-chart={chartData}
            data-avg={seriesAvg?.toFixed(3) ?? '0'}
            aria-label="M(DAX40)RG10 historical series"
            role="img"
            style="width: 100%; height: 100%;"
          ></canvas>
        </div>
        <p class="text-xs text-gray-400 mt-2">
          Note: trailing P/E is more volatile than CAPE. The 2020 spike reflects the pandemic
          earnings collapse, not a genuine valuation extreme. DAX 30→40 composition break: September 2021.
        </p>
      </>
    ) : (
      <>
        <p class="text-sm text-gray-500 mb-4">
          For the S&P 500, the Shiller CAPE data (Yale University) provides a monthly series
          back to 1881. No equivalent free automated source could be verified for the DAX 40.
        </p>
        <div class="border border-dashed border-gray-300 rounded-md bg-gray-50/60 px-6 py-8">
          <p class="text-sm font-semibold text-gray-600 mb-2">Historical series not yet available</p>
          <p class="text-sm text-gray-500 mb-4">
            All checked free data sources for historical DAX P/E or CAPE returned errors or access blocks:
          </p>
          <div class="grid grid-cols-2 gap-x-8 gap-y-1 text-xs text-gray-400 mb-4">
            {[
              ['multpl.com/dax-pe', '404 — page does not exist'],
              ['Deutsche Bundesbank API', '503 — service unavailable'],
              ['OECD MEI_FIN (Germany)', 'No P/E series in dataset'],
              ['macrotrends.net', '403 — access blocked'],
              ['stooq.com', 'Attempted daily — blocked from cloud IPs'],
              ['StarCapital archive', '403 — access blocked'],
              ['JST macrohistory', '404 — page not found'],
              ['Quandl / Nasdaq Data Link', '403 — access blocked'],
            ].map(([src, status]) => (
              <div class="flex gap-2">
                <span class="shrink-0 text-gray-300">✗</span>
                <span><span class="font-medium text-gray-500">{src}:</span> {status}</span>
              </div>
            ))}
          </div>
          <p class="text-xs text-gray-400">
            <span class="font-medium text-gray-500">Note for researchers:</span> Siblis Research
            (siblisresearch.com) publishes historical CAPE data for Germany / DAX going back 40+ years
            ($48/month). That is the recommended source for a proper M(DAX)RG10 historical series.
          </p>
        </div>
      </>
    )}
  </section>

  <!-- ── Section 5: Methodology ─────────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      5. Methodology Notes
    </h2>

    <div class="space-y-4">
      <div class="border-l-2 border-gray-200 pl-4">
        <p class="text-sm font-semibold text-gray-700 mb-1">Trailing P/E vs. CAPE</p>
        <p class="text-sm text-gray-500">{data.method_note}</p>
      </div>

      <div class="border-l-2 border-gray-200 pl-4">
        <p class="text-sm font-semibold text-gray-700 mb-1">Data source</p>
        <p class="text-sm text-gray-500">
          Trailing P/E fetched via yfinance from two DAX ETFs: iShares Core DAX UCITS ETF (EXS1.DE)
          and Xtrackers DAX UCITS ETF (DBXD.DE). Both replicate the full DAX 40 total-return index.
          Values are cross-checked; the average is used when both are available.
        </p>
      </div>

      <div class="border-l-2 border-gray-200 pl-4">
        <p class="text-sm font-semibold text-gray-700 mb-1">DAX vs. S&P 500 structural differences</p>
        <p class="text-sm text-gray-500">
          The DAX 40 is a total-return index (dividends reinvested) while the S&P 500 price
          index is price-only. The DAX is heavily weighted toward industrials, automotive,
          chemicals, and financials — sectors with historically lower P/E multiples than the
          technology-heavy S&P 500. A lower M(DAX40)RG10 than M(S&P500)RG10 is structurally
          expected, independent of valuation levels.
        </p>
      </div>

      <div class="border-l-2 border-gray-200 pl-4">
        <p class="text-sm font-semibold text-gray-700 mb-1">DAX 30 → DAX 40 composition break (September 2021)</p>
        <p class="text-sm text-gray-500">
          In September 2021, Deutsche Börse expanded the flagship German index from 30 to 40
          constituents, adding 10 new companies primarily from mid-cap industries. Any future
          historical series covering pre- and post-2021 data should mark this structural break:
          the DAX 40 P/E and earnings profile is not directly comparable to the DAX 30 series
          prior to September 2021. Current ETF data (EXS1.DE, DBXD.DE) reflects the DAX 40
          composition.
        </p>
      </div>

      <div class="border-l-2 border-gray-200 pl-4">
        <p class="text-sm font-semibold text-gray-700 mb-1">What this does not include</p>
        <p class="text-sm text-gray-500">
          Like the S&P 500 macro approximation, the DAX construction omits tangible equity.
          The full RG formula is MC / (TE + N·G); the macro version uses only the earnings term.
          No trend code is shown for DAX40 because no historical series is available for
          comparison with prior periods.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Footer note ─────────────────────────────────────────────────────── -->
  <div class="border-t border-gray-100 pt-6 text-xs text-gray-400 space-y-1">
    <p>Source: {data.source}</p>
    <p>Fetched: {data.fetched}. Trailing P/E data reflects the most recent ETF factsheet values from Yahoo Finance.</p>
    <p>All data illustrative. Not investment advice.</p>
  </div>

</div>

{hasSeries && (
<script>
  function initDaxChart(): void {
    const canvas = document.getElementById('dax-history-chart') as HTMLCanvasElement | null;
    if (!canvas) return;
    if ((canvas as any).__daxChartInit) return;
    (canvas as any).__daxChartInit = true;

    const Chart = (window as any).Chart;
    if (!Chart) return;

    const raw = canvas.getAttribute('data-chart');
    const avgVal = parseFloat(canvas.getAttribute('data-avg') ?? '0');
    if (!raw) return;

    const { labels, rg10, avg } = JSON.parse(raw) as {
      labels: string[]; rg10: number[]; avg: number[];
    };
    const refLine = labels.map(() => 1.0);

    new Chart(canvas, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'M(DAX40)RG10',
            data: rg10,
            borderColor: '#b45309',
            backgroundColor: 'rgba(180,83,9,0.05)',
            fill: true,
            borderWidth: 2,
            pointRadius: 0,
            pointHoverRadius: 4,
            tension: 0.2,
            spanGaps: false,
          },
          {
            label: `Series avg (${avgVal.toFixed(2)}×)`,
            data: avg,
            borderColor: '#9ca3af',
            backgroundColor: 'transparent',
            borderWidth: 1.5,
            borderDash: [5, 4],
            pointRadius: 0,
            tension: 0,
            spanGaps: true,
          },
          {
            label: 'RG10 = 1.0',
            data: refLine,
            borderColor: '#ef4444',
            backgroundColor: 'transparent',
            borderWidth: 1,
            borderDash: [2, 3],
            pointRadius: 0,
            tension: 0,
            spanGaps: true,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx: any): string => {
                const v = ctx.parsed.y;
                if (v === null || v === undefined) return '';
                return `${ctx.dataset.label}: ${Number(v).toFixed(2)}×`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: '#9ca3af', font: { size: 10 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 12 },
            border: { color: '#e5e7eb' },
          },
          y: {
            beginAtZero: true,
            min: 0,
            grid: { color: '#f3f4f6' },
            ticks: { color: '#9ca3af', font: { size: 10 }, callback: (v: any): string => `${Number(v).toFixed(1)}×` },
            border: { color: '#e5e7eb' },
          },
        },
      },
    });
  }

  function loadChartJs(cb: () => void): void {
    if ((window as any).Chart) { cb(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    s.onload = cb;
    s.onerror = (): void => console.warn('DaxChart: failed to load Chart.js');
    document.head.appendChild(s);
  }

  loadChartJs(initDaxChart);
</script>
)}

</BaseLayout>
