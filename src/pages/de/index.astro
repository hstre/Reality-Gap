---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { de } from '../../i18n/de';
import sp500Raw from '../../data/macro/sp500_cape.json';
import daxRaw   from '../../data/macro/dax40_pe.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const t = de;

const sp500 = (sp500Raw as any).current as { date: string; cape: number; rg10: number; trend: string };
const dax   = (daxRaw as any).current  as { date: string; trailing_pe: number; rg10: number };

function snapshotBand(v: number): string {
  if (v < 1.0) return 'text-emerald-700';
  if (v < 1.8) return 'text-blue-700';
  if (v < 2.5) return 'text-amber-700';
  if (v < 3.5) return 'text-orange-700';
  return 'text-red-700';
}
---

<BaseLayout
  title={t.home.meta.title}
  description={t.home.meta.description}
  lang="de"
  canonicalPath="/de/"
  altLangPath="/"
  altLang="en"
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-10">
    <div class="max-w-2xl">
      <h1 class="text-4xl font-normal text-gray-900 mb-3" style="font-family: Georgia, serif;">
        {t.home.hero.title}
      </h1>
      <p class="text-lg text-gray-500 mb-6 font-light">{t.home.hero.subtitle}</p>
      <p class="text-base text-gray-700 leading-relaxed mb-8">
        {t.home.hero.description}
      </p>
      <p class="text-xs text-gray-400 border-l-2 border-gray-200 pl-3">
        {t.home.hero.note}
      </p>
    </div>
  </section>

  <!-- Makro-Schnappschuss -->
  <section class="max-w-5xl mx-auto px-6 pb-10">
    <div class="flex flex-wrap gap-3 items-stretch">
      <a href={`${base}/de/makro`}
         class="flex-1 min-w-[180px] border border-gray-200 rounded-md px-5 py-4 bg-white hover:border-gray-300 hover:shadow-sm transition-all no-underline group">
        <div class="text-xs text-gray-400 mb-1 font-medium tracking-wide uppercase">M(S&amp;P 500)RG10</div>
        <div class={`text-2xl font-mono font-semibold ${snapshotBand(sp500.rg10)}`}>
          {sp500.rg10.toFixed(2)}<span class="text-base ml-0.5">{sp500.trend}</span>
        </div>
        <div class="text-xs text-gray-400 mt-1">CAPE {sp500.cape.toFixed(1)} · {sp500.date}</div>
      </a>

      <a href={`${base}/de/makro/dax40`}
         class="flex-1 min-w-[180px] border border-gray-200 rounded-md px-5 py-4 bg-white hover:border-gray-300 hover:shadow-sm transition-all no-underline group">
        <div class="text-xs text-gray-400 mb-1 font-medium tracking-wide uppercase">M(DAX 40)RG10</div>
        <div class={`text-2xl font-mono font-semibold ${snapshotBand(dax.rg10)}`}>
          {dax.rg10.toFixed(2)}
        </div>
        <div class="text-xs text-gray-400 mt-1">Trailing-KGV {dax.trailing_pe.toFixed(1).replace('.', ',')} · {dax.date}</div>
      </a>

      <div class="flex-1 min-w-[180px] border border-gray-100 rounded-md px-5 py-4 bg-gray-50/60">
        <div class="text-xs text-gray-400 mb-1 font-medium tracking-wide uppercase">Makronäherung</div>
        <div class="text-xs text-gray-500 leading-relaxed mt-2">
          M(Index)RG10 = CAPE ÷ 10 (S&amp;P) bzw. Trailing-KGV ÷ 10 (DAX).
          Werte über 2,0 zeigen überdurchschnittliche Streckung; über 3,5 ist historisch selten.
        </div>
      </div>
    </div>
  </section>

  <!-- Karten -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { href: `${base}/de/methodik`,    card: t.home.cards.methodology },
        { href: `${base}/de/paper`,       card: t.home.cards.paper },
        { href: `${base}/de/rankings`,    card: t.home.cards.rankings },
        { href: `${base}/de/unternehmen`, card: t.home.cards.companies },
        { href: `${base}/de/forschung`,   card: t.home.cards.research },
        { href: `${base}/de/makro`,       card: t.home.cards.macro },
      ].map(({ href, card }) => (
        <a href={href} class="border border-gray-200 rounded-md p-5 bg-white hover:border-gray-300 hover:shadow-sm transition-all no-underline group block">
          <h2 class="text-sm font-semibold text-gray-800 group-hover:text-accent transition-colors mb-2">
            {card.title}
          </h2>
          <p class="text-xs text-gray-500 leading-relaxed">{card.description}</p>
          <p class="text-xs text-accent mt-4 opacity-0 group-hover:opacity-100 transition-opacity">{t.home.cta} →</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Datenzusammenarbeit -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="border border-gray-200 rounded-md px-8 py-8 bg-gray-50/40">
      <h2 class="text-base font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
        Den Gap öffnen: Ein Aufruf zur Datenzusammenarbeit
      </h2>
      <p class="text-xs text-gray-400 mb-6 border-b border-gray-100 pb-4">
        Das Reality-Gap-Framework wurde entwickelt, um die Distanz zwischen Marktbewertungen und
        konservativer fundamentaler Abdeckung sichtbarer und leichter diskutierbar zu machen. Während
        Märkte zunehmend langfristige Erwartungen, Dominanznarrative und strategische Optionalität
        einpreisen, sind die historischen Daten, die für die Untersuchung von Bewertungsstreckungen
        über Länder und Sektoren hinweg erforderlich sind, außerhalb institutioneller Umgebungen oft
        schwer zugänglich.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6 text-sm">
        <div>
          <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Warum das wichtig ist</h3>
          <p class="text-xs text-gray-500 leading-relaxed">
            Eine breitere empirische Anwendung des RG-Frameworks — über große Indizes, Sektoren und
            internationale Märkte hinweg — erfordert historische Finanzdaten, die häufig in proprietären
            Datenbanken konzentriert sind. Dies erzeugt eine praktische Asymmetrie: Große Institutionen
            können diese Fragen vergleichsweise einfach untersuchen, während unabhängige Forscher und die
            breite Öffentlichkeit erhebliche Hürden überwinden müssen.
          </p>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Was wir aufbauen möchten</h3>
          <p class="text-xs text-gray-500 leading-relaxed">
            Das langfristige Ziel ist eine öffentlich zugängliche Forschungsumgebung, in der Nutzer die
            konservative Abdeckung großer Aktienuniversen wie S&amp;P 500, DAX, Nikkei 225 und andere
            vergleichen können. Dies ist kein primär kommerzielles Projekt. Es ist ein Versuch,
            Bewertungsstreckung und Marktfragilität transparenter und diskutierbarer zu machen.
          </p>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Wie Sie helfen können</h3>
          <p class="text-xs text-gray-500 leading-relaxed mb-3">
            Wir bitten nicht um finanzielle Unterstützung, sondern um Datenzusammenarbeit im Rahmen rechtlicher und lizenzrechtlicher Grenzen. Besonders hilfreich wären:
          </p>
          <ul class="space-y-2 text-xs text-gray-500">
            <li class="flex gap-2">
              <span class="text-gray-300 shrink-0">—</span>
              <span><span class="font-medium text-gray-600">Aggregierte Makrodaten.</span> Bereits nützlich sind verifizierte Langfristreihen wie Zehnjahresdurchschnitte inflationsbereinigter Gewinne für große Indizes.</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gray-300 shrink-0">—</span>
              <span><span class="font-medium text-gray-600">CAPE-basierte Makronäherungen.</span> Historisch konsistente CAPE-ähnliche Reihen für Märkte außerhalb der USA wären von hohem Wert.</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gray-300 shrink-0">—</span>
              <span><span class="font-medium text-gray-600">Sektorale Aggregate.</span> Aggregierte Bewertungs- und Gewinnreihen für Sektoren oder Branchen könnten die RG-basierte Fragilitsanalyse erweitern.</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gray-300 shrink-0">—</span>
              <span><span class="font-medium text-gray-600">Methodische Hinweise.</span> Hinweise auf rechtlich nutzbare öffentliche oder institutionell teilbare aggregierte Datenquellen sind ebenfalls willkommen.</span>
            </li>
          </ul>
        </div>

        <div class="space-y-5">
          <div>
            <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">Wichtiger Hinweis</h3>
            <p class="text-xs text-gray-500 leading-relaxed">
              Bitte senden Sie keine Rohdaten oder Materialien, die gegen Lizenzbedingungen, Datenbankverträge
              oder institutionelle Zugriffsregeln verstoßen. Wir sind ausschließlich an Beiträgen interessiert,
              die rechtmäßig geteilt und genutzt werden können.
            </p>
          </div>
          <div class="border-l-2 border-gray-200 pl-4">
            <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2">An der Forschung mitwirken</h3>
            <p class="text-xs text-gray-500 leading-relaxed">
              Das übergeordnete Ziel ist es, Reality Gap zu einem transparenten Forschungsrahmen
              weiterzuentwickeln, der über die Zeit getestet, hinterfragt und verbessert werden kann.
              Wenn Sie über relevanten Datenzugang, methodische Expertise oder Ideen zur Erweiterung
              der empirischen Basis verfügen, sind Sie herzlich eingeladen, Kontakt aufzunehmen.
            </p>
            <p class="text-xs text-gray-400 mt-3 italic">
              Reality Gap ist kein Geschäftsmodell zuerst. Es ist ein Versuch, Bewertungsstreckung
              transparenter zu machen in einer Welt, in der Marktnarrative oft schneller reisen als
              fundamentale Abdeckung.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
