---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import capeRaw from '../../../data/macro/sp500_cape.json';
import daxRaw  from '../../../data/macro/dax40_pe.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dax = (daxRaw as any).current as { date: string; rg10: number; trailing_pe: number };

// ── Types ────────────────────────────────────────────────────────────────────
interface CapePoint { date: string; cape: number; rg10: number; }
interface CapeData {
  source: string; url: string; fetched: string; note: string;
  sources: string[];
  yale_cutoff: string;
  supplement_url: string | null;
  series_standard: string;
  long_run_avg_rg10: number;
  long_run_max_rg10: number;
  long_run_min_rg10: number;
  current: { date: string; cape: number; rg10: number; trend: string; };
  series: CapePoint[];
  peaks: Array<{ date: string; note: string; cape?: number; rg10?: number; }>;
}

const data = capeRaw as unknown as CapeData;

// ── Aktueller Wert — letzte monatliche Beobachtung ───────────────────────────
const cur     = data.current;
const rg10    = cur.rg10;
const trend   = cur.trend;
const display = `${rg10.toFixed(2)}${trend}`;

// ── Langfristiger Durchschnitt (aus JSON) ────────────────────────────────────
const avgRg10 = data.long_run_avg_rg10;
const maxRg10 = data.long_run_max_rg10;
const minRg10 = data.long_run_min_rg10;

// ── Interpretation ───────────────────────────────────────────────────────────
function bandFor(v: number): { label: string; color: string; bg: string; border: string; } {
  if (v < 1.0) return { label: 'Unter dem langfristigen Durchschnitt — historisch selten',
                         color: 'text-emerald-700', bg: 'bg-emerald-50', border: 'border-emerald-200' };
  if (v < 1.8) return { label: 'Um den langfristigen Durchschnitt (~1,7) — normale Zone',
                         color: 'text-blue-700',    bg: 'bg-blue-50',    border: 'border-blue-200' };
  if (v < 2.5) return { label: 'Über dem Durchschnitt — erhöhte Vorsicht',
                         color: 'text-amber-700',   bg: 'bg-amber-50',   border: 'border-amber-200' };
  if (v < 3.5) return { label: 'Deutlich gestreckt — historisch erhöht',
                         color: 'text-orange-700',  bg: 'bg-orange-50',  border: 'border-orange-200' };
  return              { label: 'Historisch sehr heiß — seltenes Terrain',
                         color: 'text-red-700',     bg: 'bg-red-50',     border: 'border-red-200' };
}
const band = bandFor(rg10);

// ── Bandtabelle ──────────────────────────────────────────────────────────────
const bands = [
  { lo: 0,   hi: 1.0, rg: '< 1.0',   cape: '< 10',  label: 'Unter langfr. Durchschnitt / historisch attraktiv', color: 'bg-emerald-50 text-emerald-700 border-emerald-200', ctx: 'Selten außerhalb großer Bärenmärkte. 1982, 2009 kurzzeitig.' },
  { lo: 1.0, hi: 1.8, rg: '1,0–1,8', cape: '10–18', label: 'Um den langfristigen Durchschnitt — normale Zone',  color: 'bg-blue-50 text-blue-700 border-blue-200',           ctx: 'Langfristiger CAPE-Mittelwert ~17. Typisch in Erholungsphasen.' },
  { lo: 1.8, hi: 2.5, rg: '1,8–2,5', cape: '18–25', label: 'Über dem Durchschnitt — Vorsicht',                  color: 'bg-amber-50 text-amber-700 border-amber-200',         ctx: 'Häufig in anhaltenden Bullenmärkten (1960er, 1990er, 2010er).' },
  { lo: 2.5, hi: 3.5, rg: '2,5–3,5', cape: '25–35', label: 'Deutlich gestreckt — erhöhtes Risiko',              color: 'bg-orange-50 text-orange-700 border-orange-200',      ctx: 'Vor der GFC 2007 (~2,7), post-COVID 2021 (~3,9).' },
  { lo: 3.5, hi: 999, rg: '≥ 3,5',   cape: '≥ 35',  label: 'Historisch sehr heiß — seltenes Terrain',           color: 'bg-red-50 text-red-700 border-red-200',               ctx: 'Dotcom-Gipfel 2000 (~4,4), Ende 2021 (~3,9), heute (~3,9).' },
];
const currentBandIdx = bands.findIndex(b => rg10 >= b.lo && rg10 < b.hi);

// ── Monatsserie für Chart — selber Standard wie aktueller Wert ───────────────
const chartLabels = data.series.map(p => p.date);
const chartRg10   = data.series.map(p => p.rg10);
const chartAvg    = data.series.map(() => parseFloat(avgRg10.toFixed(3)));
const chartGs10   = data.series.map((p: any) => p.gs10 ?? null);
const chartData   = JSON.stringify({ labels: chartLabels, rg10: chartRg10, avg: chartAvg, gs10: chartGs10 });

const hasMultpl = data.sources.includes('multpl_supplement');

function fmt2(v: number): string { return v.toFixed(2); }
---

<BaseLayout
  title="Makro-RG — Reality Gap"
  description="M(S&P500)RG10: Makro-Näherung des Reality Gap auf Basis des Shiller/CAPE-Datensatzes. Historische Zeitreihe 1881 bis heute."
  lang="de"
  canonicalPath="/de/makro"
  altLangPath="/macro"
  altLang="en"
>
<div class="max-w-5xl mx-auto px-6 py-12">

  <!-- ── Header ──────────────────────────────────────────────────────────── -->
  <div class="mb-2">
    <a href={`${base}/de/`} class="text-sm text-gray-400 hover:text-accent no-underline">← Startseite</a>
  </div>

  <!-- Index-Umschalter -->
  <div class="flex items-center gap-2 mb-4 flex-wrap">
    <span class="text-xs border border-accent bg-accent/5 text-accent rounded px-3 py-1 font-medium">
      S&amp;P 500 ←
    </span>
    <a href={`${base}/de/makro/dax40`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      DAX 40
    </a>
    <a href={`${base}/de/makro/global`}
       class="text-xs border border-gray-200 rounded px-3 py-1 text-gray-500 hover:text-accent hover:border-accent no-underline transition-colors">
      Globaler Buffett-Indikator
    </a>
  </div>

  <h1 class="text-3xl font-normal text-gray-900 mb-2" style="font-family: Georgia, serif;">
    Makro-RG — Marktweite Näherung
  </h1>
  <p class="text-gray-600 mb-1">
    Eine Makro-Erweiterung des Reality-Gap-Rahmens: Der RG-Blick richtet sich
    auf ganze Aktienuniversen statt auf einzelne Unternehmen.
  </p>
  <div class="flex flex-wrap gap-2 mb-8">
    <span class="text-xs bg-blue-50 text-blue-700 border border-blue-200 rounded px-2 py-0.5">Makro-Näherung — kein vollständiger RG</span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">Monatliche Reihe · {data.series.length} Beobachtungen</span>
    <span class="text-xs bg-gray-50 text-gray-500 border border-gray-200 rounded px-2 py-0.5">Daten bis {cur.date} · abgerufen {data.fetched}</span>
    <span class="text-xs bg-amber-50 text-amber-700 border border-amber-200 rounded px-2 py-0.5">Vollständige Eigenkapital-Korrektur in Vorbereitung (P/B-Daten ausstehend)</span>
  </div>

  <!-- ── Abschnitt 1: Aktueller Wert ────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      1. Aktueller Wert
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <!-- Hauptkennzahl -->
      <div class={`border rounded-md p-5 ${band.bg} ${band.border}`}>
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">M(S&amp;P 500)RG10</div>
        <div class={`text-4xl font-mono font-semibold mb-1 ${band.color}`}>{display}</div>
        <div class="text-xs text-gray-500">Stand: {cur.date}</div>
        <div class={`text-xs mt-2 font-medium ${band.color}`}>{band.label}</div>
      </div>

      <!-- CAPE-Rohwert -->
      <div class="border border-gray-200 rounded-md p-5 bg-gray-50">
        <div class="text-xs text-gray-500 mb-1 font-medium tracking-wide uppercase">Shiller CAPE</div>
        <div class="text-3xl font-mono font-semibold text-gray-800 mb-1">{cur.cape.toFixed(1)}</div>
        <div class="text-xs text-gray-500">Konjunkturbereinigtes KGV (10-Jahres-Realgewinne)</div>
        <div class="text-xs text-gray-400 mt-2">Langfristiger Mittelwert: ~{(avgRg10 * 10).toFixed(1)}</div>
      </div>

      <!-- Formel -->
      <div class="border border-gray-200 rounded-md p-5 bg-white">
        <div class="text-xs text-gray-500 mb-2 font-medium tracking-wide uppercase">Konstruktion</div>
        <div class="font-mono text-sm text-gray-800 mb-1">Aktuell: CAPE / 10</div>
        <div class="font-mono text-xs text-gray-500 mb-3">Vollständig (P/B ausstehend): 1 / (1/PB + 10/CAPE)</div>
        <p class="text-xs text-gray-500">
          Der vollständige Makro-RG lautet <span class="font-mono">MC / (Buchwert + 10·Gewinne)</span>.
          Da <span class="font-mono">Buchwert = MC/PB</span> und <span class="font-mono">Gewinne = MC/CAPE</span>,
          vereinfacht sich das zu <span class="font-mono">1/(1/PB + 10/CAPE)</span>.
          Die P/B-Datenquelle wird recherchiert; bis dahin bleibt CAPE/10 die veröffentlichte
          Näherung — sie liegt immer über der vollständigen Konstruktion.
        </p>
      </div>
    </div>

    <!-- Trendzeichen -->
    <div class="text-sm text-gray-600 border-l-2 border-gray-200 pl-4">
      Trendzeichen direkt an den Wert angehängt ({display}): Vergleich mit 12 Monaten zuvor.
      <span class="font-mono text-gray-700 ml-1">++ &gt;+20% · + &gt;+5% · = ±5% · - &gt;−5% · -- &gt;−20%</span>
    </div>
  </section>

  <!-- ── Abschnitt 2: Interpretationsbänder ─────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      2. Heuristische Interpretationsbänder
    </h2>
    <p class="text-sm text-gray-500 mb-5">
      Nur als Orientierungshilfe. Es handelt sich nicht um Kauf- oder Verkaufssignale —
      Märkte können über lange Zeiträume in jeder Zone verharren.
    </p>

    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">M(S&amp;P 500)RG10</th>
            <th class="text-left text-xs text-gray-500 font-medium">CAPE-Äquivalent</th>
            <th class="text-left text-xs text-gray-500 font-medium">Heuristische Bezeichnung</th>
            <th class="text-left text-xs text-gray-500 font-medium">Kontext</th>
          </tr>
        </thead>
        <tbody>
          {bands.map((row, i) => (
            <tr class={i === currentBandIdx ? 'bg-blue-50/40' : ''}>
              <td class="font-mono font-semibold text-sm text-gray-800 whitespace-nowrap">
                {row.rg}
                {i === currentBandIdx && (
                  <span class={`ml-2 text-xs rounded px-1.5 py-0.5 border font-normal ${row.color}`}>← aktuell</span>
                )}
              </td>
              <td class="font-mono text-sm text-gray-600 whitespace-nowrap">{row.cape}</td>
              <td><span class={`text-xs rounded px-2 py-0.5 border font-medium ${row.color}`}>{row.label}</span></td>
              <td class="text-xs text-gray-500">{row.ctx}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Abschnitt 3: Historischer Chart ────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      3. M(S&amp;P 500)RG10 — Monatliche Zeitreihe (1881–{cur.date})
    </h2>
    <p class="text-sm text-gray-500 mb-1">
      <strong>Monatliche Beobachtungen</strong> — selber Standard wie der aktuelle Wert oben.
      Gestrichelte Linie = langfristiger Durchschnitt ({fmt2(avgRg10)}×).
    </p>
    <p class="text-xs text-gray-400 mb-4">
      Primärquelle: Yale ie_data.xls (1881-01 – {data.yale_cutoff}).
      {hasMultpl && `Ergänzt mit multpl.com (${data.yale_cutoff} – ${cur.date}).`}
    </p>

    <!-- Legende -->
    <div class="flex flex-wrap gap-5 mb-3 text-xs text-gray-500 select-none">
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#1e4d78" stroke-width="2.5"/>
        </svg>
        M(S&amp;P 500)RG10
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#9ca3af" stroke-width="1.5" stroke-dasharray="4 3"/>
        </svg>
        Langfristiger Mittelwert ({fmt2(avgRg10)}×)
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#ef4444" stroke-width="1" stroke-dasharray="2 2"/>
        </svg>
        RG10 = 1,0 Referenz
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="24" height="10" aria-hidden="true">
          <line x1="0" y1="5" x2="24" y2="5" stroke="#10b981" stroke-width="1.5" stroke-dasharray="3 2"/>
        </svg>
        10-J. Treasury GS10 (rechte Achse)
      </span>
    </div>

    <div class="relative" style="height: 300px;">
      <canvas
        id="macro-cape-chart-de"
        data-chart={chartData}
        data-avg={fmt2(avgRg10)}
        aria-label="M(S&P500)RG10 historische Zeitreihe 1881 bis heute"
        role="img"
        style="width: 100%; height: 100%;"
      ></canvas>
    </div>
    <p class="text-xs text-gray-400 mt-2">
      Monatliche Werte · {data.series.length} Datenpunkte · Spanne {fmt2(minRg10)}× – {fmt2(maxRg10)}×.
      CAPE-Reihe beginnt 1881 (erfordert 10 Jahre Gewinnhistorie ab 1871).
    </p>
  </section>

  <!-- ── Abschnitt 4: Historische Höhepunkte ────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      4. Historische Höhepunkte
    </h2>
    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">Episode</th>
            <th class="text-left text-xs text-gray-500 font-medium">Datum</th>
            <th class="text-right text-xs text-gray-500 font-medium">CAPE</th>
            <th class="text-right text-xs text-gray-500 font-medium">M(S&amp;P 500)RG10</th>
            <th class="text-left text-xs text-gray-500 font-medium">Bewertung</th>
          </tr>
        </thead>
        <tbody>
          {data.peaks.filter(p => p.cape != null).map(p => (
            <tr>
              <td class="text-sm font-medium text-gray-800">{p.note}</td>
              <td class="font-mono text-sm text-gray-600">{p.date}</td>
              <td class="text-right font-mono text-sm text-gray-800">{p.cape!.toFixed(2)}</td>
              <td class="text-right font-mono text-sm font-semibold text-accent">{p.rg10!.toFixed(2)}</td>
              <td class="text-xs text-gray-500">
                {p.rg10! >= 3.5 ? 'Historisch sehr heiß' :
                 p.rg10! >= 2.5 ? 'Deutlich gestreckt' :
                 p.rg10! >= 1.8 ? 'Über Durchschnitt' : 'Moderat'}
              </td>
            </tr>
          ))}
          <!-- Aktuell -->
          <tr class="bg-blue-50/30">
            <td class="text-sm font-medium text-gray-800">Aktueller Wert</td>
            <td class="font-mono text-sm text-gray-600">{cur.date}</td>
            <td class="text-right font-mono text-sm text-gray-800">{cur.cape.toFixed(2)}</td>
            <td class="text-right font-mono text-sm font-semibold text-accent">{rg10.toFixed(2)}{trend}</td>
            <td class={`text-xs font-medium ${band.color}`}>{band.label.split('—')[0].trim()}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Abschnitt 5: Weitere Aktienuniversen ─────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-1" style="font-family: Georgia, serif;">
      5. Weitere Aktienuniversen
    </h2>
    <p class="text-sm text-gray-500 mb-5">
      Makro-RG stellt derzeit eine veröffentlichte historische Zeitreihe für den S&amp;P 500 bereit.
      Der DAX 40 ist als provisorische Markterweiterung auf Basis des Trailing-KGV eingebunden.
      Weitere Märkte werden ergänzt, sobald hinreichend robuste Langzeitdaten unabhängig
      verifiziert werden können.
    </p>
    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">Notation</th>
            <th class="text-left text-xs text-gray-500 font-medium">Universum</th>
            <th class="text-right text-xs text-gray-500 font-medium">Aktuell</th>
            <th class="text-left text-xs text-gray-500 font-medium">Datenquelle</th>
            <th class="text-left text-xs text-gray-500 font-medium">Status</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="font-mono text-sm text-gray-800 whitespace-nowrap">
              <a href={`${base}/de/makro`} class="text-accent hover:underline no-underline">M(S&amp;P 500)RG10</a>
            </td>
            <td class="text-sm text-gray-700">S&amp;P 500 (US Large-Cap)</td>
            <td class="text-right font-mono text-sm font-semibold text-accent">{rg10.toFixed(2)}×</td>
            <td class="text-xs text-gray-500">Shiller ie_data.xls / Yale · CAPE / 10</td>
            <td><span class="text-xs rounded px-2 py-0.5 font-medium border bg-emerald-50 text-emerald-700 border-emerald-200">live</span></td>
          </tr>
          <tr>
            <td class="font-mono text-sm text-gray-800 whitespace-nowrap">
              <a href={`${base}/de/makro/dax40`} class="text-accent hover:underline no-underline">M(DAX 40)RG10</a>
            </td>
            <td class="text-sm text-gray-700">DAX 40 (Deutsche Large-Caps)</td>
            <td class="text-right font-mono text-sm font-semibold text-accent">{dax.rg10.toFixed(2)}×</td>
            <td class="text-xs text-gray-500">yfinance ETF-Proxy · Trailing-KGV / 10 <span class="text-gray-400">(kein CAPE)</span></td>
            <td><span class="text-xs rounded px-2 py-0.5 font-medium border bg-emerald-50 text-emerald-700 border-emerald-200">live</span></td>
          </tr>
          {[
            { m: 'M(Nikkei 225)RG10', uni: 'Nikkei 225 (Japanische Large-Caps)', src: 'StarCapital / akademische Quellen' },
            { m: 'M(STOXX 600)RG10',  uni: 'STOXX Europe 600',                   src: 'MSCI / Barclays europäische CAPE-Daten' },
            { m: 'M(EM)RG10',         uni: 'MSCI Schwellenländer',               src: 'MSCI CAPE-Daten' },
          ].map(row => (
            <tr>
              <td class="font-mono text-sm text-gray-500 whitespace-nowrap" set:html={row.m} />
              <td class="text-sm text-gray-600">{row.uni}</td>
              <td class="text-right text-xs text-gray-300">—</td>
              <td class="text-xs text-gray-400">{row.src}</td>
              <td><span class="text-xs rounded px-2 py-0.5 font-medium border bg-gray-50 text-gray-400 border-gray-200">geplant</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Abschnitt 6: Methodik ──────────────────────────────────────────── -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold text-gray-800 mb-4" style="font-family: Georgia, serif;">
      6. Methodik und Einschränkungen
    </h2>
    <div class="overflow-x-auto">
      <table class="table-rg w-full">
        <thead>
          <tr class="bg-gray-50">
            <th class="text-left text-xs text-gray-500 font-medium">Dimension</th>
            <th class="text-left text-xs text-gray-500 font-medium">Detail</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['Bezeichnung',           'M(S&P 500)RG10 — M für Makro, (S&P 500) für das Universum, RG10 für den Kapitalisierungsfaktor N=10'],
            ['Formel',                'M(S&P 500)RG10 = CAPE / 10. CAPE = P / (10-Jahres-Realgewinn-Durchschnitt).'],
            ['Was enthalten ist',     'Preis relativ zu langfristigen inflationsbereinigten Gewinnen (CAPE). Erfasst Konjunkturbereinigung und Gewinnglättung.'],
            ['Was NICHT enthalten ist','Das materielle Eigenkapital fehlt. Der vollständige RG lautet MC / (TE + N·G). Daher liegt die Makronäherung systematisch über einem vollständigen RG-Wert.'],
            ['Reihenstandard',        `Alle Werte — aktueller Wert und Chart — verwenden dieselbe <strong>monatliche</strong> Reihe. Kein Jahres-Downsampling. ${data.series.length} monatliche Beobachtungen (1881-01 – ${cur.date}).`],
            ['Aktueller Wert',        `Letzte monatliche Beobachtung: ${cur.date}, CAPE = ${cur.cape.toFixed(2)}, M(S&P500)RG10 = ${rg10.toFixed(3)}. Trend (${trend}) = 12-Monats-Veränderung des CAPE.`],
            ['Langfristiger Mittelwert',`Langfristiger CAPE-Mittelwert ≈ ${(avgRg10 * 10).toFixed(1)} (1881–${cur.date.slice(0,4)}), M(S&P500)RG10-Mittelwert ≈ ${avgRg10.toFixed(2)}. Die „normale" Zone liegt bei ~1,7, nicht bei 1,0.`],
            ['Primärquelle',          `Robert Shiller, Yale University — ie_data.xls. Abdeckung: 1881-01 – ${data.yale_cutoff}.`],
            ['Ergänzungsquelle',      hasMultpl
              ? `multpl.com Shiller-PE-Tabelle — für Monate nach dem Yale-Cutoff (${data.yale_cutoff}). Abdeckung ${data.yale_cutoff} – ${cur.date}.`
              : 'Keine Ergänzung — Yale-Daten decken den gesamten Zeitraum ab.'],
            ['Trendberechnung',       '12-Monats-Veränderung in Prozent des CAPE-Werts (monatlich).'],
            ['Interpretation',        'Die Bänder sind heuristische Orientierungspunkte, keine Kauf-/Verkaufssignale. Hohe CAPE-Werte können jahrelang anhalten.'],
          ].map(([dim, detail]) => (
            <tr>
              <td class="text-sm font-medium text-gray-700 whitespace-nowrap align-top">{dim}</td>
              <td class="text-sm text-gray-600" set:html={detail} />
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Fußnote -->
  <p class="text-xs text-gray-400 border-t border-gray-100 pt-6">
    Primärdaten: Robert Shiller, Yale University — <em>Irrational Exuberance</em>-Datensatz (1881-01 – {data.yale_cutoff}).
    {hasMultpl && `Ergänzt mit multpl.com für Monate nach ${data.yale_cutoff}.`}
    Zuletzt abgerufen: {data.fetched}. Reihenstandard: durchgehend monatlich (aktueller Wert und Chart verwenden dieselbe Reihe).
    Diese Seite zeigt eine Makro-Näherung zu Forschungszwecken.
    Es handelt sich nicht um den vollständigen Reality-Gap-Indikator und nicht um Anlageberatung.
    M(S&amp;P 500)RG10 = CAPE / 10. Das materielle Eigenkapital ist in dieser Makrokonstruktion nicht enthalten.
  </p>

</div>

<!-- ── Chart.js ─────────────────────────────────────────────────────────────── -->
<script>
  function initMacroChartDE(): void {
    const canvas = document.getElementById('macro-cape-chart-de') as HTMLCanvasElement | null;
    if (!canvas) return;
    if ((canvas as any).__macroChartInit) return;
    (canvas as any).__macroChartInit = true;

    // @ts-ignore
    const Chart = (window as any).Chart;
    if (!Chart) return;

    const raw = canvas.getAttribute('data-chart');
    if (!raw) return;
    const avg = parseFloat(canvas.getAttribute('data-avg') ?? '0');

    const { labels, rg10, avg: avgLine, gs10 } = JSON.parse(raw) as {
      labels: string[];
      rg10: number[];
      avg: number[];
      gs10: (number | null)[];
    };

    const refLine = labels.map(() => 1.0);

    new Chart(canvas, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'M(S&P500)RG10',
            data: rg10,
            borderColor: '#1e4d78',
            backgroundColor: 'rgba(30,77,120,0.05)',
            fill: true,
            borderWidth: 2,
            pointRadius: 0,
            pointHoverRadius: 4,
            tension: 0.2,
            spanGaps: false,
            yAxisID: 'y',
            order: 1,
          },
          {
            label: `Langfr. Mittelwert (${avg.toFixed(2)}×)`,
            data: avgLine,
            borderColor: '#9ca3af',
            backgroundColor: 'transparent',
            borderWidth: 1.5,
            borderDash: [5, 4],
            pointRadius: 0,
            tension: 0,
            spanGaps: true,
            yAxisID: 'y',
            order: 2,
          },
          {
            label: 'RG10 = 1,0',
            data: refLine,
            borderColor: '#ef4444',
            backgroundColor: 'transparent',
            borderWidth: 1,
            borderDash: [2, 3],
            pointRadius: 0,
            tension: 0,
            spanGaps: true,
            yAxisID: 'y',
            order: 3,
          },
          {
            label: '10-J. Treasury (GS10)',
            data: gs10,
            borderColor: '#10b981',
            backgroundColor: 'transparent',
            borderWidth: 1.5,
            borderDash: [3, 2],
            pointRadius: 0,
            tension: 0.2,
            spanGaps: false,
            yAxisID: 'y2',
            order: 4,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx: any): string => {
                const v = ctx.parsed.y;
                if (v === null || v === undefined) return '';
                if (ctx.datasetIndex === 3) return `GS10: ${Number(v).toFixed(2)} %`;
                return `${ctx.dataset.label}: ${Number(v).toFixed(2)}×`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: '#9ca3af', font: { size: 10 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 15 },
            border: { color: '#e5e7eb' },
          },
          y: {
            beginAtZero: true, min: 0, position: 'left',
            grid: { color: '#f3f4f6' },
            ticks: { color: '#9ca3af', font: { size: 10 }, callback: (v: any): string => `${Number(v).toFixed(1)}×` },
            border: { color: '#e5e7eb' },
          },
          y2: {
            beginAtZero: true, min: 0, max: 20, position: 'right',
            grid: { display: false },
            ticks: { color: '#10b981', font: { size: 9 }, callback: (v: any): string => `${Number(v).toFixed(0)}%` },
            border: { color: '#d1fae5' },
          },
        },
      },
    });
  }

  function loadChartJs(cb: () => void): void {
    // @ts-ignore
    if ((window as any).Chart) { cb(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    s.onload = cb;
    s.onerror = (): void => console.warn('MacroChart: failed to load Chart.js');
    document.head.appendChild(s);
  }

  loadChartJs(initMacroChartDE);
</script>

</BaseLayout>
