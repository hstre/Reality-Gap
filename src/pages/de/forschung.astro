      <!-- ── SVG: Spreizung (Narrative RG − Core RG) ───────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-1">Fragility Spread — Zeitverlauf</h3>
      <p class="text-xs text-gray-400 mb-3">
        Narrative RG minus Core RG. Höherer Wert = größere strukturelle Spaltung des Markts.
      </p>
      <div class="border border-gray-100 rounded-md bg-white p-3 mb-8 overflow-x-auto">
        <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} class="w-full" style="min-width:400px; max-height:260px;">
          {/* Y-Raster + Beschriftung */}
          {Array.from({ length: Math.ceil(svgSpreadMaxY / 0.5) + 1 }, (_, i) => i * 0.5).map(y => (
            <>
              <line x1={SVG_PL} y1={SVG_PT + (1 - y / svgSpreadMaxY) * SVG_IH} x2={SVG_W - SVG_PR} y2={SVG_PT + (1 - y / svgSpreadMaxY) * SVG_IH} stroke="#f3f4f6" stroke-width="1" />
              {(y * 10) % 5 === 0 && (
                <text x={SVG_PL - 5} y={SVG_PT + (1 - y / svgSpreadMaxY) * SVG_IH + 3.5} text-anchor="end" font-size="10" fill="#9ca3af">{y.toFixed(1)}</text>
              )}
            </>
          ))}
          {/* Vertikale Führungslinien */}
          {openFragSeries.map((_, i) => (
            <line x1={svgX(i)} y1={SVG_PT} x2={svgX(i)} y2={SVG_PT + SVG_IH} stroke="#f9fafb" stroke-width="1" stroke-dasharray="3 2" />
          ))}
          {/* Fläche */}
          {svgSpreadFillPts && <polygon points={svgSpreadFillPts} fill="rgba(234,88,12,0.12)" />}
          {/* Basislinie */}
          <line x1={SVG_PL} y1={SVG_PT + SVG_IH} x2={SVG_W - SVG_PR} y2={SVG_PT + SVG_IH} stroke="#e5e7eb" stroke-width="1" />
          {/* Spreizungslinie */}
          {svgSpreadPts && <polyline points={svgSpreadPts} fill="none" stroke="rgb(234,88,12)" stroke-width="2.2" stroke-linejoin="round" />}
          {/* Punkte + Wertebeschriftungen */}
          {openFragSeries.map((r, i) => {
            const cy = SVG_PT + (1 - r.spread / svgSpreadMaxY) * SVG_IH;
            const isPeak = r.spread === Math.max(...openFragSeries.map(x => x.spread));
            return (
              <>
                <circle cx={svgX(i)} cy={cy} r="3.5" fill={isPeak ? 'rgb(185,28,28)' : 'rgb(234,88,12)'} />
                <text x={svgX(i)} y={cy - 7} text-anchor="middle" font-size="9" fill={isPeak ? 'rgb(185,28,28)' : 'rgb(194,65,12)'}
                  font-weight={isPeak ? 'bold' : 'normal'}>{r.spread.toFixed(2)}{isPeak ? ' ↑' : ''}</text>
              </>
            );
          })}
          {/* X-Beschriftungen + n */}
          {openFragSeries.map((r, i) => (
            <>
              <text x={svgX(i)} y={SVG_PT + SVG_IH + 16} text-anchor="middle" font-size="10" fill="#6b7280">{r.label}</text>
              <text x={svgX(i)} y={SVG_PT + SVG_IH + 28} text-anchor="middle" font-size="8.5" fill="#d1d5db">n={r.n}</text>
            </>
          ))}
          <text
            transform={`translate(11,${SVG_PT + SVG_IH / 2}) rotate(-90)`}
            text-anchor="middle" font-size="9.5" fill="#9ca3af">Spread</text>
        </svg>
      </div>

      <!-- ── SVG: Gini-Koeffizient der RG10-Verteilung ───────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-1">Gini-Koeffizient — Zeitverlauf</h3>
      <p class="text-xs text-gray-400 mb-3">
        Verteilungsungleichheit des RG10 über alle Unternehmen je Quartal (0 = vollständige Gleichverteilung, 1 = maximale Konzentration).
        Unabhängig von Quartilsgrenzen — erfasst die gesamte Verteilungsform.
        Peak: {giniPeak.label} ({giniPeak.g.toFixed(3)}) · Aktuell: {giniLatest.label} ({giniLatest.g.toFixed(3)}).
      </p>
      <div class="border border-gray-100 rounded-md bg-white p-3 mb-8 overflow-x-auto">
        <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} class="w-full" style="min-width:400px; max-height:260px;">
          {giniYTicks.map(y => (
            <>
              <line x1={SVG_PL} y1={gY(y)} x2={SVG_W - SVG_PR} y2={gY(y)} stroke="#f3f4f6" stroke-width="1" />
              <text x={SVG_PL - 5} y={gY(y) + 3.5} text-anchor="end" font-size="10" fill="#9ca3af">{y.toFixed(1)}</text>
            </>
          ))}
          {giniSeries.map((_, i) => (
            <line x1={gX(i)} y1={SVG_PT} x2={gX(i)} y2={SVG_PT + SVG_IH} stroke="#f9fafb" stroke-width="1" stroke-dasharray="3 2" />
          ))}
          {svgGiniFillPts && <polygon points={svgGiniFillPts} fill="rgba(99,102,241,0.08)" />}
          <line x1={SVG_PL} y1={SVG_PT + SVG_IH} x2={SVG_W - SVG_PR} y2={SVG_PT + SVG_IH} stroke="#e5e7eb" stroke-width="1" />
          {svgGiniPts && <polyline points={svgGiniPts} fill="none" stroke="rgb(99,102,241)" stroke-width="2.2" stroke-linejoin="round" />}
          {giniSeries.map((r, i) => {
            const cy = gY(r.g);
            const isPeak = r.pk === giniPeak.pk;
            return (
              <>
                <circle cx={gX(i)} cy={cy} r="3.5" fill={isPeak ? 'rgb(79,70,229)' : 'rgb(99,102,241)'} />
                <text x={gX(i)} y={cy - 7} text-anchor="middle" font-size="9"
                  fill={isPeak ? 'rgb(79,70,229)' : 'rgb(99,102,241)'}
                  font-weight={isPeak ? 'bold' : 'normal'}>
                  {r.g.toFixed(3)}{isPeak ? ' ↑' : ''}
                </text>
              </>
            );
          })}
          {giniSeries.map((r, i) => (
            <>
              <text x={gX(i)} y={SVG_PT + SVG_IH + 16} text-anchor="middle" font-size="10" fill="#6b7280">{r.label}</text>
              <text x={gX(i)} y={SVG_PT + SVG_IH + 28} text-anchor="middle" font-size="8.5" fill="#d1d5db">n={r.n}</text>
            </>
          ))}
          <text transform={`translate(11,${SVG_PT + SVG_IH / 2}) rotate(-90)`}
            text-anchor="middle" font-size="9.5" fill="#9ca3af">Gini</text>
        </svg>
      </div>

      <!-- ── Gini-Befund ────────────────────────────────────────────────── -->
      <div class="border border-indigo-100 bg-indigo-50/40 rounded-md px-5 py-4 mb-8 space-y-3">
        <p class="text-xs font-semibold text-indigo-800 uppercase tracking-wide">Was der Gini zeigt, was der Spread nicht zeigt</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs text-indigo-900">
          <div class="border-l-2 border-indigo-300 pl-3">
            <p class="font-semibold mb-0.5">2023 → 2024: Oberkante-Expansion, keine breite Ungleichheit</p>
            <p class="text-indigo-700 leading-relaxed">
              Q4 2023 → Q4 2024: Spreizung stieg von 3,20 auf 4,60 (+1,40), aber der Gini bewegte sich
              kaum (0,486 → 0,496, +0,010). Die Quartilsextreme weiteten sich dramatisch aus, während
              die Gesamtform der Verteilung nahezu gleich blieb. Schluss: das teure Tail wuchs
              vom Rest weg — die Mitte verschob sich nicht.
            </p>
          </div>
          <div class="border-l-2 border-indigo-300 pl-3">
            <p class="font-semibold mb-0.5">2024 → 2025: Breite Kompression über die gesamte Verteilung</p>
            <p class="text-indigo-700 leading-relaxed">
              Q4 2024 → Q1 2025: Gini (0,496 → 0,376) und Spreizung (4,60 → 2,35) fielen gemeinsam
              stark. Wenn Gini und Spread parallel fallen, ist die Kompression strukturell — sie
              betrifft die gesamte Verteilung, nicht nur die Extremwerte. Konsistent mit einem echten
              Bewertungsreset oder dem 2025-Marktkapitalisierungs-Vorbehalt.
            </p>
          </div>
        </div>
        <p class="text-[11px] text-indigo-500 leading-relaxed pt-1">
          Keiner dieser Befunde ist aus Spreizung oder Ratio allein ablesbar.
          Ein stabiler Gini bei steigendem Spread ist ein spezifisches Struktursignal:
          der Markt wird nicht insgesamt ungleicher — nur die bestehenden Extreme driften weiter auseinander.
        </p>
      </div>

      <!-- ── Divergenzdiagramm ──────────────────────────────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.divergenceChartHeading}</h3>
      <div class="flex items-center gap-5 mb-3 text-xs text-gray-500">
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-3 rounded-sm bg-teal-400/80"></span>
          {tc.fragility.divergenceLegendCons}
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-3 rounded-sm bg-orange-400/70"></span>
          {tc.fragility.divergenceLegendHigh}
        </span>
      </div>
      <div class="space-y-4 mb-8">
        {fragSeries.map(row => (
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-mono text-gray-600 w-16 shrink-0 text-right">{row.label}</span>
              <span class="text-xs text-gray-400 w-16 shrink-0">{row.dataType === 'annual' ? tc.fragility.annualLabel : tc.fragility.quarterlyLabel}</span>
            </div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-gray-400 w-32 shrink-0 text-right">Core RG</span>
              <div class="flex-1 bg-gray-100 rounded-sm h-4 relative">
                <div class="h-4 rounded-sm bg-teal-400/70"
                  style={`width: ${maxFHigh > 0 ? Math.round((row.conservativeMedian / maxFHigh) * 100) : 0}%`} />
              </div>
              <span class="text-xs font-mono text-gray-600 w-8 shrink-0">{fmt(row.conservativeMedian)}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-400 w-32 shrink-0 text-right">Narrative RG</span>
              <div class="flex-1 bg-gray-100 rounded-sm h-4 relative">
                <div class={`h-4 rounded-sm ${row.spread === maxFSpread ? 'bg-orange-500/70' : 'bg-orange-400/55'}`}
                  style={`width: ${maxFHigh > 0 ? Math.round((row.highMedian / maxFHigh) * 100) : 0}%`} />
              </div>
              <span class="text-xs font-mono font-semibold text-gray-700 w-8 shrink-0">{fmt(row.highMedian)}</span>
              {row.spread === maxFSpread && (
                <span class="text-xs text-orange-600 font-medium shrink-0">← {tc.fragility.peakAnnotation}</span>
              )}
            </div>
          </div>
        ))}
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.spreadChartHeading}</h3>
      <div class="space-y-2 mb-8">
        {fragSeries.map(row => (
          <div class="flex items-center gap-3">
            <span class="text-xs font-mono text-gray-500 w-16 text-right shrink-0">{row.label}</span>
            <div class="flex-1 bg-gray-100 rounded-sm h-6 relative">
              <div class={`h-6 rounded-sm ${row.spread === maxFSpread ? 'bg-accent' : 'bg-accent/55'}`}
                style={`width: ${maxFSpread > 0 ? Math.round((row.spread / maxFSpread) * 100) : 0}%`} />
            </div>
            <span class="text-xs font-mono text-gray-700 w-10 shrink-0">{fmt(row.spread)}</span>
            {row.spread === maxFSpread && (
              <span class="text-xs text-accent font-semibold shrink-0">{tc.fragility.peakAnnotation}</span>
            )}
            {row.spreadChange !== null && (
              <span class={`text-xs font-mono shrink-0 w-14 ${row.spreadChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                {row.spreadChange >= 0 ? '+' : ''}{fmt(row.spreadChange)}
              </span>
            )}
          </div>
        ))}
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.ratioChartHeading}</h3>
      <div class="space-y-2 mb-8">
        {fragSeries.map(row => (
          <div class="flex items-center gap-3">
            <span class="text-xs font-mono text-gray-500 w-16 text-right shrink-0">{row.label}</span>
            <div class="flex-1 bg-gray-100 rounded-sm h-6 relative">
              <div class={`h-6 rounded-sm ${row.ratio === maxFRatio ? 'bg-accent' : 'bg-accent/55'}`}
                style={`width: ${maxFRatio > 0 ? Math.round((row.ratio / maxFRatio) * 100) : 0}%`} />
            </div>
            <span class="text-xs font-mono text-gray-700 w-10 shrink-0">{fmt(row.ratio, 1)}×</span>
            {row.ratio === maxFRatio && (
              <span class="text-xs text-accent font-semibold shrink-0">{tc.fragility.peakAnnotation}</span>
            )}
            {row.ratioChange !== null && (
              <span class={`text-xs font-mono shrink-0 w-14 ${row.ratioChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                {row.ratioChange >= 0 ? '+' : ''}{fmt(row.ratioChange, 1)}×
              </span>
            )}
          </div>
        ))}
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.tableHeading}</h3>
      <div class="border border-gray-200 rounded-md overflow-hidden mb-6 text-xs">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-50 text-gray-500 uppercase tracking-wide">
              <th class="text-left px-3 py-2 font-medium">{tc.fragility.colPeriod}</th>
              <th class="text-left px-3 py-2 font-medium">{tc.fragility.colType}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colConsMedian}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colHighMedian}</th>
              <th class="text-right px-3 py-2 font-medium font-semibold text-gray-700">{tc.fragility.colSpread}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colSpreadChange}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colRatio}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colRatioChange}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colUpperTail}</th>
            </tr>
          </thead>
          <tbody>
            {fragSeries.map(row => (
              <tr class={`border-t border-gray-100 ${row.spread === maxFSpread ? 'bg-orange-50/40' : ''}`}>
                <td class="px-3 py-2 font-medium text-gray-700">
                  {row.label}
                  {row.spread === maxFSpread && (
                    <span class="ml-1 text-orange-500 text-xs">↑ {tc.fragility.peakAnnotation}</span>
                  )}
                </td>
                <td class="px-3 py-2 text-gray-400">{row.dataType === 'annual' ? tc.fragility.annualLabel : tc.fragility.quarterlyLabel}</td>
                <td class="px-3 py-2 text-right font-mono text-gray-600">{fmt(row.conservativeMedian)}</td>
                <td class="px-3 py-2 text-right font-mono text-gray-600">{fmt(row.highMedian)}</td>
                <td class="px-3 py-2 text-right font-mono font-semibold text-gray-900">{fmt(row.spread)}</td>
                <td class={`px-3 py-2 text-right font-mono ${row.spreadChange == null ? 'text-gray-300' : row.spreadChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                  {row.spreadChange == null ? '—' : (row.spreadChange >= 0 ? '+' : '') + fmt(row.spreadChange)}
                </td>
                <td class="px-3 py-2 text-right font-mono text-gray-700">{fmt(row.ratio, 1)}×</td>
                <td class={`px-3 py-2 text-right font-mono ${row.ratioChange == null ? 'text-gray-300' : row.ratioChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                  {row.ratioChange == null ? '—' : (row.ratioChange >= 0 ? '+' : '') + fmt(row.ratioChange, 1) + '×'}
                </td>
                <td class="px-3 py-2 text-right font-mono text-gray-500">{Math.round(row.upperTailShare * 100)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- ── Übergangsmatrix ─────────────────────────────────────────────── -->
      <h3 class="text-sm font-semibold text-gray-700 mb-1">Übergangsmatrix: Q4 2023 → Q4 2025</h3>
      <p class="text-xs text-gray-400 mb-4">
        Panel von {tN} Unternehmen mit gültigem RG10 in beiden Perioden. Zeilen = Position 2023, Spalten = Position 2025.
        Schwellwerte je Periode unabhängig berechnet ({transMethod === 'quartile' ? 'Quartilsmethode' : 'Drittel-Methode'}).
        Diagonale = stabile Quartilsposition ({transStabilityPct}% des Panels).
      </p>
      <div class="border border-gray-200 rounded-md overflow-hidden mb-5 text-xs">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-50 text-gray-400 uppercase tracking-wide text-[10px]">
              <th class="text-left px-3 py-2 font-medium">2023 ↓ / 2025 →</th>
              <th class="px-3 py-2 font-medium text-center text-teal-600">Core 2025</th>
              <th class="px-3 py-2 font-medium text-center">Mitte 2025</th>
              <th class="px-3 py-2 font-medium text-center text-orange-600">Narrative 2025</th>
            </tr>
          </thead>
          <tbody>
            {transMatrix.map((row, ri) => {
              const rowLabel = ['Core 2023', 'Mitte 2023', 'Narrative 2023'][ri];
              const rowColor = ['text-teal-700', 'text-gray-600', 'text-orange-700'][ri];
              return (
                <tr class="border-t border-gray-100">
                  <td class={`px-3 py-2 font-medium ${rowColor}`}>{rowLabel}</td>
                  {row.map((count, ci) => {
                    const pct = tN > 0 ? Math.round(count / tN * 100) : 0;
                    const isDiag = ri === ci;
                    const isHot  = ri === 0 && ci === 2;
                    const isCool = ri === 2 && ci === 0;
                    return (
                      <td class={[
                        'px-3 py-2 text-center font-mono',
                        isDiag ? 'bg-gray-50 font-semibold text-gray-800' : 'text-gray-500',
                        isHot  ? 'bg-orange-50 !text-orange-800 font-bold' : '',
                        isCool ? 'bg-teal-50 !text-teal-800 font-bold' : '',
                      ].join(' ')}>
                        {count > 0 ? count : '—'}
                        {count > 0 && <span class="font-normal text-gray-400 ml-1 text-[10px]">{pct}%</span>}
                      </td>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {/* Extremwechsler */}
      {(narrativeToCore.length > 0 || coreToNarrative.length > 0) && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          {narrativeToCore.length > 0 && (
            <div>
              <p class="text-xs font-semibold text-teal-700 mb-2">
                Narrative → Core — korrigiert ({narrativeToCore.length})
              </p>
              <div class="space-y-1">
                {narrativeToCore.slice(0, 6).map(c => (
                  <div class="flex items-center justify-between text-xs border border-teal-100 bg-teal-50/50 rounded px-2.5 py-1.5">
                    <span class="font-medium text-gray-700 truncate mr-2">{c.company}</span>
                    <span class="font-mono text-teal-700 shrink-0">{c.rg23.toFixed(2)} → {c.rg25.toFixed(2)}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
          {coreToNarrative.length > 0 && (
            <div>
              <p class="text-xs font-semibold text-orange-700 mb-2">
                Core → Narrative — verteuert ({coreToNarrative.length})
              </p>
              <div class="space-y-1">
                {coreToNarrative.slice(0, 6).map(c => (
                  <div class="flex items-center justify-between text-xs border border-orange-100 bg-orange-50/50 rounded px-2.5 py-1.5">
                    <span class="font-medium text-gray-700 truncate mr-2">{c.company}</span>
                    <span class="font-mono text-orange-700 shrink-0">{c.rg23.toFixed(2)} → {c.rg25.toFixed(2)}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      <!-- ── Befunde der Übergangsmatrix ────────────────────────────────── -->
      <div class="space-y-2.5 mb-8">
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">RG-Positionen sind träge</p>
          <p class="text-sm text-gray-500">
            {transStabilityPct}% der {tN} Unternehmen blieben zwischen Q4 2023 und Q4 2025 in derselben
            Quartilsgruppe. Die Bewertungsstruktur, wie RG sie abbildet, neigt zur Persistenz — eine
            Eigenschaft, die einfache preisbasierte Multiples mit jeder Kursänderung zurücksetzen.
          </p>
        </div>
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Kein direkter Core ↔ Narrative-Sprung</p>
          <p class="text-sm text-gray-500">
            Jedes Unternehmen, das zwischen den Extremen wechselte, durchlief zunächst die mittleren
            Quartile. Kein Unternehmen sprang direkt von Core nach Narrative oder umgekehrt.
            Extreme RG-Positionen sind offenbar nicht schnell oder einfach reversibel.
          </p>
        </div>
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Core ist stabiler als Narrative</p>
          <p class="text-sm text-gray-500">
            {tN > 0 && transMatrix[0] && transMatrix[2] ? (() => {
              const coreTotal = (transMatrix[0][0]??0)+(transMatrix[0][1]??0)+(transMatrix[0][2]??0);
              const narrTotal = (transMatrix[2][0]??0)+(transMatrix[2][1]??0)+(transMatrix[2][2]??0);
              const corePct = coreTotal > 0 ? Math.round((transMatrix[0][0]??0)/coreTotal*100) : 0;
              const narrPct = narrTotal > 0 ? Math.round((transMatrix[2][2]??0)/narrTotal*100) : 0;
              return `${corePct}% der Core-Unternehmen blieben Core; nur ${narrPct}% der Narrative-Unternehmen blieben Narrative.`;
            })() : ''}
            {' '}Narrative-Positionen erodieren schneller — konsistent mit der Überlegung, dass hohe
            RG-Bewertungen stärkerem Regressionsdruck unterliegen als niedrige.
          </p>
        </div>
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Die Mitte wirkt als Einbahnpuffer</p>
          <p class="text-sm text-gray-500">
            Bewegungen zwischen den Extremen verlaufen über die Mitte — die mittlere Gruppe ist
            strukturell eine Übergangszone, kein stabiler Ruhezustand. Das unterscheidet RG
            von P/G, bei dem eine einzelne Gewinnrevision sofortige Neuordnungen bewirken kann.
          </p>
        </div>
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.interpretation.heading}</h3>
      <div class="space-y-3 mb-5">
        {tc.fragility.interpretation.items.map((item: { title: string; body: string }) => (
          <div class="border-l-2 border-gray-200 pl-4">
            <p class="text-sm font-semibold text-gray-700 mb-0.5">{item.title}</p>
            <p class="text-sm text-gray-500">{item.body}</p>
          </div>
        ))}
      </div>

      <p class="text-xs text-gray-400 border border-gray-100 rounded-md bg-gray-50/50 px-4 py-3">
        {tc.fragility.limitationNote}
      </p>
    </section>

    <!-- 5b. Sektorale interne Fragilität -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">Sektorale Fragilität</h2>
      <p class="text-sm text-gray-500 mb-1">Wie weit liegen die günstige und die teure Hälfte innerhalb jedes Sektors auseinander — aktueller Schnappschuss.</p>
      <p class="text-xs text-gray-400 mb-6">Sektoren mit ≥ 4 Unternehmen. n ≥ 8: Quartilsmethode; n &lt; 8: Mediansplit. Sortiert nach Spreizung absteigend.</p>

      <div class="space-y-3">
        {sectorFragRows.map(row => (
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-medium text-gray-700">{row.sector}</span>
              <span class="text-xs text-gray-400">n={row.n}</span>
            </div>
            <div class="relative h-6 bg-gray-100 rounded-sm overflow-hidden">
              <div
                class="absolute inset-y-0 left-0 bg-orange-400/50 rounded-sm"
                style={`width:${maxSectorNarr > 0 ? (row.narrativeMedian / maxSectorNarr * 100).toFixed(1) : 0}%`}
              />
              <div
                class="absolute inset-y-0 left-0 bg-teal-400/70 rounded-sm"
                style={`width:${maxSectorNarr > 0 ? (row.coreMedian / maxSectorNarr * 100).toFixed(1) : 0}%`}
              />
            </div>
            <div class="flex items-center gap-3 mt-1 text-[11px]">
              <span class="text-teal-700 font-mono">Core {row.coreMedian.toFixed(2)}</span>
              <span class="text-gray-300">·</span>
              <span class="text-orange-700 font-mono">Narrative {row.narrativeMedian.toFixed(2)}</span>
              <span class="text-gray-300">·</span>
              <span class={`font-mono font-semibold ${row.spread === maxSectorSpread ? 'text-orange-700' : 'text-gray-600'}`}>
                Spreizung {row.spread.toFixed(2)}{row.spread === maxSectorSpread ? ' ↑' : ''}
              </span>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-6 border-l-2 border-gray-200 pl-4 space-y-2.5">
        <div>
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Automotive — der intern am stärksten gespaltene Sektor</p>
          <p class="text-sm text-gray-500">
            Traditionelle Automobilhersteller (niedriger RG, gewinnangebunden) stehen im selben Sektor wie
            hochnarrative E-Fahrzeug-Unternehmen. Die sektorinterne Spreizung von
            {sectorFragRows.find(r => r.sector === 'Automotive')?.spread.toFixed(2) ?? '—'}
            ist die größte im Panel — breiter als bei Technologie.
          </p>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Halbleiter: Wachstumsprämie im oberen Segment konzentriert</p>
          <p class="text-sm text-gray-500">
            Der Sektor reicht von reifen Foundry-Unternehmen (niedrigerer RG) bis zu KI-Infrastrukturnamen
            mit hohem Vielfachen auf geglättete Gewinne. Spreizung:
            {sectorFragRows.find(r => r.sector === 'Semiconductors')?.spread.toFixed(2) ?? '—'}.
          </p>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Technologie: geringere Spreizung als erwartet</p>
          <p class="text-sm text-gray-500">
            Trotz der breitesten Unternehmensanzahl zeigt Technologie eine moderate Spreizung von
            {sectorFragRows.find(r => r.sector === 'Technology')?.spread.toFixed(2) ?? '—'} —
            der Begriff deckt ein homogeneres RG-Band ab als Automotive oder Halbleiter.
          </p>
        </div>
      </div>
    </section>

    <!-- 5c. RG-Persistenz -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">RG-Persistenz</h2>
      <p class="text-sm text-gray-500 mb-1">
        Welche Unternehmen sind strukturell in ihrer RG-Gruppe verankert — und welche rotieren?
        Klassifizierung über alle verfügbaren Perioden (max. {PERSIST_PERIODS.length} Quartale).
      </p>
      <p class="text-xs text-gray-400 mb-6">
        Dauerhaft Narrative / Core = ≥ 70% der beobachteten Quartale im oberen bzw. unteren Quartil.
        Schwellwerte je Periode unabhängig berechnet.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div>
          <p class="text-xs font-semibold text-orange-700 mb-2 uppercase tracking-wide">
            Dauerhaft Narrative — {permNarrative.length} Unternehmen
          </p>
          <div class="space-y-1">
            {permNarrative.map(r => (
              <div class="flex items-center justify-between text-xs border border-orange-100 bg-orange-50/30 rounded px-2.5 py-1.5">
                <span class="font-medium text-gray-700 truncate mr-2">{r.company}</span>
                <span class="font-mono text-orange-600 shrink-0">{r.narrPct}%</span>
              </div>
            ))}
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold text-teal-700 mb-2 uppercase tracking-wide">
            Dauerhaft Core — {permCore.length} Unternehmen
          </p>
          <div class="space-y-1">
            {permCore.map(r => (
              <div class="flex items-center justify-between text-xs border border-teal-100 bg-teal-50/30 rounded px-2.5 py-1.5">
                <span class="font-medium text-gray-700 truncate mr-2">{r.company}</span>
                <span class="font-mono text-teal-600 shrink-0">{r.corePct}%</span>
              </div>
            ))}
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold text-gray-500 mb-2 uppercase tracking-wide">
            Mitte / Rotatoren — {rotators.length} Unternehmen (n ≥ 3)
          </p>
          <div class="space-y-1">
            {rotators.map(r => (
              <div class="flex items-center justify-between text-xs border border-gray-100 bg-gray-50/30 rounded px-2.5 py-1.5">
                <span class="font-medium text-gray-700 truncate mr-2">{r.company}</span>
                <span class="font-mono text-gray-400 shrink-0">{Math.round(r.nMid / r.nTotal * 100)}% mid</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="space-y-2.5">
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Der Narrative-Cluster ist strukturell stabil — und US-dominiert</p>
          <p class="text-sm text-gray-500">
            Jedes Unternehmen in der dauerhaft narrativen Gruppe befand sich in jedem beobachteten
            Quartal im oberen Quartil. Das sind keine Momentumwetten — sie sind strukturell teuer nach
            der Logik geglätteter Gewinne. Die Gruppe besteht fast ausschließlich aus US-notierten
            Wachstums- und Qualitätsnamen: Halbleiter, Zahlungsverkehr, Basiskonsumgüter, Streaming.
            Kein europäisches oder japanisches Unternehmen taucht hier auf.
          </p>
        </div>
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Der Core-Cluster ist strukturell stabil — und geographisch konzentriert</p>
          <p class="text-sm text-gray-500">
            Dauerhaft-Core-Unternehmen werden dominiert von deutschen Automobilherstellern (BMW,
            Mercedes-Benz, Volkswagen, Porsche SE), japanischen Industrie- und Bankwerten (Toyota,
            Honda, Mitsubishi UFJ) sowie deutschen Finanz- und Versorgungsunternehmen (Deutsche Bank,
            RWE). Diese Namen lagen konsistent im unteren Quartil — strukturell günstig nach RG-Logik,
            oder strukturell ertragsschwach.
          </p>
        </div>
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Alphabet und Meta stehen in der Mitte — nicht bei Nvidia</p>
          <p class="text-sm text-gray-500">
            Obwohl sie gemeinsam mit Nvidia und AMD als Big Tech klassifiziert werden, befanden sich
            Alphabet und Meta in keiner einzigen beobachteten Periode im oberen Quartil. Ihre geglätteten
            Gewinne sind hoch genug relativ zur Marktkapitalisierung, um sie aus dem Narrative-Cluster
            herauszuhalten. Das ist eine strukturelle Unterscheidung, die RG trifft — die ein
            einfaches „Tech-Sektor"-Label nicht macht.
          </p>
        </div>
      </div>
    </section>

    <!-- 5d. Konvergenz zu RG = 1 -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">Konvergenz zum Fairvalue (RG = 1)</h2>
      <p class="text-sm text-gray-500 mb-1">
        RG = 1 ist der theoretische Ankerpunkt des Instruments: Marktkapitalisierung entspricht dem Zehnfachen der geglätteten Gewinne.
        Bewegen sich Unternehmen tatsächlich darauf zu — oder driften sie weiter weg?
      </p>
      <p class="text-xs text-gray-400 mb-6">
        Panel von {tN} Unternehmen mit gültigem RG10 in Q4 2023 und Q4 2025.
        Konvergenz = Abstand zu RG 1,0 um &gt; 0,05 gesunken; Divergenz = um &gt; 0,05 gestiegen.
      </p>

      <!-- Zusammenfassung -->
      <div class="flex gap-3 mb-6 flex-wrap">
        <div class="border border-teal-200 bg-teal-50/50 rounded-md px-5 py-3 min-w-[140px]">
          <p class="text-xs text-teal-600 font-medium uppercase tracking-wide mb-1">Konvergierend</p>
          <p class="text-3xl font-light text-teal-800" style="font-family:Georgia,serif">{convCount}</p>
          <p class="text-xs text-teal-500 mt-0.5">{convPct}% des Panels</p>
        </div>
        <div class="border border-orange-200 bg-orange-50/50 rounded-md px-5 py-3 min-w-[140px]">
          <p class="text-xs text-orange-600 font-medium uppercase tracking-wide mb-1">Divergierend</p>
          <p class="text-3xl font-light text-orange-800" style="font-family:Georgia,serif">{divCount}</p>
          <p class="text-xs text-orange-500 mt-0.5">{100 - convPct}% des Panels</p>
        </div>
        <div class="border border-gray-200 bg-gray-50/50 rounded-md px-5 py-3 min-w-[200px] flex-1">
          <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Nach Ausgangsgruppe</p>
          <div class="mt-1 text-xs">
            <span><span class="text-teal-700 font-semibold">{coreConvPct}%</span> <span class="text-gray-500">der Core-Unternehmen (RG &lt; 0,8) konvergieren</span></span>
          </div>
          <div class="mt-0.5 text-xs">
            <span><span class="text-orange-700 font-semibold">{narrConvPct}%</span> <span class="text-gray-500">der Narrative-Unternehmen (RG &gt; 1,5) konvergieren</span></span>
          </div>
        </div>
      </div>

      <!-- Top-Mover -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div>
          <p class="text-xs font-semibold text-teal-700 mb-2">Stärkste Konvergenz — nähern sich RG 1,0</p>
          <div class="space-y-1.5">
            {topConvergers.map(c => (
              <div class="border border-teal-100 bg-teal-50/40 rounded px-3 py-2 text-xs">
                <div class="flex justify-between items-baseline">
                  <span class="font-medium text-gray-700">{c.company}</span>
                  <span class="font-mono text-teal-700">{c.rg23.toFixed(2)} → {c.rg25.toFixed(2)}</span>
                </div>
                <div class="text-gray-400 mt-0.5">
                  Abstand zu RG 1,0: {c.dist23.toFixed(2)} → {c.dist25.toFixed(2)}
                  <span class="text-teal-600 ml-1">({c.distDelta.toFixed(2)})</span>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold text-orange-700 mb-2">Stärkste Divergenz — entfernen sich von RG 1,0</p>
          <div class="space-y-1.5">
            {topDivergers.map(c => (
              <div class="border border-orange-100 bg-orange-50/40 rounded px-3 py-2 text-xs">
                <div class="flex justify-between items-baseline">
                  <span class="font-medium text-gray-700">{c.company}</span>
                  <span class="font-mono text-orange-700">{c.rg23.toFixed(2)} → {c.rg25.toFixed(2)}</span>
                </div>
                <div class="text-gray-400 mt-0.5">
                  Abstand zu RG 1,0: {c.dist23.toFixed(2)} → {c.dist25.toFixed(2)}
                  <span class="text-orange-600 ml-1">(+{c.distDelta.toFixed(2)})</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Sektoraufschlüsselung -->
      {convSectorRows.length > 0 && (
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-700 mb-3">Konvergenzrate nach Sektor (n ≥ 3)</h3>
          <div class="space-y-2">
            {convSectorRows.map(row => (
              <div class="flex items-center gap-3">
                <span class="text-xs text-gray-600 w-40 shrink-0">{row.sector}</span>
                <div class="flex-1 bg-gray-100 rounded-sm h-4 relative">
                  <div class="h-4 rounded-sm bg-teal-400/70" style={`width:${row.convPct}%`} />
                </div>
                <span class="text-xs font-mono text-gray-700 w-10 shrink-0">{row.convPct}%</span>
                <span class="text-xs text-gray-400 shrink-0">n={row.n}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Interpretation -->
      <div class="space-y-2.5">
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Core-Unternehmen konvergieren schneller als Narrative</p>
          <p class="text-sm text-gray-500">
            {coreConvPct}% der Unternehmen unter RG 0,8 näherten sich dem Fairvalue — vermutlich über steigende
            geglättete Gewinne, nicht fallende Kurse. Nur {narrConvPct}% der Unternehmen über RG 1,5 korrigierten
            auf 1,0 zu. Das teure Tail ist klebriger als das günstige, konsistent mit der Fragilitätshypothese:
            Narrative-Bewertungen widerstehen Abwärtskorrekturen.
          </p>
        </div>
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Eine schwache interne Validierung</p>
          <p class="text-sm text-gray-500">
            Die Mehrheit des Panels ({convPct}%) bewegt sich in die Richtung, die die RG-Logik vorhersagt.
            Das belegt keine Prognosekraft, ist aber konsistent mit der internen Prämisse des Instruments.
            Die {100 - convPct}% divergierende Gruppe — angeführt von Tesla und Broadcom — ist die
            eigentlich offene Frage: Werden diese korrigieren, oder hat sich die Gewinnbasis selbst verschoben?
          </p>
        </div>
        <div class="border-l-2 border-gray-300 pl-4">
          <p class="text-sm font-semibold text-gray-700 mb-0.5">Vorbehalt: 2025-Marktkapitalisierungsverzerrung</p>
          <p class="text-sm text-gray-500">
            Wie bei allen 2025-Beobachtungen: Es wird die aktuelle Marktkapitalisierung verwendet, keine
            historischen Quartalsschlusspreise. Unternehmen mit höheren geglätteten Gewinnen in 2025
            zeigen mechanisch einen niedrigeren RG — Konvergenz ohne Kurskorrektur.
          </p>
        </div>
      </div>
    </section>

    <!-- 6. RG vs Simpler Metrics -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.metricComparison.heading}</h2>
      <p class="text-sm text-gray-500 mb-2">{tc.metricComparison.subheading}</p>
      <p class="text-xs text-gray-400 mb-6">{tc.metricComparison.sampleNote}</p>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.metricComparison.comparisonTableHeading}</h3>
      <div class="border border-gray-200 rounded-md overflow-hidden mb-8 text-xs">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-50 text-gray-500 uppercase tracking-wide">
              <th class="text-left px-3 py-2 font-medium">{tc.metricComparison.colMetric}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.metricComparison.colN}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.metricComparison.colLowAvg}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.metricComparison.colHighAvg}</th>
              <th class="px-3 py-2 font-medium" style="width:120px;">Visual</th>
              <th class="text-right px-3 py-2 font-medium font-semibold text-gray-700">{tc.metricComparison.colSpread}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.metricComparison.colRho}</th>
            </tr>
          </thead>
          <tbody>
            {retroMetrics.map(m => (
              <tr class="border-t border-gray-100">
                <td class="px-3 py-2"><span class="text-xs font-semibold text-gray-800">{m.key.toUpperCase()}</span></td>
                <td class="px-3 py-2 text-right font-mono text-gray-500">{m.n}</td>
                <td class={`px-3 py-2 text-right font-mono font-semibold ${m.inverted ? 'text-gray-600' : 'text-teal-700'}`}>
                  {m.inverted ? '' : '+'}{fmt(m.lowAvg, 0)}%
                </td>
                <td class={`px-3 py-2 text-right font-mono ${m.inverted ? 'text-teal-700 font-semibold' : 'text-gray-600'}`}>
                  {m.inverted ? '+' : ''}{fmt(m.highAvg, 0)}%
                </td>
                <td class="px-3 py-2">
                  <div class="flex items-center gap-1" style="height:14px;">
                    <div class="bg-teal-400/60 rounded-sm" style={`height:10px; width:${Math.round((m.inverted ? m.highAvg : m.lowAvg) / maxAvgRet * 60)}px;`} />
                    <div class="bg-gray-300/80 rounded-sm" style={`height:10px; width:${Math.round((m.inverted ? m.lowAvg : m.highAvg) / maxAvgRet * 60)}px;`} />
                  </div>
                </td>
                <td class={`px-3 py-2 text-right font-mono font-semibold ${Math.abs(m.spread) >= 30 ? 'text-gray-900' : 'text-gray-500'}`}>
                  {m.spread >= 0 ? '+' : ''}{fmt(m.spread, 0)}%
                </td>
                <td class="px-3 py-2 text-right font-mono text-gray-600">
                  {m.rho != null ? (m.rho >= 0 ? '+' : '') + m.rho.toFixed(2) : '—'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.metricComparison.quartileHeading}</h3>
      <div class="grid grid-cols-1 gap-6 mb-8" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        {retroMetrics.slice(0, 3).map(m => (
          <div class="border border-gray-200 rounded-md overflow-hidden text-xs">
            <div class="bg-gray-50 px-3 py-2 font-semibold text-gray-700 border-b border-gray-200">{m.key.toUpperCase()} — {tc.metricComparison.quartileHeading}</div>
            <div class="p-3 space-y-2">
              {[m.q1, m.q2, m.q3, m.q4].map((q, i) => (
                <div class="flex items-center gap-2">
                  <span class="text-gray-400 w-4 shrink-0">Q{i+1}</span>
                  <div class="flex-1 bg-gray-100 rounded-sm h-5 relative">
                    <div class={`h-5 rounded-sm ${q.avgRet >= 70 ? 'bg-teal-400/70' : q.avgRet >= 40 ? 'bg-accent/60' : 'bg-gray-300'}`}
                      style={`width: ${maxAvgRet > 0 ? Math.round(Math.max(0, q.avgRet) / maxAvgRet * 100) : 0}%`} />
                  </div>
                  <span class={`font-mono w-14 text-right shrink-0 ${q.avgRet >= 70 ? 'text-teal-700 font-semibold' : 'text-gray-600'}`}>
                    {q.avgRet >= 0 ? '+' : ''}{fmt(q.avgRet, 0)}%
                  </span>
                  <span class="text-gray-400 w-5 shrink-0 text-center">n={q.n}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="border border-gray-200 rounded-md bg-gray-50/50 px-5 py-4 mb-8">
        <p class="text-sm font-semibold text-gray-700 mb-1">{tc.metricComparison.verdictHeading}</p>
        <p class="text-sm text-gray-600">{tc.metricComparison.verdictBody}</p>
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-2">{tc.metricComparison.casesHeading}</h3>
      <p class="text-xs text-gray-400 mb-3">{tc.metricComparison.casesNote}</p>
      <div class="border border-gray-200 rounded-md overflow-hidden text-xs">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-50 text-gray-500 uppercase tracking-wide">
              <th class="text-left px-3 py-2 font-medium">{tc.metricComparison.colCompany}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.metricComparison.colRG10}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.metricComparison.colPG}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.metricComparison.colMTE}</th>
              <th class="text-right px-3 py-2 font-medium font-semibold text-gray-700">{tc.metricComparison.colReturn}</th>
              <th class="text-left px-3 py-2 font-medium">{tc.metricComparison.colCase}</th>
            </tr>
          </thead>
          <tbody>
            {illustrativeCases.map(c => {
              const cc = c.caseType === 'consistent' ? 'text-teal-600' : c.caseType === 'exception' ? 'text-orange-600' : 'text-gray-400';
              return (
                <tr class="border-t border-gray-100">
                  <td class="px-3 py-2 font-medium text-gray-700">{c.company}</td>
                  <td class="px-3 py-2 text-right font-mono text-gray-600">{c.rg10.toFixed(2)}</td>
                  <td class="px-3 py-2 text-right font-mono text-gray-600">{c.pg != null ? c.pg.toFixed(2) : '—'}</td>
                  <td class="px-3 py-2 text-right font-mono text-gray-600">{c.mte != null ? c.mte.toFixed(1) : '—'}</td>
                  <td class={`px-3 py-2 text-right font-mono font-semibold ${c.ret > 0 ? 'text-gray-800' : 'text-gray-500'}`}>{c.ret > 0 ? '+' : ''}{c.ret}%</td>
                  <td class={`px-3 py-2 text-xs ${cc}`}>{(tc.metricComparison.caseTypes as any)[c.caseType]}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 7. Use cases -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">{tc.useCases.heading}</h2>
      <div class="space-y-4">
        {tc.useCases.items.map((item: { title: string; body: string }) => (
          <div class="border-l-2 border-gray-200 pl-4">
            <p class="text-sm font-semibold text-gray-700 mb-1">{item.title}</p>
            <p class="text-sm text-gray-500">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 7. Historical Coverage Status -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.coverage.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.coverage.subheading}</p>

      <div class="border border-red-200 bg-red-50/60 rounded-md px-5 py-4 mb-8">
        <p class="text-sm font-semibold text-red-700 mb-1">Aktuelles Beobachtungsfenster: nur 2023–2026</p>
        <p class="text-sm text-red-600 leading-relaxed">{tc.coverage.currentSliceNote}</p>
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-2">{tc.coverage.timelineHeading}</h3>
      <div class="flex flex-wrap items-center gap-4 mb-3 text-xs text-gray-500">
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-3 rounded-sm bg-gray-300"></span>
          {tc.coverage.timelineLegend.missing}
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-3 rounded-sm bg-amber-300/80"></span>
          {tc.coverage.timelineLegend.partial}
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-3 rounded-sm bg-teal-400/80"></span>
          {tc.coverage.timelineLegend.full}
        </span>
      </div>

      <div class="rounded-md overflow-hidden border border-gray-200 mb-2" style="height: 40px; display: flex;">
        <div style="width:38.7%; background:#d1d5db;" class="flex items-center justify-center">
          <span class="text-xs text-gray-600 font-medium px-1" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">1995–2007</span>
        </div>
        <div style="width:51.6%; background:#fcd34d; opacity:0.75;" class="flex items-center justify-center border-l border-gray-200">
          <span class="text-xs text-amber-900 font-medium px-1" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">2007–2023</span>
        </div>
        <div style="width:9.7%; background:#2dd4bf; opacity:0.75;" class="flex items-center justify-center border-l border-gray-200">
          <span class="text-xs text-teal-900 font-medium px-1" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">2023–26</span>
        </div>
      </div>
      <div class="relative mb-1" style="height: 22px;">
        <div class="absolute text-xs text-gray-500" style="left:16.1%; transform:translateX(-50%);">
          <span class="block text-center">↑</span><span style="white-space:nowrap; font-size:10px;">Dot-com-Spitze</span>
        </div>
        <div class="absolute text-xs text-gray-500" style="left:38.7%; transform:translateX(-50%);">
          <span class="block text-center">↑</span><span style="white-space:nowrap; font-size:10px;">GFC-Spitze</span>
        </div>
        <div class="absolute text-xs text-teal-700 font-medium" style="left:90.3%; transform:translateX(-50%);">
          <span class="block text-center">↑</span><span style="white-space:nowrap; font-size:10px;">Datensatz-Start</span>
        </div>
      </div>
      <div class="relative mb-6" style="height: 16px;">
        {[
          { yr: '1995', pct: '0%' }, { yr: '2000', pct: '16.1%' }, { yr: '2007', pct: '38.7%' },
          { yr: '2015', pct: '64.5%' }, { yr: '2023', pct: '90.3%' }, { yr: '2026', pct: '100%' },
        ].map(({ yr, pct }) => (
          <span class="absolute text-xs text-gray-400" style={`left:${pct}; transform:translateX(-50%);`}>{yr}</span>
        ))}
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.coverage.phasesHeading}</h3>
      <div class="border border-gray-200 rounded-md overflow-hidden mb-6 text-xs">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-50 text-gray-500 uppercase tracking-wide">
              <th class="text-left px-3 py-2 font-medium">Phase</th>
              <th class="text-left px-3 py-2 font-medium">Zeitraum</th>
              <th class="text-left px-3 py-2 font-medium">Status</th>
              <th class="text-left px-3 py-2 font-medium">Vorhanden</th>
              <th class="text-left px-3 py-2 font-medium">Fehlend</th>
              <th class="text-left px-3 py-2 font-medium">Nächster Schritt</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-gray-100 bg-gray-50/30">
              <td class="px-3 py-2 font-medium text-gray-700">Dot-com</td>
              <td class="px-3 py-2 font-mono text-gray-600">1995–2003</td>
              <td class="px-3 py-2"><span class="bg-gray-200 text-gray-600 text-xs px-1.5 py-0.5 rounded">Keine Daten</span></td>
              <td class="px-3 py-2 text-gray-500">Nichts</td>
              <td class="px-3 py-2 text-gray-500">Alle Fundamentaldaten + Kurse</td>
              <td class="px-3 py-2 text-gray-500">Neue Quelle erforderlich (Compustat / WRDS)</td>
            </tr>
            <tr class="border-t border-gray-100 bg-amber-50/20">
              <td class="px-3 py-2 font-medium text-gray-700">GFC</td>
              <td class="px-3 py-2 font-mono text-gray-600">2004–2011</td>
              <td class="px-3 py-2"><span class="bg-amber-100 text-amber-700 text-xs px-1.5 py-0.5 rounded border border-amber-200">Partiell</span></td>
              <td class="px-3 py-2 text-amber-700">fundamentals.db: 30 US-Titel, Erträge + EK ab 2007</td>
              <td class="px-3 py-2 text-gray-500">Historische Schlusskurse</td>
              <td class="px-3 py-2 text-teal-700 font-medium">Kurse via yfinance abrufen → RG aus fundamentals.db berechnen</td>
            </tr>
            <tr class="border-t border-gray-100 bg-amber-50/20">
              <td class="px-3 py-2 font-medium text-gray-700">Moderne Erweiterung</td>
              <td class="px-3 py-2 font-mono text-gray-600">2012–2022</td>
              <td class="px-3 py-2"><span class="bg-amber-100 text-amber-700 text-xs px-1.5 py-0.5 rounded border border-amber-200">Partiell</span></td>
              <td class="px-3 py-2 text-amber-700">fundamentals.db: vollständige 30-Titel-Abdeckung</td>
              <td class="px-3 py-2 text-gray-500">Historische Schlusskurse</td>
              <td class="px-3 py-2 text-teal-700 font-medium">Wie GFC — nur Kurse fehlen</td>
            </tr>
            <tr class="border-t border-gray-100 bg-teal-50/20">
              <td class="px-3 py-2 font-medium text-gray-700">Aktuell</td>
              <td class="px-3 py-2 font-mono text-gray-600">2023–2026</td>
              <td class="px-3 py-2"><span class="bg-teal-100 text-teal-700 text-xs px-1.5 py-0.5 rounded">Vollständig</span></td>
              <td class="px-3 py-2 text-teal-700">77 Unternehmen, alle Indizes, quartalsweise + jährlich</td>
              <td class="px-3 py-2 text-gray-400">—</td>
              <td class="px-3 py-2 text-gray-400">Aktive Abdeckung</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mb-7">{tc.coverage.fundamentalsDbNote}</p>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.coverage.whatWeWouldSee}</h3>
      <div class="space-y-2 mb-5">
        {tc.coverage.whatWeWouldSeeItems.map((item: { title: string; body: string }) => (
          <div class="flex gap-3 text-sm">
            <span class="text-gray-300 shrink-0 mt-0.5">–</span>
            <span><span class="font-medium text-gray-700">{item.title}: </span><span class="text-gray-500">{item.body}</span></span>
          </div>
        ))}
      </div>
      <p class="text-xs text-gray-400 italic">{tc.coverage.disclaimer}</p>
    </section>

    <!-- 8. Limitations -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">{tc.limitations.heading}</h2>
      <div class="border border-gray-200 rounded-md p-5">
        <ul class="space-y-3">
          {tc.limitations.items.map((item: string) => (
            <li class="flex gap-3 text-sm text-gray-600">
              <span class="text-gray-300 shrink-0 mt-0.5">–</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <p class="text-xs text-gray-400 border-t border-gray-100 pt-6">{t.companyDetail.disclaimer}</p>
  </div>
</BaseLayout>
