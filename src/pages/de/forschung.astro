---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { de } from '../../i18n/de';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const t = de;
const tc = t.research;

// ── Load all company data at build time ──────────────────────────────────────
const rawFiles = import.meta.glob('../../data/companies/*.json', { eager: true });
const allCompanies: any[] = Object.values(rawFiles).map((m: any) => m.default ?? m);

// ── Helpers ──────────────────────────────────────────────────────────────────
function median(arr: number[]): number {
  if (!arr.length) return 0;
  const s = [...arr].sort((a, b) => a - b);
  const mid = Math.floor(s.length / 2);
  return s.length % 2 !== 0 ? s[mid]! : ((s[mid - 1]! + s[mid]!) / 2);
}

function quantile(arr: number[], q: number): number {
  const s = [...arr].sort((a, b) => a - b);
  const pos = q * (s.length - 1);
  const lo = Math.floor(pos);
  const hi = Math.ceil(pos);
  return lo === hi ? s[lo]! : s[lo]! + (pos - lo) * (s[hi]! - s[lo]!);
}

function fmt(v: number | null | undefined, decimals = 2): string {
  if (v == null) return '—';
  return v.toFixed(decimals);
}

// ── Latest RG10 per company ──────────────────────────────────────────────────
const summaries = allCompanies.map((d) => {
  const obs = [...d.observations].sort((a: any, b: any) =>
    a.periodKey < b.periodKey ? 1 : -1
  );
  const latest = obs[0] as any;
  return {
    company:      d.company,
    sector:       d.sector ?? '',
    index:        d.index  ?? '',
    rg10:         latest?.rg10 ?? null,
    nearBoundary: latest?.nearBoundary === true,
    notCovered:   latest?.rg10 == null,
  };
});

const valid = summaries.filter((s: any) => s.rg10 !== null && !s.nearBoundary);
const validRG = valid.map((s: any) => s.rg10 as number);
const notCoveredCount = summaries.filter((s: any) => s.notCovered).length;
const nearBoundaryCount = summaries.filter((s: any) => s.nearBoundary).length;

// ── Distribution ─────────────────────────────────────────────────────────────
const buckets = [
  { label: '< 1',   min: 0,  max: 1  },
  { label: '1 – 2', min: 1,  max: 2  },
  { label: '2 – 5', min: 2,  max: 5  },
  { label: '5 – 10',min: 5,  max: 10 },
  { label: '> 10',  min: 10, max: Infinity },
].map(b => ({
  ...b,
  count: validRG.filter(v => v >= b.min && v < b.max).length,
}));
const maxBucketCount = Math.max(...buckets.map(b => b.count));
const med = median(validRG);
const p25 = quantile(validRG, 0.25);
const p75 = quantile(validRG, 0.75);

// ── Cross-index ───────────────────────────────────────────────────────────────
const indexGroups: Record<string, number[]> = {};
for (const s of valid) {
  if (!indexGroups[(s as any).index]) indexGroups[(s as any).index] = [];
  indexGroups[(s as any).index].push((s as any).rg10);
}
const indexStats = Object.entries(indexGroups)
  .map(([idx, vals]) => ({
    idx, n: vals.length,
    med: median(vals),
    p25: quantile(vals, 0.25),
    p75: quantile(vals, 0.75),
  }))
  .sort((a, b) => b.med - a.med);

// ── Sector comparison ─────────────────────────────────────────────────────────
const sectorGroups: Record<string, number[]> = {};
for (const s of valid) {
  const sec = (s as any).sector || 'Other';
  if (!sectorGroups[sec]) sectorGroups[sec] = [];
  sectorGroups[sec].push((s as any).rg10);
}
const sectorStats = Object.entries(sectorGroups)
  .map(([sector, vals]) => ({
    sector, n: vals.length,
    med: median(vals),
    min: Math.min(...vals),
    max: Math.max(...vals),
  }))
  .sort((a, b) => b.med - a.med);
const maxSectorMed = Math.max(...sectorStats.map(s => s.med));

// ── Time series ───────────────────────────────────────────────────────────────
const qPeriodMap: Record<string, number[]> = {};
for (const d of allCompanies) {
  for (const o of d.observations as any[]) {
    if (o.dataType !== 'quarterly') continue;
    if (o.rg10 == null || o.nearBoundary) continue;
    if (!qPeriodMap[o.periodKey]) qPeriodMap[o.periodKey] = [];
    qPeriodMap[o.periodKey].push(o.rg10);
  }
}
const timeSeries = Object.entries(qPeriodMap)
  .filter(([, vals]) => vals.length >= 15)
  .map(([pk, vals]) => ({
    periodKey: pk,
    label:     pk.replace(/^(\d{4})_q(\d)$/, 'Q$2 $1'),
    n:         vals.length,
    med:       median(vals),
    p25:       quantile(vals, 0.25),
    p75:       quantile(vals, 0.75),
  }))
  .sort((a, b) => a.periodKey.localeCompare(b.periodKey));

// ── Valuation Fragility Analysis ─────────────────────────────────────────────
const FRAG_PERIODS = ['2023_q4', '2024_q4', '2025_q1', '2025_q2', '2025_q3', '2025_q4'];
const FRAG_LABELS: Record<string, string> = {
  '2023_q4': 'GJ 2023', '2024_q4': 'GJ 2024',
  '2025_q1': 'Q1 2025', '2025_q2': 'Q2 2025',
  '2025_q3': 'Q3 2025', '2025_q4': 'Q4 2025',
};
const FRAG_DTYPE: Record<string, string> = {
  '2023_q4': 'annual', '2024_q4': 'annual',
  '2025_q1': 'quarterly', '2025_q2': 'quarterly',
  '2025_q3': 'quarterly', '2025_q4': 'quarterly',
};

const fragMaps: Record<string, Map<string, number>> = {};
for (const pk of FRAG_PERIODS) fragMaps[pk] = new Map<string, number>();
for (const d of allCompanies) {
  for (const o of d.observations as any[]) {
    const pk = o.periodKey as string;
    if (!FRAG_PERIODS.includes(pk)) continue;
    if (o.rg10 == null || o.nearBoundary) continue;
    fragMaps[pk].set(d.company as string, o.rg10 as number);
  }
}

let fragPanel: Set<string> = new Set(fragMaps[FRAG_PERIODS[0]!]!.keys());
for (const pk of FRAG_PERIODS.slice(1)) {
  fragPanel = new Set([...fragPanel].filter(c => fragMaps[pk]!.has(c)));
}
const fragPanelN = fragPanel.size;
const fragMethod = fragPanelN >= 30 ? 'quartile' : 'third';
const fragMethodLabel = fragMethod === 'quartile'
  ? tc.fragility.methodQuartile
  : tc.fragility.methodThird;

interface FragRow {
  periodKey: string; label: string; dataType: string; n: number;
  conservativeMedian: number; highMedian: number;
  spread: number; ratio: number;
  spreadChange: number | null; ratioChange: number | null;
  upperTailShare: number;
}

const fragSeries: FragRow[] = [];
let prevFSpread: number | null = null;
let prevFRatio: number | null = null;

for (const pk of FRAG_PERIODS) {
  const vals = [...fragPanel].map(c => fragMaps[pk]!.get(c)!).sort((a, b) => a - b);
  const n = vals.length;
  let consVals: number[], highVals: number[];
  if (fragMethod === 'quartile') {
    const q1 = quantile(vals, 0.25), q3 = quantile(vals, 0.75);
    consVals = vals.filter(v => v <= q1);
    highVals = vals.filter(v => v >= q3);
  } else {
    const t = Math.floor(n / 3);
    consVals = vals.slice(0, t);
    highVals = vals.slice(n - t);
  }
  const consMedian = median(consVals);
  const highMedian = median(highVals);
  const spread    = highMedian - consMedian;
  const ratio     = consMedian > 0 ? highMedian / consMedian : 0;
  const upperTail = vals.filter(v => v > 3.0).length / n;
  fragSeries.push({
    periodKey: pk, label: FRAG_LABELS[pk] ?? pk, dataType: FRAG_DTYPE[pk] ?? '?', n,
    conservativeMedian: consMedian, highMedian,
    spread, ratio,
    spreadChange: prevFSpread !== null ? spread - prevFSpread : null,
    ratioChange:  prevFRatio  !== null ? ratio  - prevFRatio  : null,
    upperTailShare: upperTail,
  });
  prevFSpread = spread;
  prevFRatio  = ratio;
}

const maxFSpread = Math.max(...fragSeries.map(r => r.spread));
const maxFRatio  = Math.max(...fragSeries.map(r => r.ratio));
const maxFHigh   = Math.max(...fragSeries.map(r => r.highMedian));
const fragPeak   = fragSeries.find(r => r.spread === maxFSpread)!;
const fragLatest = fragSeries[fragSeries.length - 1]!;
---

<BaseLayout
  title="Historische Forschung — Reality Gap"
  description="Explorative retrospektive Analyse von Reality-Gap-Daten. Vorläufig, approximiert und keine Anlageberatung."
  lang="de"
  altLangPath="/research"
  altLang="en"
>
  <div class="max-w-5xl mx-auto px-6 py-10">

    <div class="mb-8">
      <p class="text-xs text-gray-400 uppercase tracking-widest mb-2">{tc.label}</p>
      <h1 class="text-3xl font-light text-gray-900 mb-3" style="font-family: Georgia, serif;">
        {tc.heading}
      </h1>
      <p class="text-gray-500 text-base max-w-2xl">{tc.subheading}</p>
    </div>

    <div class="border border-amber-300 bg-amber-50 rounded-md px-6 py-5 mb-10">
      <p class="text-sm font-semibold text-amber-800 mb-2">{tc.disclaimer.heading}</p>
      <p class="text-sm text-amber-700 leading-relaxed">{tc.disclaimer.body}</p>
    </div>

    <!-- 1. Cross-index -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.indexSection.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.indexSection.note}</p>
      <div class="border border-gray-200 rounded-md overflow-hidden mb-3">
        <table class="table-rg">
          <thead>
            <tr class="bg-gray-50 text-xs uppercase text-gray-500 tracking-wide">
              <th class="text-left px-4 py-2 font-medium">{tc.indexSection.colIndex}</th>
              <th class="text-right px-4 py-2 font-medium">{tc.indexSection.colN}</th>
              <th class="text-right px-4 py-2 font-medium">{tc.indexSection.colP25}</th>
              <th class="text-right px-4 py-2 font-semibold text-gray-700">{tc.indexSection.colMedian}</th>
              <th class="text-right px-4 py-2 font-medium">{tc.indexSection.colP75}</th>
            </tr>
          </thead>
          <tbody>
            {indexStats.map(row => (
              <tr class="border-t border-gray-100">
                <td class="px-4 py-2 text-gray-700 font-medium">{row.idx}</td>
                <td class="px-4 py-2 text-right font-mono text-gray-500">{row.n}</td>
                <td class="px-4 py-2 text-right font-mono text-gray-500">{fmt(row.p25)}</td>
                <td class="px-4 py-2 text-right font-mono font-semibold text-gray-900">{fmt(row.med)}</td>
                <td class="px-4 py-2 text-right font-mono text-gray-500">{fmt(row.p75)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400">{tc.indexSection.footnote}</p>
    </section>

    <!-- 2. Distribution -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.distribution.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">
        {tc.distribution.note
          .replace('{n}', String(valid.length))
          .replace('{total}', String(summaries.length))
          .replace('{notCovered}', String(notCoveredCount))
          .replace('{nearBoundary}', String(nearBoundaryCount))}
      </p>
      <div class="space-y-2 mb-5">
        {buckets.map(b => (
          <div class="flex items-center gap-3">
            <span class="text-xs font-mono text-gray-500 w-14 text-right shrink-0">{b.label}</span>
            <div class="flex-1 bg-gray-100 rounded-sm h-6 relative">
              <div
                class="h-6 rounded-sm bg-accent/70"
                style={`width: ${maxBucketCount > 0 ? Math.round((b.count / maxBucketCount) * 100) : 0}%`}
              />
            </div>
            <span class="text-xs font-mono text-gray-700 w-8 shrink-0">{b.count}</span>
          </div>
        ))}
      </div>
      <div class="grid grid-cols-3 gap-4">
        {[
          { label: 'P25', value: fmt(p25) },
          { label: tc.distribution.medianLabel, value: fmt(med) },
          { label: 'P75', value: fmt(p75) },
        ].map(item => (
          <div class="border border-gray-200 rounded-md p-4 text-center">
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">{item.label}</p>
            <p class="text-2xl font-light text-gray-800" style="font-family: Georgia, serif;">{item.value}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 3. Sectors -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.sectors.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.sectors.note}</p>
      <div class="space-y-2 mb-4">
        {sectorStats.map(s => (
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-600 shrink-0 text-right" style="width: 200px; min-width: 200px;">
              {s.sector}
            </span>
            <div class="flex-1 bg-gray-100 rounded-sm h-5 relative">
              <div
                class="h-5 rounded-sm bg-accent/60"
                style={`width: ${maxSectorMed > 0 ? Math.round((s.med / maxSectorMed) * 100) : 0}%`}
              />
            </div>
            <span class="text-xs font-mono font-semibold text-gray-800 w-10 shrink-0">{fmt(s.med)}</span>
            <span class="text-xs font-mono text-gray-400 w-8 shrink-0">n={s.n}</span>
          </div>
        ))}
      </div>
      <p class="text-xs text-gray-400">{tc.sectors.footnote}</p>
    </section>

    <!-- 4. Time series -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.timeSeries.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.timeSeries.note}</p>
      {timeSeries.length > 0 ? (
        <div class="border border-gray-200 rounded-md overflow-hidden mb-3">
          <table class="table-rg">
            <thead>
              <tr class="bg-gray-50 text-xs uppercase text-gray-500 tracking-wide">
                <th class="text-left px-4 py-2 font-medium">{tc.timeSeries.colPeriod}</th>
                <th class="text-right px-4 py-2 font-medium">{tc.timeSeries.colN}</th>
                <th class="text-right px-4 py-2 font-medium">{tc.timeSeries.colP25}</th>
                <th class="text-right px-4 py-2 font-semibold text-gray-700">{tc.timeSeries.colMedian}</th>
                <th class="text-right px-4 py-2 font-medium">{tc.timeSeries.colP75}</th>
              </tr>
            </thead>
            <tbody>
              {timeSeries.map(row => (
                <tr class="border-t border-gray-100">
                  <td class="px-4 py-2 text-gray-700 font-medium">{row.label}</td>
                  <td class="px-4 py-2 text-right font-mono text-gray-500">{row.n}</td>
                  <td class="px-4 py-2 text-right font-mono text-gray-500">{fmt(row.p25)}</td>
                  <td class="px-4 py-2 text-right font-mono font-semibold text-gray-900">{fmt(row.med)}</td>
                  <td class="px-4 py-2 text-right font-mono text-gray-500">{fmt(row.p75)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="border border-gray-200 rounded-md px-5 py-6 text-center text-sm text-gray-400">
          {tc.timeSeries.noData}
        </div>
      )}
      <p class="text-xs text-gray-400">{tc.timeSeries.footnote}</p>
    </section>

    <!-- 5. Valuation Fragility Divergence -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-1">{tc.fragility.heading}</h2>
      <p class="text-sm text-gray-500 mb-5">{tc.fragility.subheading}</p>

      <div class="border border-gray-200 rounded-md bg-gray-50/60 px-5 py-4 mb-7 text-sm text-gray-600 leading-relaxed">
        <p class="font-semibold text-gray-700 mb-1">Panel-Konstruktion</p>
        <p>{tc.fragility.panelNote(fragPanelN, FRAG_PERIODS.length, fragMethodLabel)}</p>
        <p class="mt-2 text-xs text-gray-500">{tc.fragility.dataTypeNote}</p>
      </div>

      <p class="text-xs text-gray-400 uppercase tracking-widest mb-3">{tc.fragility.signalHeading}</p>
      <div class="grid grid-cols-2 gap-3 mb-8">
        {[
          { label: tc.fragility.peakSpreadLabel,   value: fmt(fragPeak.spread, 2),        note: fragPeak.label },
          { label: tc.fragility.currentSpreadLabel, value: fmt(fragLatest.spread, 2),      note: fragLatest.label },
          { label: tc.fragility.peakRatioLabel,    value: fmt(fragPeak.ratio, 1) + '×',   note: fragPeak.label },
          { label: tc.fragility.currentRatioLabel,  value: fmt(fragLatest.ratio, 1) + '×', note: fragLatest.label },
        ].map(card => (
          <div class="border border-gray-200 rounded-md p-4">
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">{card.label}</p>
            <p class="text-2xl font-light text-gray-800" style="font-family: Georgia, serif;">{card.value}</p>
            <p class="text-xs text-gray-400 mt-1">{card.note}</p>
          </div>
        ))}
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.divergenceChartHeading}</h3>
      <div class="flex items-center gap-5 mb-3 text-xs text-gray-500">
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-3 rounded-sm bg-teal-400/80"></span>
          {tc.fragility.divergenceLegendCons}
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-3 h-3 rounded-sm bg-orange-400/70"></span>
          {tc.fragility.divergenceLegendHigh}
        </span>
      </div>
      <div class="space-y-4 mb-8">
        {fragSeries.map(row => (
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-mono text-gray-600 w-16 shrink-0 text-right">{row.label}</span>
              <span class="text-xs text-gray-400 w-16 shrink-0">{row.dataType === 'annual' ? tc.fragility.annualLabel : tc.fragility.quarterlyLabel}</span>
            </div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-gray-400 w-32 shrink-0 text-right">{tc.fragility.divergenceLegendCons.split(' ').slice(-1)[0]}</span>
              <div class="flex-1 bg-gray-100 rounded-sm h-4 relative">
                <div class="h-4 rounded-sm bg-teal-400/70"
                  style={`width: ${maxFHigh > 0 ? Math.round((row.conservativeMedian / maxFHigh) * 100) : 0}%`} />
              </div>
              <span class="text-xs font-mono text-gray-600 w-8 shrink-0">{fmt(row.conservativeMedian)}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-400 w-32 shrink-0 text-right">{tc.fragility.divergenceLegendHigh.split(' ').slice(-1)[0]}</span>
              <div class="flex-1 bg-gray-100 rounded-sm h-4 relative">
                <div class={`h-4 rounded-sm ${row.spread === maxFSpread ? 'bg-orange-500/70' : 'bg-orange-400/55'}`}
                  style={`width: ${maxFHigh > 0 ? Math.round((row.highMedian / maxFHigh) * 100) : 0}%`} />
              </div>
              <span class="text-xs font-mono font-semibold text-gray-700 w-8 shrink-0">{fmt(row.highMedian)}</span>
              {row.spread === maxFSpread && (
                <span class="text-xs text-orange-600 font-medium shrink-0">← {tc.fragility.peakAnnotation}</span>
              )}
            </div>
          </div>
        ))}
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.spreadChartHeading}</h3>
      <div class="space-y-2 mb-8">
        {fragSeries.map(row => (
          <div class="flex items-center gap-3">
            <span class="text-xs font-mono text-gray-500 w-16 text-right shrink-0">{row.label}</span>
            <div class="flex-1 bg-gray-100 rounded-sm h-6 relative">
              <div class={`h-6 rounded-sm ${row.spread === maxFSpread ? 'bg-accent' : 'bg-accent/55'}`}
                style={`width: ${maxFSpread > 0 ? Math.round((row.spread / maxFSpread) * 100) : 0}%`} />
            </div>
            <span class="text-xs font-mono text-gray-700 w-10 shrink-0">{fmt(row.spread)}</span>
            {row.spread === maxFSpread && (
              <span class="text-xs text-accent font-semibold shrink-0">{tc.fragility.peakAnnotation}</span>
            )}
            {row.spreadChange !== null && (
              <span class={`text-xs font-mono shrink-0 w-14 ${row.spreadChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                {row.spreadChange >= 0 ? '+' : ''}{fmt(row.spreadChange)}
              </span>
            )}
          </div>
        ))}
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.ratioChartHeading}</h3>
      <div class="space-y-2 mb-8">
        {fragSeries.map(row => (
          <div class="flex items-center gap-3">
            <span class="text-xs font-mono text-gray-500 w-16 text-right shrink-0">{row.label}</span>
            <div class="flex-1 bg-gray-100 rounded-sm h-6 relative">
              <div class={`h-6 rounded-sm ${row.ratio === maxFRatio ? 'bg-accent' : 'bg-accent/55'}`}
                style={`width: ${maxFRatio > 0 ? Math.round((row.ratio / maxFRatio) * 100) : 0}%`} />
            </div>
            <span class="text-xs font-mono text-gray-700 w-10 shrink-0">{fmt(row.ratio, 1)}×</span>
            {row.ratio === maxFRatio && (
              <span class="text-xs text-accent font-semibold shrink-0">{tc.fragility.peakAnnotation}</span>
            )}
            {row.ratioChange !== null && (
              <span class={`text-xs font-mono shrink-0 w-14 ${row.ratioChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                {row.ratioChange >= 0 ? '+' : ''}{fmt(row.ratioChange, 1)}×
              </span>
            )}
          </div>
        ))}
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.tableHeading}</h3>
      <div class="border border-gray-200 rounded-md overflow-hidden mb-6 text-xs">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-50 text-gray-500 uppercase tracking-wide">
              <th class="text-left px-3 py-2 font-medium">{tc.fragility.colPeriod}</th>
              <th class="text-left px-3 py-2 font-medium">{tc.fragility.colType}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colConsMedian}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colHighMedian}</th>
              <th class="text-right px-3 py-2 font-medium font-semibold text-gray-700">{tc.fragility.colSpread}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colSpreadChange}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colRatio}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colRatioChange}</th>
              <th class="text-right px-3 py-2 font-medium">{tc.fragility.colUpperTail}</th>
            </tr>
          </thead>
          <tbody>
            {fragSeries.map(row => (
              <tr class={`border-t border-gray-100 ${row.spread === maxFSpread ? 'bg-orange-50/40' : ''}`}>
                <td class="px-3 py-2 font-medium text-gray-700">
                  {row.label}
                  {row.spread === maxFSpread && (
                    <span class="ml-1 text-orange-500 text-xs">↑ {tc.fragility.peakAnnotation}</span>
                  )}
                </td>
                <td class="px-3 py-2 text-gray-400">{row.dataType === 'annual' ? tc.fragility.annualLabel : tc.fragility.quarterlyLabel}</td>
                <td class="px-3 py-2 text-right font-mono text-gray-600">{fmt(row.conservativeMedian)}</td>
                <td class="px-3 py-2 text-right font-mono text-gray-600">{fmt(row.highMedian)}</td>
                <td class="px-3 py-2 text-right font-mono font-semibold text-gray-900">{fmt(row.spread)}</td>
                <td class={`px-3 py-2 text-right font-mono ${row.spreadChange == null ? 'text-gray-300' : row.spreadChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                  {row.spreadChange == null ? '—' : (row.spreadChange >= 0 ? '+' : '') + fmt(row.spreadChange)}
                </td>
                <td class="px-3 py-2 text-right font-mono text-gray-700">{fmt(row.ratio, 1)}×</td>
                <td class={`px-3 py-2 text-right font-mono ${row.ratioChange == null ? 'text-gray-300' : row.ratioChange >= 0 ? 'text-orange-500' : 'text-teal-600'}`}>
                  {row.ratioChange == null ? '—' : (row.ratioChange >= 0 ? '+' : '') + fmt(row.ratioChange, 1) + '×'}
                </td>
                <td class="px-3 py-2 text-right font-mono text-gray-500">{Math.round(row.upperTailShare * 100)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="text-sm font-semibold text-gray-700 mb-3">{tc.fragility.interpretation.heading}</h3>
      <div class="space-y-3 mb-5">
        {tc.fragility.interpretation.items.map((item: { title: string; body: string }) => (
          <div class="border-l-2 border-gray-200 pl-4">
            <p class="text-sm font-semibold text-gray-700 mb-0.5">{item.title}</p>
            <p class="text-sm text-gray-500">{item.body}</p>
          </div>
        ))}
      </div>

      <p class="text-xs text-gray-400 border border-gray-100 rounded-md bg-gray-50/50 px-4 py-3">
        {tc.fragility.limitationNote}
      </p>
    </section>

    <!-- 6. Use cases -->
    <section class="mb-12">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">{tc.useCases.heading}</h2>
      <div class="space-y-4">
        {tc.useCases.items.map((item: { title: string; body: string }) => (
          <div class="border-l-2 border-gray-200 pl-4">
            <p class="text-sm font-semibold text-gray-700 mb-1">{item.title}</p>
            <p class="text-sm text-gray-500">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 7. Limitations -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">{tc.limitations.heading}</h2>
      <div class="border border-gray-200 rounded-md p-5">
        <ul class="space-y-3">
          {tc.limitations.items.map((item: string) => (
            <li class="flex gap-3 text-sm text-gray-600">
              <span class="text-gray-300 shrink-0 mt-0.5">–</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <p class="text-xs text-gray-400 border-t border-gray-100 pt-6">{t.companyDetail.disclaimer}</p>
  </div>
</BaseLayout>
