---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import MetricBlock from '../../../components/ui/MetricBlock.astro';
import TrendBadge from '../../../components/ui/TrendBadge.astro';
import RGChart from '../../../components/ui/RGChart.astro';
import { de } from '../../../i18n/de';
import type { Company } from '../../../lib/rg';
import { getLatestObservation, formatRGCapped, formatRGLabel } from '../../../lib/rg';
import { formatBillions } from '../../../lib/format';
import slugsJson from '../../../data/companies.index.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const t = de;

export async function getStaticPaths() {
  const slugs: string[] = (await import('../../../data/companies.index.json')).default;
  return Promise.all(
    slugs.map(async slug => {
      const company: Company = (await import(`../../../data/companies/${slug}.json`)).default;
      return { params: { slug }, props: { company } };
    })
  );
}

interface Props {
  company: Company;
}

const { company } = Astro.props;
const obs = getLatestObservation(company);
const tc = t.companyDetail;

// German trend labels
const trendLabelsDE: Record<string, string> = {
  '++': 'Stark steigend',
  '+':  'Steigend',
  '=':  'Stabil',
  '-':  'Sinkend',
  '--': 'Stark sinkend',
};
const trendLabel = obs?.trend ? (trendLabelsDE[obs.trend] ?? obs.trend) : undefined;
---

<BaseLayout
  title={`${company.company} — Reality Gap`}
  description={`Reality-Gap-Werte für ${company.company} (${company.ticker}). RG8, RG10, RG12 und Trend für ${obs?.periodLabel ?? 'aktuellste Periode'}.`}
  lang="de"
  canonicalPath={`/de/unternehmen/${company.slug}`}
  altLangPath={`/companies/${company.slug}`}
  altLang="en"
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    <a href={`${base}/de/unternehmen`} class="text-sm text-gray-400 hover:text-accent no-underline mb-6 block">
      {tc.backToCompanies}
    </a>

    <div class="mb-8">
      <div class="flex flex-wrap items-start gap-4 justify-between">
        <div>
          <h1 class="text-3xl font-normal text-gray-900" style="font-family: Georgia, serif;">
            {company.company}
          </h1>
          <p class="text-gray-500 mt-1">
            <span class="font-mono text-sm">{company.ticker}</span>
            {' · '}
            <span>{company.sector}</span>
            {' · '}
            <span>{company.currency}</span>
          </p>
        </div>
        {obs && (
          <div class="text-right">
            <p class="text-xs text-gray-400 mb-1">{tc.latestObservation}</p>
            <p class="text-sm font-medium text-gray-700">{obs.periodLabel}</p>
          </div>
        )}
      </div>
    </div>

    {obs ? (
      <>
        <h2 class="text-lg font-semibold text-gray-800 mb-4">{tc.metrics.heading}</h2>
        {obs.rg8 === null && obs.rg10 === null && obs.rg12 === null ? (
          <div class="border border-amber-200 bg-amber-50 rounded-md px-5 py-4 mb-8">
            <p class="text-sm font-semibold text-amber-800 mb-1">{tc.metrics.notComputable}</p>
            <p class="text-sm text-amber-700">{tc.metrics.notComputableNote}</p>
          </div>
        ) : (
          <>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
              <MetricBlock
                label={formatRGLabel(8, obs.periodLabel)}
                value={formatRGCapped(obs.rg8)}
                nearBoundary={(obs as any).nearBoundary === true}
              />
              <MetricBlock
                label={formatRGLabel(10, obs.periodLabel)}
                value={formatRGCapped(obs.rg10)}
                highlight={(obs as any).nearBoundary !== true}
                nearBoundary={(obs as any).nearBoundary === true}
              />
              <MetricBlock
                label={formatRGLabel(12, obs.periodLabel)}
                value={formatRGCapped(obs.rg12)}
                nearBoundary={(obs as any).nearBoundary === true}
              />
            </div>
            {(obs as any).nearBoundary === true && (
              <div class="border border-amber-200 bg-amber-50 rounded-md px-5 py-3 mb-8">
                <p class="text-sm font-semibold text-amber-800 mb-1">{tc.metrics.nearBoundaryHeading}</p>
                <p class="text-sm text-amber-700">{tc.metrics.nearBoundaryNote}</p>
              </div>
            )}
            {(obs as any).nearBoundary !== true && <div class="mb-8" />}
          </>
        )}

        <div class="mb-8">
          <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">{tc.trend}</p>
          <TrendBadge trend={obs.trend} label={trendLabel} />
        </div>

        {(obs.marketCap !== undefined || obs.tangentialEquity !== undefined || (obs as any).smoothedEarnings !== undefined || obs.fundamentalBaseRG10 !== undefined) && (
          <div class="mb-8">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">{tc.supportingData.heading}</h2>
            <div class="border border-gray-200 rounded-md overflow-hidden">
              <table class="table-rg">
                <tbody>
                  {obs.marketCap !== undefined && (
                    <tr>
                      <td class="text-gray-600">{tc.supportingData.marketCap}</td>
                      <td class="text-right font-mono">{formatBillions(obs.marketCap, company.currency)}</td>
                    </tr>
                  )}
                  {(obs as any).tangibleEquity !== undefined && (
                    <tr>
                      <td class="text-gray-600">{tc.supportingData.tangibleEquity}{(obs as any).teIsApprox ? ' *' : ''}</td>
                      <td class="text-right font-mono">{formatBillions((obs as any).tangibleEquity, company.currency)}</td>
                    </tr>
                  )}
                  {(obs as any).smoothedEarnings !== undefined && (obs as any).smoothedEarnings !== null && (
                    <tr>
                      <td class="text-gray-600">{tc.supportingData.smoothedEarnings}</td>
                      <td class="text-right font-mono">{formatBillions((obs as any).smoothedEarnings, company.currency)}</td>
                    </tr>
                  )}
                  {(obs as any).fundamentalBaseRG10 !== undefined && (
                    <tr>
                      <td class="text-gray-600">{tc.supportingData.fundamentalBase}</td>
                      <td class="text-right font-mono">{formatBillions((obs as any).fundamentalBaseRG10, company.currency)}</td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
            {(obs as any).teIsApprox && (
              <p class="text-xs text-gray-400 mt-1">* {tc.supportingData.teApprox}</p>
            )}
            <p class="text-xs text-gray-400 mt-1">{tc.supportingData.billions}.</p>
          </div>
        )}

        {obs.note && (
          <div class="border-l-2 border-amber-200 pl-4 py-1 mb-8">
            <p class="text-xs text-gray-500 font-medium mb-1">{tc.dataNote}</p>
            <p class="text-sm text-gray-600">{obs.note}</p>
          </div>
        )}

        <!-- Historischer RG-Verlauf (nur Quartalsbeobachtungen) -->
        <RGChart
          company={company}
          headingLabel={tc.historicalChart.heading}
          noDataLabel={tc.historicalChart.noData}
          shorterHistLabel={tc.historicalChart.shorterHistory}
        />
      </>
    ) : (
      <p class="text-gray-500">Keine Daten für dieses Unternehmen verfügbar.</p>
    )}

    <p class="text-xs text-gray-400 border-t border-gray-100 pt-6">{tc.disclaimer}</p>
  </div>
</BaseLayout>
