---
/**
 * RGChart.astro
 *
 * Renders a Chart.js line chart of RG8 / RG10 / RG12 over time.
 *
 * DATA INTEGRITY RULES
 * ─────────────────────
 * • Only observations with dataType === "quarterly" are plotted.
 *   These are derived from real yfinance quarterly income statements.
 * • Observations with dataType === "annual" (synthetic annual-NI / 4
 *   approximations) are intentionally excluded from the chart.
 * • No values are fabricated, interpolated, or simulated.
 * • If fewer than 2 qualifying observations exist, an honest empty-state
 *   message is displayed instead of a chart.
 * • If fewer than 40 observations (< 10 years) are present, a disclaimer
 *   note is shown beneath the chart.
 *
 * PROPS
 * ─────
 * company          – Full Company object from the JSON data file.
 * headingLabel     – Section heading text (localised by caller).
 * noDataLabel      – Message shown when < 2 real quarterly observations exist.
 * shorterHistLabel – Note shown when < 40 real quarterly observations exist.
 */

import type { Company } from '../../lib/rg';

interface Props {
  company: Company;
  headingLabel?: string;
  noDataLabel?: string;
  shorterHistLabel?: string;
}

const {
  company,
  headingLabel    = 'Historical RG Values',
  noDataLabel     = 'Historical RG chart not yet available for this company.',
  shorterHistLabel = 'Historical series shorter than 10 years due to current data availability.',
} = Astro.props;

// ── Filter: only real quarterly observations ──────────────────────────────────
// dataType === "quarterly"  →  derived from yfinance quarterly_income_stmt
// dataType === "annual"     →  synthetic (annual NI / 4); excluded from chart
const quarterlyObs = company.observations
  .filter(o => (o as any).dataType === 'quarterly')
  .filter(o => o.rg8 !== null || o.rg10 !== null || o.rg12 !== null)
  .sort((a, b) => (a.periodKey < b.periodKey ? -1 : a.periodKey > b.periodKey ? 1 : 0));

const hasEnoughData  = quarterlyObs.length >= 2;
const isPartialHist  = quarterlyObs.length < 40;   // 40 quarters ≈ 10 years

// Serialise only the data that will actually be rendered
const labels   = quarterlyObs.map(o => o.periodLabel);
const rg8Data  = quarterlyObs.map(o => o.rg8  ?? null);
const rg10Data = quarterlyObs.map(o => o.rg10 ?? null);
const rg12Data = quarterlyObs.map(o => o.rg12 ?? null);

const canvasId   = `rg-chart-${company.slug}`;
const serialised = JSON.stringify({ labels, rg8: rg8Data, rg10: rg10Data, rg12: rg12Data });
---

<div class="mb-8">
  <h2 class="text-lg font-semibold text-gray-800 mb-4">{headingLabel}</h2>

  {hasEnoughData ? (
    <>
      {/* Legend */}
      <div class="flex flex-wrap gap-4 mb-3 text-xs text-gray-500 select-none">
        <span class="flex items-center gap-1.5">
          <svg width="24" height="10" aria-hidden="true">
            <line x1="0" y1="5" x2="24" y2="5"
              stroke="#7ba7c9" stroke-width="1.5" stroke-dasharray="4 3" />
          </svg>
          RG8
        </span>
        <span class="flex items-center gap-1.5">
          <svg width="24" height="10" aria-hidden="true">
            <line x1="0" y1="5" x2="24" y2="5"
              stroke="#1e4d78" stroke-width="2.5" />
          </svg>
          RG10
        </span>
        <span class="flex items-center gap-1.5">
          <svg width="24" height="10" aria-hidden="true">
            <line x1="0" y1="5" x2="24" y2="5"
              stroke="#3d8b85" stroke-width="1.5" />
          </svg>
          RG12
        </span>
      </div>

      {/* Chart canvas */}
      <div class="relative" style="height: 260px;">
        <canvas
          id={canvasId}
          data-chart={serialised}
          aria-label={`RG chart for ${company.company}`}
          role="img"
          style="width: 100%; height: 100%;"
        ></canvas>
      </div>

      {/* Honest data-availability note */}
      {isPartialHist && (
        <p class="text-xs text-gray-400 mt-2 italic">{shorterHistLabel}</p>
      )}
    </>
  ) : (
    /* Empty state – shown when fewer than 2 real quarterly observations exist */
    <div class="border border-dashed border-gray-200 rounded-md px-6 py-8 bg-gray-50 text-center">
      <p class="text-sm text-gray-400">{noDataLabel}</p>
    </div>
  )}
</div>

<script>
  function initRGCharts(): void {
    const canvases = document.querySelectorAll<HTMLCanvasElement>('canvas[data-chart]');
    if (!canvases.length) return;

    // @ts-ignore – Chart.js loaded via CDN
    const Chart = (window as any).Chart;
    if (!Chart) return;

    canvases.forEach(canvas => {
      // Prevent double-initialisation (Astro view-transitions etc.)
      if ((canvas as any).__rgChartInit) return;
      (canvas as any).__rgChartInit = true;

      const raw = canvas.getAttribute('data-chart');
      if (!raw) return;

      const { labels, rg8, rg10, rg12 } = JSON.parse(raw) as {
        labels: string[];
        rg8:  (number | null)[];
        rg10: (number | null)[];
        rg12: (number | null)[];
      };

      new Chart(canvas, {
        type: 'line',
        data: {
          labels,
          datasets: [
            {
              label: 'RG8',
              data: rg8,
              borderColor: '#7ba7c9',
              backgroundColor: 'transparent',
              borderWidth: 1.5,
              borderDash: [4, 3],
              pointRadius: 3,
              pointHoverRadius: 5,
              tension: 0.2,
              spanGaps: false,
            },
            {
              label: 'RG10',
              data: rg10,
              borderColor: '#1e4d78',
              backgroundColor: 'transparent',
              borderWidth: 2.5,
              pointRadius: 3,
              pointHoverRadius: 5,
              tension: 0.2,
              spanGaps: false,
            },
            {
              label: 'RG12',
              data: rg12,
              borderColor: '#3d8b85',
              backgroundColor: 'transparent',
              borderWidth: 1.5,
              pointRadius: 3,
              pointHoverRadius: 5,
              tension: 0.2,
              spanGaps: false,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: false,
          interaction: {
            mode: 'index',
            intersect: false,
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx: any): string => {
                  const v = ctx.parsed.y;
                  return v !== null && v !== undefined
                    ? `${ctx.dataset.label}: ${Number(v).toFixed(2)}×`
                    : `${ctx.dataset.label}: —`;
                },
              },
            },
          },
          scales: {
            x: {
              grid: { display: false },
              ticks: {
                color: '#9ca3af',
                font: { size: 10 },
                maxRotation: 45,
                autoSkip: true,
                maxTicksLimit: 12,
              },
              border: { color: '#e5e7eb' },
            },
            y: {
              beginAtZero: false,
              grid: { color: '#f3f4f6' },
              ticks: {
                color: '#9ca3af',
                font: { size: 10 },
                callback: (v: any): string => `${Number(v).toFixed(1)}×`,
              },
              border: { color: '#e5e7eb' },
            },
          },
        },
      });
    });
  }

  function loadChartJs(callback: () => void): void {
    // @ts-ignore
    if ((window as any).Chart) { callback(); return; }

    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    script.onload = callback;
    script.onerror = (): void => {
      console.warn('RGChart: failed to load Chart.js from CDN');
    };
    document.head.appendChild(script);
  }

  loadChartJs(initRGCharts);
</script>
